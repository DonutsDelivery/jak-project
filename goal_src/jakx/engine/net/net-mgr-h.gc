(deftype net-mgr-game-state (structure)
  ((connect-handle      basic)
   (local-machine-idx   int32)
   (session-master-idx  int32)
   (host-idx            int32)
   (connected-bitfield  int32)
   (time                int32)
   (first-time-host     symbol)
   (locked              symbol)
   (kicked              symbol)
   (sm-eligible         symbol)
   )
  :pack-me
  )


(deftype net-mgr-lobby-state (structure)
  ((connect-handle          basic)
   (connect-handle-mgcl     basic)
   (connect-handle-muis     basic)
   (my-account-id           int32)
   (channel-id              int32)
   (in-special-channel      symbol)
   (last-normal-channel-id  int32)
   (created-game-id         int32)
   (joined-game-id          int32)
   (channel-list-valid      symbol)
   (last-medius-error       int32)
   (last-mgcl-error         int32)
   (last-dme-error          int32)
   (callback-occurred       symbol)
   (callback-status         int32)
   (callback-userdata       basic)
   (timeout                 symbol)
   (got-error               symbol)
   (last-report-time        int32)
   (game-on-me              uint64)
   (game-on-me-error-delay  int32)
   )
  )


(deftype net-mgr (process)
