(deftype net-available-game-info (structure)
  ((game-name     uint8   64)
   (player-count  uint8)
   (min-players   uint8)
   (max-players   uint8)
   (in-staging    symbol)
   (event         uint8)
   (location      uint8)
   (task-node     uint8)
   (generic-1     int32)
   (generic-2     int32)
   (generic-3     int32)
   (burn-version  uint32  :overlay-at generic-1)
   (lobby-world   int32   :overlay-at generic-2)
   (class-type    int32   :overlay-at generic-3)
   (clan-1        int32)
   (clan-2        int32)
   (skill-level   int32)
   (avg-ping      int32)
   )
  )


