(defmethod relocate ((this net-simple-destruct-mgr) (offset int))
  (set! *net-simple-destruct-mgr* this)
  (if *net-simple-destruct-mgr*
      (set! *net-simple-destruct-mgr* (+ (the-as uint *net-simple-destruct-mgr*) offset))
