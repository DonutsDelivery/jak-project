  (the-as net-simple-destruct-mgr ((method-of-type process-nettable relocate) this offset))
  )

(defmethod deactivate ((this net-simple-destruct-mgr))
  "Make a process dead, clean it up, remove it from the active pool, and return to dead pool."
  (set! *net-simple-destruct-mgr* (the-as object #f))
  ((method-of-type process-nettable deactivate) this)
  )

