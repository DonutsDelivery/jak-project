;;-*-Lisp-*-
(in-package goal)

;; definition of type ip-to-name-map
(deftype ip-to-name-map (structure)
  ((ip        uint32)
   (mac       uint64)
   (name      basic)
   (has-16x9  basic)
   )
  )

;; definition for method 3 of type ip-to-name-map
(defmethod inspect ((this ip-to-name-map))
  (when (not this)
    (set! this this)
    (goto cfg-4)
    )
  (format #t "[~8x] ~A~%" this 'ip-to-name-map)
  (format #t "~1Tip: ~D~%" (-> this ip))
  (format #t "~1Tmac: ~D~%" (-> this mac))
  (format #t "~1Tname: ~A~%" (-> this name))
  (format #t "~1Thas-16x9: ~A~%" (-> this has-16x9))
  (label cfg-4)
  this
  )

;; definition for symbol *ip-to-name-map*, type array
(define *ip-to-name-map*
  (the-as array
    (new 'static 'boxed-array :type ip-to-name-map
      (new 'static 'ip-to-name-map :ip #xc0a80302 :mac #x41f21c81e :name "jlanier-1" :has-16x9 #f)
