;;-*-Lisp-*-
(in-package goal)

;; name: fmv-player.gc
;; name in dgo: fmv-player
;; dgos: GAME

;; Thin GOAL wrapper around the C++ FMVPlayer infrastructure.
;; pc-fmv-play/stop/is-done are in game/kernel/jakx/kmachine_extras.cpp,
;; backed by FMVPlayer.cpp (ffmpeg, runs in render thread).
;;
;; Starts playback of path (relative to iso_data/jakx/), suspends until done.
;; Start button calls pc-fmv-stop; loop exits on next is-done poll.
(defun fmv-player-run ((path string))
  (pc-fmv-play path)
  (until (nonzero? (pc-fmv-is-done))
    (when (cpad-pressed? 0 start)
      (pc-fmv-stop))
    (suspend))
  (none)
  )

(define *subtitles-text* (the-as object #f))

(define *fmv-m2v-name* (the-as object (new 'global 'string 32 (the-as string #f))))

(define *fmv-snd-name* (the-as object (new 'global 'string 32 (the-as string #f))))

(define *fmv-old-hflip* (the-as object #f))

(deftype fmv-buffer (structure)
  ((buff   uint32)
   (start  int32)
   )
  )


