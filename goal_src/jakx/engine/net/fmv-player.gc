;; WARN: Return type mismatch process vs fmv-player.
(defmethod relocate ((this fmv-player) (offset int))
  (set! *fmv-player* this)
  (if *fmv-player*
      (set! *fmv-player* (+ (the-as uint *fmv-player*) offset))
      )
  (the-as fmv-player ((method-of-type process relocate) this offset))
  )

