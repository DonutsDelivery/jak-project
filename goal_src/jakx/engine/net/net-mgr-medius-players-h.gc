(medius-cache-method-12 *medius-player-cache*)

(deftype medius-player (medius-cache-index)
  ()
  (:methods
    (medius-player-method-11 (_type_) none)
    (medius-player-method-12 (_type_) none)
    (medius-player-method-13 (_type_) none)
    )
