;; SCAFFOLDING: medius-player-online-state not compiled from a -h.gc file; stub here
(deftype medius-player-online-state (structure)
  ((connect-status        int32  :offset-assert 0)
   (medius-lobby-world-id int32  :offset-assert 4)
   (medius-game-world-id  int32  :offset-assert 8)
   (lobby-name            uint8  64 :offset-assert 12)
   (game-name             uint8  64 :offset-assert 76)
   )
  :pack-me
  :size-assert         #x8c
  :flag-assert         #x90000008c
  )





(deftype net-player-stats (structure)
  ((stats-version    int8)
   (current-clan     int32)
   (last-channel-id  int32)
   )
  )


(deftype medius-cached-info-player (medius-cached-info)
  ((name              uint8                       32  :offset  24)
   (format-name       uint8                       160 :offset  56)
   (online-state-ptr  medius-player-online-state      :offset 216)
   (stats-ptr         net-player-stats                :offset 356)
   (ladder-stats-ptr  net-player-ladder-stats         :offset 368)
   (pad               uint8                       312 :offset 372)
   )
  )


