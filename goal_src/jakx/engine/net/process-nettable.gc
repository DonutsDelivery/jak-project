(defmethod deactivate ((this process-nettable))
  "Make a process dead, clean it up, remove it from the active pool, and return to dead pool."
  ;; SCAFFOLDING: method-30 arg count unknown; skip net cleanup, just call super
  (when (process-nettable-method-25 this)
    (format 0 "process-nettable deactivating with net registration active~%")
    )
  ((method-of-type process deactivate) this)
  )

