(define *msg-map-net-test*
  (the-as array (new 'static 'boxed-array :type symbol :length 0 :allocated-length 64))
  )

(define *net-process-class-info-net-test* #f)

;; SCAFFOLDING: net-test class registration (s.w! / call! blocks) removed

(defmethod process-nettable-method-40 ((this net-test))
  (the-as net-process-class-info *net-process-class-info-net-test*)
  )

(defstate running (net-test)
  :virtual #t
  :trans (behavior ()
    (format *stdcon* "running!!! owner is ~D ctr is ~D~%" (-> self owner-idx) (-> self spoon))
    (+! (-> self spoon) 1)
    )
  :code sleep-code
  )

(defstate die (net-test)
  :virtual #t
  :code (behavior ()
    '()
    )
  )

