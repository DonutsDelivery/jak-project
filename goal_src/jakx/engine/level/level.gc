(defmethod level-status? ((this level-group) (arg0 symbol) (arg1 symbol))
  (if (not arg0)
      (return #f)
      )
  (let ((s4-0 (level-get *level* arg0)))
    (lookup-level-info arg0)
    (when s4-0
      (when (and (or (= (-> s4-0 status) 'loaded) (= (-> s4-0 status) 'active))
                 (and (-> s4-0 info borrow) (!= arg1 'ignore-borrow))
                 )
        (dotimes (s3-1 3)
          (let ((v1-14 (-> s4-0 info borrow borrow-info s3-1)))
            (when v1-14
              (when (car (cdr v1-14))
                (let ((v1-15 (level-status? this (the-as symbol (car v1-14)) arg1)))
                  (if (!= v1-15 (-> s4-0 status))
                      (return v1-15)
                      )
                  )
                )
              )
            )
          )
        )
      (-> s4-0 status)
      )
    )
  )

