;; STRIPPED-RESTORATION: minimum-viable bg from 1c1685105 with branches
;; pruned for stubbed/missing helpers on master (2026-05-04 update: most
;; "missing" helpers were renames discovered via slot-shape sweep).
;;   KEPT:    lookup-level-info, visname/name reads, *level* vis? set,
;;            memory-mode borrow check, packages loop, add-borrow-levels.
;;   SKIPPED: level-get-for-use (stubbed body), load-continue loop (depends
;;            on level-get-for-use return + load-continue body, both stubbed),
;;            *load-state* reset!/want setup (reset! mapping unclear,
;;            depends on s5-1), set-continue! (stubbed with break!),
;;            activate-levels! (real body, calls level-status-update!
;;            which now has a real body too — but the path is gated on
;;            successful level load first, so still effectively no-op now),
;;            time-of-day branches (out of scope for verification).
;; Goal: load packages from level-load-info so boot reaches further than
;; the previous "call to bg" idle. NOT a full restoration. See memory note
;; project_jakx_render_path_trade_2026-05-04.md for full restoration recipe.
(defun bg ((arg0 symbol))
  (set! *cheat-mode* (if *debug-segment* 'debug #f))
  (let ((v1-2 (lookup-level-info arg0)))
    (when (or (zero? (the-as int v1-2)) (= v1-2 (the-as level-load-info #f)))
      (format 0 "[bg] lookup-level-info ~A returned #f — level table empty (no static level-load-info instances defined). Aborting bg cleanly.~%" arg0)
      (return 0)
      )
    (format 0 "[bg] lookup-level-info ~A → name=~A visname=~A~%" arg0 (-> v1-2 name) (-> v1-2 visname))
    (cond
      ((= (-> v1-2 visname) arg0)
       (set! (-> *level* vis?) #t)
       (set! arg0 (-> v1-2 name))
       )
      (else
        (set! (-> *level* vis?) #f)
        (set! (-> *kernel-context* low-memory-message) #f)
        )
      )
    (let ((a0-8 (-> v1-2 memory-mode)))
      (if (or (= a0-8 (level-memory-mode borrow)) (or (= a0-8 (level-memory-mode borrow0))
                                                      (= a0-8 (level-memory-mode borrow1))
                                                      (= a0-8 (level-memory-mode borrow2))
                                                      (= a0-8 (level-memory-mode borrow3))
                                                      (= a0-8 (level-memory-mode borrow4))
                                                      (= a0-8 (level-memory-mode borrow-city-small))
                                                      )
              )
          (set! (-> v1-2 memory-mode) (level-memory-mode small-edge))
          )
      )
    (format 0 "[bg] memory-mode after adjust=~A~%" (-> v1-2 memory-mode))
    (let* ((s5-0 (-> v1-2 packages))
           (a0-12 (car s5-0))
           )
      (format 0 "[bg] packages=~A~%" s5-0)
      (while (not (null? s5-0))
        (case (rtype-of a0-12)
          ((symbol)
           (format 0 "[bg]   load-package symbol ~A~%" a0-12)
           (load-package (symbol->string (the-as symbol a0-12)) global)
           )
          ((string)
           (format 0 "[bg]   load-package string ~A~%" a0-12)
           (load-package (the-as string a0-12) global)
           )
          )
        (set! s5-0 (cdr s5-0))
        (set! a0-12 (car s5-0))
        )
      )
    )
  ;; EXTENSION 2026-05-05: drive the level-get-for-use + load-continue loop.
  ;; Mirrors jak3 bg (engine/level/level.gc:2782-2796) with two differences:
  ;; 1) reset! is invoked via load-state-method-9 (the canonical name on jakx);
  ;; 2) set-continue! is skipped (stubbed in jakx — break! body, would crash).
  ;; Goal: get past package-load idle and exercise level loading. Logs s5-1
  ;; (level returned), status transitions, and dproc activation. Every step
  ;; logs so a future log walker can see exactly where the boot stalls.
  (let ((s5-1 (level-get-for-use *level* arg0 'active)))
    (format 0 "[bg] level-get-for-use ~A → ~A~%" arg0 s5-1)
    (let ((iter 0))
      (while (and s5-1
                  (or (= (-> s5-1 status) 'loading) (= (-> s5-1 status) 'loading-bt) (= (-> s5-1 status) 'login))
                  (not *dproc*))
        (set! iter (+ iter 1))
        (when (zero? (mod iter 32))
          (format 0 "[bg]   load-continue iter=~D status=~A *dproc*=~A~%" iter (-> s5-1 status) *dproc*)
          )
        (load-continue s5-1)
        )
      (format 0 "[bg] load-continue loop exit: iter=~D s5-1=~A status=~A *dproc*=~A~%"
              iter s5-1 (if s5-1 (-> s5-1 status) 'no-level) *dproc*)
      )
    (when s5-1
      ;; reset *load-state* and tag the just-loaded level as the display target.
      (load-state-method-9 *load-state*)
      (set! (-> *load-state* vis-nick) (-> s5-1 name))
      (set! (-> *load-state* want 0 name) (-> s5-1 name))
      (set! (-> *load-state* want 0 display?) 'display)
      (format 0 "[bg] *load-state* configured: vis-nick=~A want[0]=~A display=display~%"
              (-> *load-state* vis-nick) (-> *load-state* want 0 name))
      ;; want-sound from continue-point (jakx continue-point want-sound is array-1).
      (when (-> s5-1 info continues)
        (let ((cp (the-as continue-point (car (-> s5-1 info continues)))))
          (dotimes (i 1)
            (set! (-> *load-state* want-sound i name) (-> cp want-sound i))
            (set! (-> *load-state* want-sound i mode) (sound-bank-mode unknown))
            )
          (format 0 "[bg] continue-point ~A: want-sound[0]=~A~%" (-> cp name) (-> cp want-sound 0))
          )
        )
      )
    )
  (add-borrow-levels *load-state*)
  (activate-levels! *level*)
  (set! *print-login* #f)
  (format 0 "[bg] returning — extended body finished (level-get-for-use + load-continue loop run; set-continue! still stubbed)~%")
  0
  (none)
  )

;; ERROR: failed type prop at 86: Could not figure out load: (set! v1 (l.wu v1))
;; ERROR: Failed to guess stack use for 16 in play:70
(defun play ((arg0 symbol) (arg1 symbol))
  "Start (or restart) the game!
   This will start up the display process, and load the initial level.
   SCAFFOLDING: minimal port of jak3's play. As of 2026-05-04 most
   level-loading deps exist by canonical name (init-level-system,
   activate-levels!, level-get-for-use, level-status-update!,
   level-get-most-disposable, load-continue). Real bodies:
   init-level-system, activate-levels!, level-status-update!,
   load-continue, level-get-for-use. Still-stubbed:
   level-get-most-disposable. Genuinely missing: add-borrow-levels.
   This minimal version handles the *kernel-boot-level* branch via bg
   when set, and falls through to a no-op title path otherwise."
  (kmemopen global "level-boot")
  (start-debug "call to play! arg0=~A arg1=~A~%" arg0 arg1)
  (when *kernel-boot-level*
    (start-debug "play: *kernel-boot-level*=~A — calling bg~%" *kernel-boot-level*)
    (bg *kernel-boot-level*)
    (on #f)
    (kmemclose)
    (kmemclose)
    (return 0)
    )
  ;; SCAFFOLDING: no title flow yet — would call init-level-system,
  ;; level-get-for-use, level-status-update! etc. All four are real
  ;; bodies as of 2026-05-04 (level-get-most-disposable is still
  ;; stubbed but only fires when an existing slot needs eviction,
  ;; which doesn't happen on this boot path). Could be wired up
  ;; once title video assets and level table are populated.
  ;; Best-effort: try to start the display process (on #t) so display-loop runs
  ;; and we can see what it does without loaded levels. on() will spawn display
  ;; and may immediately kill it if no level is loaded — that's expected and OK.
  (set! (-> *level* vis?) arg0)
  (set! (-> *level* play?) #t)
  (start-debug "play: no *kernel-boot-level* — attempting (on #t) display spawn~%")
  (on #t)
  (start-debug "play: (on #t) returned, *dproc*=~A~%" *dproc*)
  (kmemclose)
  (kmemclose)
  0
  (none)
  )

