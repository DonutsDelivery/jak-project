(defun play-boot ()
  "Function called by the C Kernel to start the game (wrapper around play)."
  (start-debug "call to play-boot!~%")
  (process-spawn-function
    process
    (lambda () (play #t #t) (none))
    :from *4k-dead-pool*
    :stack *kernel-dram-stack*
    )
  0
  (none)
  )

