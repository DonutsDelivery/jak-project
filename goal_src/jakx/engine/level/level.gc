;; STRIPPED-RESTORATION: minimum-viable bg from 1c1685105 with branches
;; pruned for missing helpers/slots on master.
;;   KEPT:    lookup-level-info, visname/name reads, *level* vis? set,
;;            memory-mode borrow check, packages loop, add-borrow-levels.
;;   SKIPPED: level-get-for-use (missing), load-continue loop (depends on
;;            level-get-for-use return), *load-state* reset!/want setup
;;            (reset! mapping unclear, depends on s5-1), set-continue!
;;            (stubbed with break!), activate-levels! (missing),
;;            time-of-day branches (out of scope for verification).
;; Goal: load packages from level-load-info so boot reaches further than
;; the previous "call to bg" idle. NOT a full restoration. See memory note
;; project_jakx_render_path_trade_2026-05-04.md for full restoration recipe.
(defun bg ((arg0 symbol))
  (set! *cheat-mode* (if *debug-segment* 'debug #f))
  (let ((v1-2 (lookup-level-info arg0)))
    (when (or (zero? (the-as int v1-2)) (= v1-2 (the-as level-load-info #f)))
      (format 0 "[bg] lookup-level-info ~A returned #f — level table empty (no static level-load-info instances defined). Aborting bg cleanly.~%" arg0)
      (return 0)
      )
    (format 0 "[bg] lookup-level-info ~A → name=~A visname=~A~%" arg0 (-> v1-2 name) (-> v1-2 visname))
    (cond
      ((= (-> v1-2 visname) arg0)
       (set! (-> *level* vis?) #t)
       (set! arg0 (-> v1-2 name))
       )
      (else
        (set! (-> *level* vis?) #f)
        (set! (-> *kernel-context* low-memory-message) #f)
        )
      )
    (let ((a0-8 (-> v1-2 memory-mode)))
      (if (or (= a0-8 (level-memory-mode borrow)) (or (= a0-8 (level-memory-mode borrow0))
                                                      (= a0-8 (level-memory-mode borrow1))
                                                      (= a0-8 (level-memory-mode borrow2))
                                                      (= a0-8 (level-memory-mode borrow3))
                                                      (= a0-8 (level-memory-mode borrow4))
                                                      (= a0-8 (level-memory-mode borrow-city-small))
                                                      )
              )
          (set! (-> v1-2 memory-mode) (level-memory-mode small-edge))
          )
      )
    (format 0 "[bg] memory-mode after adjust=~A~%" (-> v1-2 memory-mode))
    (let* ((s5-0 (-> v1-2 packages))
           (a0-12 (car s5-0))
           )
      (format 0 "[bg] packages=~A~%" s5-0)
      (while (not (null? s5-0))
        (case (rtype-of a0-12)
          ((symbol)
           (format 0 "[bg]   load-package symbol ~A~%" a0-12)
           (load-package (symbol->string (the-as symbol a0-12)) global)
           )
          ((string)
           (format 0 "[bg]   load-package string ~A~%" a0-12)
           (load-package (the-as string a0-12) global)
           )
          )
        (set! s5-0 (cdr s5-0))
        (set! a0-12 (car s5-0))
        )
      )
    )
  (add-borrow-levels *load-state*)
  (format 0 "[bg] returning — level-get-for-use/load-continue/activate-levels! missing on master~%")
  0
  (none)
  )

;; ERROR: failed type prop at 86: Could not figure out load: (set! v1 (l.wu v1))
;; ERROR: Failed to guess stack use for 16 in play:70
(defun play ((arg0 symbol) (arg1 symbol))
  "Start (or restart) the game!
   This will start up the display process, and load the initial level.
   SCAFFOLDING: minimal port of jak3's play. Most level-loading deps
   (level-get-for-use, init-level-system, level-status-update!,
   add-borrow-levels, activate-levels!) don't yet exist in jakx.
   This minimal version handles the *kernel-boot-level* branch via bg
   when set, and falls through to a no-op title path otherwise."
  (kmemopen global "level-boot")
  (start-debug "call to play! arg0=~A arg1=~A~%" arg0 arg1)
  (when *kernel-boot-level*
    (start-debug "play: *kernel-boot-level*=~A — calling bg~%" *kernel-boot-level*)
    (bg *kernel-boot-level*)
    (on #f)
    (kmemclose)
    (kmemclose)
    (return 0)
    )
  ;; SCAFFOLDING: no title flow yet — would call init-level-system,
  ;; level-get-for-use, level-status-update! etc. (none exist by name in jakx yet).
  ;; Best-effort: try to start the display process (on #t) so display-loop runs
  ;; and we can see what it does without loaded levels. on() will spawn display
  ;; and may immediately kill it if no level is loaded — that's expected and OK.
  (set! (-> *level* vis?) arg0)
  (set! (-> *level* play?) #t)
  (start-debug "play: no *kernel-boot-level* — attempting (on #t) display spawn~%")
  (on #t)
  (start-debug "play: (on #t) returned, *dproc*=~A~%" *dproc*)
  (kmemclose)
  (kmemclose)
  0
  (none)
  )

;; ERROR: function has no type analysis. Cannot decompile.

