;; WARN: Return type mismatch none vs level.
;; ERROR: Function may read a register that is not set: a1
(defmethod level-get-most-disposable ((this level-group))
  "Get the level inside this level-group that should be used to load a new level.
   2026-05-05: Body restored from jak3 (engine/level/level.gc:2574). The
   priority-based active-fallback branch is dropped because jakx's level-load-info
   deftype lost the `priority` slot; first-three loops (inactive/loading/loaded)
   cover the common case where slots are free at boot."
  (dotimes (v1-0 (-> this length))
    (case (-> this level v1-0 status)
      (('inactive)
       (return (-> this level v1-0))
       )
      )
    )
  (dotimes (v1-6 (-> this length))
    (case (-> this level v1-6 status)
      (('loading 'loading-bt)
       (return (-> this level v1-6))
       )
      )
    )
  (dotimes (v1-12 (-> this length))
    (case (-> this level v1-12 status)
      (('loaded)
       (return (-> this level v1-12))
       )
      )
    )
  ;; SKIPPED: jak3's active-fallback-with-priority — jakx dropped priority slot.
  (the-as level #f)
  )

