         (buf1 (kmalloc (-> this heap) buf-sz (kmalloc-flags align-64 top) "dgo-level-buf-1"))
         )
    (set! (-> this load-buffer 0) (the-as uint buf1))
    (set! (-> this load-buffer 1) (the-as uint buf2))
    (set! (-> this load-buffer-size) (the-as uint buf-sz))
    (set! (-> this load-buffer-mode) (level-memory-mode micro))
    (format 0 "[load-begin] buf1=~X buf2=~X size=~X — calling dgo-load-begin~%" buf1 buf2 buf-sz)
    (dgo-load-begin
      *temp-string*
      (the-as uint128 (-> this load-id))
      buf1
      buf2
      (logand -64 (&+ (-> this heap current) 63))
      )
    )
  this
  )

