(in-package goal)

;; name: level-info.gc
;; name in dgo: level-info
;; dgos: GAME

;; DECOMP BEGINS

;; SCAFFOLDING: L-labels reference static binary data; use zeroed placeholders
(define *default-mood-range* (new 'static 'mood-range))

(define *mood-range-1* (new 'static 'mood-range))

(define *mood-range-snow* (new 'static 'mood-range))

(define default-level #f)

;; SCAFFOLDING: spurious decompiler output; default-level is #f above, cannot dereference
;; (set! (-> default-level name) #f)

;; PARTIAL RESTORATION 2026-05-04: minimal intro level-load-info
;; sourced from 1c1685105:goal_src/jakx/engine/level/level-info.gc:64,
;; fitted to current master deftype (drop run-packages/music-bank/extra-sound-bank/
;; ocean-alpha/priority/bigmap-id/borrow/fog-height/max-rain — those slots
;; were removed in master's level-h.gc deftype). Goal: give lookup-level-info
;; a real instance to walk so bg's packages loop has something to feed into
;; load-package, instead of returning default-level=#f. See memory note
;; project_jakx_render_path_trade_2026-05-04.md.
(define intro (new 'static 'level-load-info
                :name 'intro
                :visname 'intro-vis
                :nickname 'int
                :taskname 'default
                :index 2
                :level-flags (level-flags ocean-near-translucent)
                :packages '("intro")
                :memory-mode (level-memory-mode medium)
                :mood-func 'update-mood-default
                :special-mood #f
                :ocean #f
                :draw-priority 10.0
                :continues '()
                :callback-list '()
                :master-level #f
                :bottom-height (meters -10000000)
                :mood-range (new 'static 'mood-range :max-cloud 1.0 :min-fog 0.5 :max-fog 1.0)
                :fog-mult 1.0
                )
        )

