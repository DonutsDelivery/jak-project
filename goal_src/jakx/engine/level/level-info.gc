    :mood-func 'update-mood-default
    :special-mood #f
    :ocean #f
    :draw-priority 10.0
    :base-task-mask (task-mask task0)
    :continues '()
    :callback-list '()
    :borrow #f
    :bottom-height (meters -20)
    :fog-mult 1.0
    :mood-range (new 'static 'mood-range :max-cloud 1.0 :min-fog 0.5 :max-fog 1.0)
    )
