;; SCAFFOLDING -- jak3 clean version adapted for jakx (minimal stub; bsp-header lacks nodes/remap fields)
(defun mem-usage-bsp-tree ((arg0 bsp-header) (arg1 bsp-node) (arg2 memory-usage-block) (arg3 int))
  "Recursively compute memory usage of bsp-tree."
  (cond
    ((zero? arg1)
     )
    (else
      (+! (-> arg2 data 60 count) 1)
      (let ((node-size 20))
        (+! (-> arg2 data 60 used) node-size)
        (+! (-> arg2 data 60 total) node-size)
        )
      (if (zero? (-> arg1 front-box-min w))
          (mem-usage-bsp-tree arg0 (the-as bsp-node (-> arg1 front)) arg2 arg3)
          )
      (when (zero? (-> arg1 back-box-min w))
        (if (> (the-as int (-> arg1 back)) 0)
            (mem-usage-bsp-tree arg0 (the-as bsp-node (-> arg1 back)) arg2 arg3)
            )
        )
      )
    )
  (none)
  )

;; SCAFFOLDING -- minimal stub for jakx (bsp-header lacks many jak3 fields)
(defmethod mem-usage ((this bsp-header) (usage memory-usage-block) (flags int))
  (if (nonzero? (-> this drawable-trees))
      (mem-usage (-> this drawable-trees) usage flags)
      )
  this
  )

