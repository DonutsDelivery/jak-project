(defmethod collect-stats ((this bsp-header))
  "Collect triangle/perf statistics for rendering.
   This is only called when viewing stats.
   The vis-bits and culling registers are loaded during this time."
  (rlet ((vf16 :class vf)
         (vf17 :class vf)
         (vf18 :class vf)
         (vf19 :class vf)
         (vf20 :class vf)
         (vf21 :class vf)
         (vf22 :class vf)
         (vf23 :class vf)
         (vf24 :class vf)
         (vf25 :class vf)
         (vf26 :class vf)
         (vf27 :class vf)
         (vf28 :class vf)
         (vf29 :class vf)
         (vf30 :class vf)
         (vf31 :class vf)
         )
    (let ((v0-0 (view-get-active-math-camera)))
      (.lvf vf16 (&-> v0-0 plane 0 quad))
      (.lvf vf17 (&-> v0-0 plane 1 quad))
      (.lvf vf18 (&-> v0-0 plane 2 quad))
      (.lvf vf19 (&-> v0-0 plane 3 quad))
      (.lvf vf20 (&-> v0-0 shrub-mat rvec quad))
      (.lvf vf21 (&-> v0-0 shrub-mat uvec quad))
      (.lvf vf22 (&-> v0-0 shrub-mat fvec quad))
      (.lvf vf23 (&-> v0-0 shrub-mat trans quad))
      (.lvf vf24 (&-> v0-0 camera-rot rvec quad))
      (.lvf vf25 (&-> v0-0 camera-rot uvec quad))
      (.lvf vf26 (&-> v0-0 camera-rot fvec quad))
      (.lvf vf27 (&-> v0-0 camera-rot trans quad))
      (.lvf vf28 (&-> v0-0 camera-temp rvec quad))
      (.lvf vf29 (&-> v0-0 camera-temp uvec quad))
      (.lvf vf30 (&-> v0-0 camera-temp fvec quad))
      (.lvf vf31 (&-> v0-0 camera-temp trans quad))
      )
    (if (nonzero? (-> this drawable-trees))
        (collect-stats (-> this drawable-trees))
        )
    0
    )
  )

