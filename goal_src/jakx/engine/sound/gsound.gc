            (format
              #t
              "volume: ~f  pitch-mod: ~f~%"
              (* 0.09765625 (the float (-> s5-1 volume)))
              (* 0.000656168 (the float (-> s5-1 pitch-mod)))
              )
            )
          (when (-> s5-1 info)
