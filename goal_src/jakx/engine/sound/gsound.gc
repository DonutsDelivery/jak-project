    )
  0
  )

(defun show-iop-info ((dma dma-buffer))
  "Display iop info on screen."
  (dotimes (s5-0 24)
    (draw-string-xy
      (if (zero? (-> *sound-iop-info* chinfo s5-0))
          "."
          "X"
          )
      dma
      (+ (* s5-0 16) 16)
      48
      (font-color default)
      (font-flags shadow)
      )
    )
  (dotimes (s5-1 24)
    (draw-string-xy
      (if (zero? (-> *sound-iop-info* chinfo (+ s5-1 24)))
          "."
          "X"
          )
      dma
      (+ (* s5-1 16) 16)
      64
      (font-color default)
      (font-flags shadow)
      )
    )
  (let ((s5-2 draw-string-xy))
    (format
      (clear *temp-string*)
      "banks: ~15S ~15S ~15S"
      (-> *level* sound-bank 0 name)
      (-> *level* sound-bank 2 name)
      (-> *level* sound-bank 4 name)
      )
    (s5-2 *temp-string* dma 16 88 (font-color default) (font-flags shadow))
    )
  (let ((s5-3 draw-string-xy))
    (format
      (clear *temp-string*)
      "       ~15S ~15S ~15S"
      (-> *level* sound-bank 1 name)
      (-> *level* sound-bank 3 name)
      (-> *level* sound-bank 5 name)
      )
    (s5-3 *temp-string* dma 16 104 (font-color default) (font-flags shadow))
    )
  (let ((s5-4 draw-string-xy))
    (format
      (clear *temp-string*)
      "music: ~15S ~10S"
      (-> *setting-control* user-current music)
      (-> *setting-control* user-current mode-sound-bank)
      )
    (s5-4 *temp-string* dma 16 118 (font-color default) (font-flags shadow))
    )
  0
  )

(defun show-iop-memory ((dma dma-buffer))
  "Display iop memory stats on screen"
  (let ((s5-0 draw-string-xy))
    (format (clear *temp-string*) "total: ~8D bytes" (-> *sound-iop-info* freemem2))
    (s5-0 *temp-string* dma 32 144 (font-color default) (font-flags shadow))
    )
  (let ((s5-1 draw-string-xy))
    (format (clear *temp-string*) "max: ~8D bytes" (-> *sound-iop-info* freemem))
    (s5-1 *temp-string* dma 32 160 (font-color default) (font-flags shadow))
    )
  0
  )

(defun ear-trans ((mode int) (arg1 int))
  "Get the current location of the ear. Use 1 for the settings ear-handle, or 0 for the camera."
  (cond
    ((= mode 1)
     (get-player-pos arg1)
     )
    ((or (movie?) *external-cam-mode*)
     (math-camera-pos)
     )
    (else
      (-> (view-get-math-camera arg1) trans)
      )
    )
  )

(defun-debug make-sqrt-table ()
  "Generate integer square-root table used in the IOP."
  (format #t "static int sqrt_table[256] =~%{~%")
  (dotimes (gp-0 256)
    (let* ((f0-2 (sqrtf (* 16777216.0 (the float gp-0))))
           (a2-0 (the int (+ 0.5 f0-2)))
           )
      (format #t "~D,~%" a2-0)
      )
    )
  (format #t "};~%")
  0
  (none)
  )

(check-irx-version)

(sound-bank-load (static-sound-name "common") 2 10)

(dotimes (gp-3 1)
  (let* ((v1-105 gp-3)
         (s5-0 (cond
                 ((zero? v1-105)
                  'empty0
                  )
                 ((= v1-105 1)
                  'empty1
                  )
                 ((= v1-105 2)
                  'empty2
                  )
                 ((= v1-105 3)
                  'empty3
                  )
                 )
               )
         )
    (sound-bank-unload (the-as sound-name 4))
    (set! (-> *level* sound-bank (* gp-3 2) name) s5-0)
    )
  (set! (-> *level* sound-bank (* gp-3 2) mode) (sound-bank-mode full))
  )

(defun doppler-pitch-shift ((sound-pos vector) (sound-vel vector))
  "Compute pitch shift for the doppler effect. This is done assuming the listener is *target* and has *target*'s velocity."
  (let ((gp-0 (new 'stack-no-clear 'inline-array 'vector 2)))
    (set! (-> gp-0 0 quad) (-> sound-pos quad))
    (set! (-> gp-0 1 quad) (-> sound-vel quad))
    (vector-normalize! (-> gp-0 0) 1.0)
    (let ((f0-1 (/ 2048000.0 (fmax 0.1 (+ 2048000.0 (vector-dot (-> gp-0 0) (-> gp-0 1)))))))
      (fmax -0.7 (fmin 0.7 (log2f f0-1)))
      )
    )
  )

(defun sound-bank-reload ()
  "Start a background process to unload all sound banks, then load them again."
  (process-spawn-function
    process
    (lambda ()
      (local-vars (sp-0 none))
      (let ((gp-0 (new 'static 'boxed-array :type symbol :length 0 :allocated-length 7)))
        (dotimes (v1-0 7)
          (set! (-> gp-0 v1-0) (-> *level* sound-bank v1-0 name))
          )
        (let ((a1-3 (+ (the-as uint sp-0) 16)))
          (set! (-> a1-3 0) 'empty0)
          (load-state-method-12 *load-state* a1-3)
          )
        (suspend-for (seconds 1)
          )
        (let ((a1-4 (+ (the-as uint sp-0) 32)))
          (set! (-> a1-4 0) (-> gp-0 0))
          (load-state-method-12 *load-state* a1-4)
          )
        )
      (none)
      )
    :to *display-pool*
    )
  0
  (none)
  )

(defun sound-bank-reload-common ()
  (process-spawn-function
    process
    (lambda ()
      (format #t "unload sound bank~%")
      (sound-bank-unload (the-as sound-name 2))
      (sound-bank-load (static-sound-name "common") 2 10)
      (none)
      )
    :to *display-pool*
    )
  0
  (none)
  )

(define *jukebox-onoff* #f)

(define *last-music-position* (the-as uint 0))

(defun jukebox-onoff ((arg0 symbol))
  (when (not arg0)
    (set! *last-music-position* (the-as uint -1))
    (let* ((a0-1 *setting-control*)
           (t9-0 (method-of-object a0-1 set-setting))
           (a1-0 *dproc*)
           )
      'music
      0
      0
      (t9-0 a0-1 a1-0)
      )
    )
  (if arg0
      (set! *jukebox-time* (-> *display* game-clock frame-counter))
      )
  (set! *jukebox-onoff* arg0)
  0
  )

(defun update-jukebox-music ()
  (with-pp
    (cond
      ((and *jukebox-onoff* (not (-> *setting-control* user-current mpeg-mode?)))
       (when (< *jukebox-time* (-> *display* game-clock frame-counter))
         (set! *jukebox-time* (+ (-> *display* game-clock frame-counter) (seconds 5)))
         (cond
           ((or (zero? (-> *sound-iop-info* music-name name 0))
                (and (not (paused?))
                     (not *music-lock*)
                     (or (= (-> *sound-iop-info* music-position) *last-music-position*)
                         (>= (* 0.0009765625 (the float (- (-> *sound-iop-info* music-position) *last-music-position*))) 20.0)
                         )
