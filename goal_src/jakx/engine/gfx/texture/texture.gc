       (set! (-> *level* level-default texture-page-dir 6 page) page)
       )
      (else
        ;; Cycle 90: previously this branch permanently switched allocate-func to
        ;; default-allocate. In jakx that breaks subsequent dispatch — pages 1, 2, 3
        ;; (small system pages with unhandled ids in the case table) hit this branch
        ;; first, flip allocate-func, and force page-id=4 (size 94336, the
        ;; level-default common page) onto the default-allocate path. That path
        ;; uses pool->cur, which after method-12's seeding sits at #xff000
        ;; (slot 16320), only ~64 slots from the m_textures[16384] hard ceiling.
        ;; Page 4 then overflows the array → crash inside __pc-texture-upload-now.
        ;; jak3 doesn't hit this because get-common-page-slot-by-id finds pages 1-3
        ;; via the (>= s2-0 0) branch; jakx's texture-pool-method-18 stub always
        ;; returns -1, sending those pages to else here. Without the permanent
        ;; switch, common-boot-allocate stays as allocate-func and pages 4-12 keep
        ;; routing to common-allocate via their case-id branches.
        (texture-page-default-allocate pool page heap page-id)
        )
      )
    )
  (set! (-> page dram-size) (-> page size))
  page
  )

