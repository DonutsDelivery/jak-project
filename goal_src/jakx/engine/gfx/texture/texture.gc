(defun texture-page-common-boot-allocate ((pool texture-pool) (page texture-page) (heap kheap) (page-id int))
  "Allocator function for texture loaded at startup time.
   For jak 3, this seems to always do default-allocate (permanently in vram?)
   NOTE (Cycle 91): in jakx this is currently unreachable because
   texture-page-login (texture.gc:~1794) is a SCAFFOLDING stub that returns #f
   without invoking allocate-func. upload-textures (Cycle 91c sync block) lazily
   syncs the same level-default texture-page-dir slots from the global
   *texture-page-dir* (populated by Cycle 89 relocate). When login is ported
   properly, this case-table can take over."
  (let ((s2-0 (texture-pool-method-18 pool page-id)))
    (cond
      ((>= s2-0 0)
       (texture-page-common-allocate pool page heap page-id)
       (set! (-> pool common-page s2-0) page)
       )
      ((= page-id 4)
       (texture-page-common-allocate pool page heap page-id)
       (set! (-> *level* level-default texture-page-dir 7 page) page)
       )
      ((= page-id 5)
       (texture-page-common-allocate pool page heap page-id)
       (set! (-> *level* level-default texture-page-dir 4 page) page)
       )
      ((= page-id 6)
       (texture-page-common-allocate pool page heap page-id)
       (set! (-> *level* level-default texture-page-dir 0 page) page)
       )
      ((= page-id 7)
       (texture-page-common-allocate pool page heap page-id)
       (set! (-> *level* level-default texture-page-dir 1 page) page)
       )
      ((= page-id 8)
       (texture-page-common-allocate pool page heap page-id)
       (set! (-> *level* level-default texture-page-dir 9 page) page)
       )
      ((= page-id 9)
       (texture-page-common-allocate pool page heap page-id)
       (set! (-> *level* level-default texture-page-dir 8 page) page)
       )
      ((= page-id 10)
       (texture-page-common-allocate pool page heap page-id)
       (set! (-> *level* level-default texture-page-dir 5 page) page)
       )
      ((= page-id 11)
       (texture-page-common-allocate pool page heap page-id)
       (set! (-> *level* level-default texture-page-dir 2 page) page)
       )
      ((= page-id 12)
       (texture-page-font-allocate pool page heap page-id)
       )
      ((= page-id 1049)
       (texture-page-common-allocate pool page heap page-id)
       (set! (-> *level* level-default texture-page-dir 3 page) page)
       )
      ((= page-id 2533)
