(defun adgif-shader<-texture-simple! ((shader adgif-shader) (tex texture))
  "Simple adgif-shader to texture, just sets vram address and format stuff.
   Intended for use with fancy texture stuff that will later set the other regs."
  (set! (-> shader tex1) (the-as uint 96))
  (logand! (-> shader tex0) (the-as uint #xffffffe7ffffffff))
  (if tex
      (adgif-shader<-texture! shader tex)
      )
  (set! (-> shader clamp) (the-as uint 5))
  (set! (-> shader alpha) (the-as uint 68))
  (set! (-> shader prims 1) (gs-reg64 tex0-1))
  (set! (-> shader prims 3) (gs-reg64 tex1-1))
  (set! (-> shader prims 5) (gs-reg64 miptbp1-1))
  (set! (-> shader clamp-reg) (the-as uint 8))
  (set! (-> shader prims 9) (gs-reg64 alpha-1))
  shader
  )

(defun set-dirty-mask! ((lev level) (mask-idx int) (m0 int) (m1 int))
  (let ((s4-0 (sar (+ m0 #x3fff) 14))
        (s5-0 (sar m1 14))
        (gp-0 (-> lev texture-dirty-masks mask-idx))
        (v1-4 (new 'stack 'texture-mask))
        )
    (cond
      ((< 64 s4-0)
       (set! (-> v1-4 mask dword 0) (the-as uint -1))
       (set! (-> v1-4 mask dword 1) (the-as uint (+ (ash 1 (+ s4-0 -64)) -1)))
       )
      (else
        (set! (-> v1-4 mask dword 0) (the-as uint (+ (ash 1 s4-0) -1)))
        )
      )
    (when (nonzero? s5-0)
      (set! (-> v1-4 mask dword 1)
            (logior (ash (-> v1-4 mask dword 1) s5-0) (ash (-> v1-4 mask dword 0) (+ s5-0 -64)))
            )
      (set! (-> v1-4 mask dword 0) (ash (-> v1-4 mask dword 0) s5-0))
      )
    (logior! (-> gp-0 mask dword 0) (-> v1-4 mask dword 0))
    (logior! (-> gp-0 mask dword 1) (-> v1-4 mask dword 1))
    )
  0
  )

