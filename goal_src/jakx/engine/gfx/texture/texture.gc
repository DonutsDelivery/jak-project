    )
  (let ((a2-3 (texture-page-size-check this lev #t)))
    (when (nonzero? a2-3)
      (format #t "--------------------  tpage overflow error #x~X~%" a2-3)
      (texture-page-size-check this lev #f)
      (format #t "--------------------~%")
      )
    )
  0
  )

;; Cycle 91: jak3-derived port of add-level-tpage-dma. Was a SCAFFOLDING `(none)`
;; stub. Per-frame dispatcher: per (level, tpage-category, bucket) tuple,
;; queue the page's textures for upload via upload-vram-pages, which emits
;; the pc-port vif tag that TextureUploadHandler reads to populate m_textures.
;; Adapted to jakx layout: jakx has no separate `texture-page` array on level —
;; the per-category texture-page* lives inside `texture-page-dir N page`. Only
;; the maskless categories (sprite/hud/sky/warp/shrub) are wired this cycle;
;; tfrag/pris/etc. need jakx-specific texture-mask layout work.
(define *jakx-c91-method14-debug-fired* #f)

(defmethod texture-pool-method-14 ((this texture-pool) (lev level) (category tpage-category) (bucket bucket-id))
  "Set up DMA to upload all textures needed to draw this level on this frame.
   Jakx Cycle 91 port of jak3 add-level-tpage-dma (texture.gc:1281). Minimal
   per-frame texture-upload dispatch. Returns 0.
   Cycle 91b: common categories (sprite/hud/sky/warp) live on level-default's
   texture-page-dir (populated by texture-page-common-boot-allocate). Per-level
   categories (shrub) live on the loaded level's texture-page-dir."
  (let* ((src-lev (case category
                    (((tpage-category sprite) (tpage-category hud) (tpage-category sky) (tpage-category warp))
                     (-> *level* level-default))
                    (else lev)
                    ))
         (a2-1 (-> src-lev texture-page-dir (the-as int category) page))
         )
    (#when PC_PORT
      (when (not *jakx-c91-method14-debug-fired*)
        (format 0 "[c91] method-14 fired: lev='~A' src='~A' index=~D cat=~D bucket=~D pageptr=~A~%"
                (-> lev name) (-> src-lev name) (-> lev index) (the-as int category) (the-as int bucket) a2-1)
        (set! *jakx-c91-method14-debug-fired* #t)
        )
      )
    (when (and a2-1 (nonzero? (the-as int a2-1)))
      (case category
        (((tpage-category sprite))
         (set! (-> lev upload-size 7)
               (upload-vram-pages this (-> this segment-common) a2-1 (tex-upload-mode seg0-1-2) bucket)
               )
         )
        (((tpage-category hud))
         (set! (-> lev upload-size 8)
               (upload-vram-pages this (-> this segment-common) a2-1 (tex-upload-mode seg0-1-2) bucket)
               )
         )
        (((tpage-category sky))
         (set! (-> lev upload-size 9)
               (upload-vram-pages this (-> this segment-common) a2-1 (tex-upload-mode seg0-1-2) bucket)
               )
         )
        (((tpage-category warp))
         (set! (-> lev upload-size 5)
               (upload-vram-pages this (-> this segment-common) a2-1 (tex-upload-mode seg0-1-2) bucket)
               )
         )
        (((tpage-category shrub))
         (set! (-> lev upload-size 2)
               (upload-vram-pages this (-> this segment-common) a2-1 (tex-upload-mode seg0-1-2) bucket)
               )
         )
        (((tpage-category hfrag))
         ;; Disabled per jak3 PC port — hfrag renderer is rewritten on PC.
         )
        )
      )
    )
  0
  (none)
  )

(define-extern set-dirty-mask! (function level int int int int))

(define *jakx-c91-tdir-sync-done* #f)
(define *jakx-c91-tdir-debug-fired* #f)

(defun upload-textures ((pool texture-pool))
  "Set up DMA for all texture uploads for this frame."
  (#when PC_PORT
    ;; Cycle 91c: texture-page-login is a SCAFFOLDING stub in jakx, so
    ;; common-boot-allocate's case-branches never fire and level-default's
    ;; texture-page-dir slots stay #f. But Cycle-89 relocate did populate the
    ;; global *texture-page-dir* via each level's link buffer. Lazy-sync the
    ;; common pages into level-default once they're reachable.
    (when (not *jakx-c91-tdir-sync-done*)
      (when (not *jakx-c91-tdir-debug-fired*)
        (format 0 "[c91] tdir sync probe: *texture-page-dir*=~A~%" *texture-page-dir*)
        (set! *jakx-c91-tdir-debug-fired* #t)
        )
      (when (and *texture-page-dir* (>= (-> *texture-page-dir* length) 12))
        (let ((dir *texture-page-dir*))
          (let ((p (-> dir entries 4 page))) (when p (set! (-> *level* level-default texture-page-dir 7 page) p)
            (format 0 "[c91] sync entry[4] -> tdir[7] sprite page='~A' length=~D~%" (-> p name) (-> p length))))
          (let ((p (-> dir entries 5 page))) (when p (set! (-> *level* level-default texture-page-dir 4 page) p)
            (format 0 "[c92] sync entry[5] -> tdir[4] water page='~A' length=~D~%" (-> p name) (-> p length))))
          (let ((p (-> dir entries 6 page))) (when p (set! (-> *level* level-default texture-page-dir 0 page) p)
            (format 0 "[c92] sync entry[6] -> tdir[0] tfrag page='~A' length=~D~%" (-> p name) (-> p length))))
          (let ((p (-> dir entries 7 page))) (when p (set! (-> *level* level-default texture-page-dir 1 page) p)
            (format 0 "[c92] sync entry[7] -> tdir[1] pris page='~A' length=~D~%" (-> p name) (-> p length))))
          (let ((p (-> dir entries 8 page))) (when p (set! (-> *level* level-default texture-page-dir 9 page) p)
            (format 0 "[c92] sync entry[8] -> tdir[9] sky page='~A' length=~D~%" (-> p name) (-> p length))))
          (let ((p (-> dir entries 9 page))) (when p (set! (-> *level* level-default texture-page-dir 8 page) p)
            (format 0 "[c91] sync entry[9] -> tdir[8] hud~%")))
          (let ((p (-> dir entries 10 page))) (when p (set! (-> *level* level-default texture-page-dir 5 page) p)
            (format 0 "[c92] sync entry[10] -> tdir[5] warp page='~A' length=~D~%" (-> p name) (-> p length))))
          (let ((p (-> dir entries 11 page))) (when p (set! (-> *level* level-default texture-page-dir 2 page) p)
            (format 0 "[c92] sync entry[11] -> tdir[2] shrub page='~A' length=~D~%" (-> p name) (-> p length))))
          )
        ;; Mark done only when sprite slot got populated
        (when (-> *level* level-default texture-page-dir 7 page)
          (set! *jakx-c91-tdir-sync-done* #t)
          (format 0 "[c91] tdir sync DONE~%")
          ;; Cycle 92: one-shot bulk upload of all populated common pages.
          ;; Each call queues a PC_PORT vif tag in the tex-sprite bucket;
          ;; TextureUploadHandler::render consumes them and calls handle_upload_now,
          ;; registering every texture in the page (m_textures[tex.dest[mip]] = source).
          ;; tex-sprite is wired to TextureUploadHandler in init_bucket_renderers_jak3
          ;; (used for both jak3 and jakx). After this one-shot, Sprite3 lookups for
          ;; pris/water/sky/warp/shrub textures succeed without needing per-frame
          ;; method-14 dispatch for those categories.
          (let ((sprite-bucket (bucket-id tex-sprite)))
            (let ((p (-> *level* level-default texture-page-dir 1 page)))
              (when p (upload-vram-pages pool (-> pool segment-common) p (tex-upload-mode seg0-1-2) sprite-bucket)
                (format 0 "[c92] bulk-upload pris len=~D~%" (-> p length))))
            (let ((p (-> *level* level-default texture-page-dir 4 page)))
              (when p (upload-vram-pages pool (-> pool segment-common) p (tex-upload-mode seg0-1-2) sprite-bucket)
                (format 0 "[c92] bulk-upload water len=~D~%" (-> p length))))
            (let ((p (-> *level* level-default texture-page-dir 0 page)))
              (when p (upload-vram-pages pool (-> pool segment-common) p (tex-upload-mode seg0-1-2) sprite-bucket)
                (format 0 "[c92] bulk-upload tfrag len=~D~%" (-> p length))))
            (let ((p (-> *level* level-default texture-page-dir 2 page)))
              (when p (upload-vram-pages pool (-> pool segment-common) p (tex-upload-mode seg0-1-2) sprite-bucket)
                (format 0 "[c92] bulk-upload shrub len=~D~%" (-> p length))))
            (let ((p (-> *level* level-default texture-page-dir 3 page)))
              (when p (upload-vram-pages pool (-> pool segment-common) p (tex-upload-mode seg0-1-2) sprite-bucket)
                (format 0 "[c92] bulk-upload alpha len=~D~%" (-> p length))))
            (let ((p (-> *level* level-default texture-page-dir 6 page)))
              (when p (upload-vram-pages pool (-> pool segment-common) p (tex-upload-mode seg0-1-2) sprite-bucket)
                (format 0 "[c92] bulk-upload pris2 len=~D~%" (-> p length))))
            )
          )
        )
      )
    )
  (set! (-> *level* level-default texture-anim-array 0) #f)
  (dotimes (v1-1 19)
    (let ((a0-4 (-> *level* level v1-1)))
      (when (or (= (-> a0-4 status) 'active) (= (-> a0-4 status) 'reserved))
        (dotimes (a1-5 19)
          (set! (-> a0-4 upload-size a1-5) 0)
          )
        )
      )
    )
  ;; Cycle 91: split the boot-path gate. The car-level-array dirty-mask loop
  ;; still requires *car-level-array* (per-vehicle TBP ranges, not yet wired).
  ;; The texture-page-translate iteration dispatches the per-frame upload
  ;; pipeline now that *texture-page-translate* is defined (jakx-h.gc).
  ;; Without splitting, the AND-gate skipped both even when only car-level was
  ;; missing -> sprite TBPs never registered in C++ TexturePool m_textures.
  (when (nonzero? (the-as int *car-level-array*))
    (dotimes (s5-0 6)
      (let ((a3-0 (* (-> *car-level-array* data s5-0 first-tbp) 256))
            (v1-10 (* (-> *car-level-array* data s5-0 last-tbp) 256))
            )
        (set-dirty-mask! (-> *level* level (+ s5-0 6)) 1 (the-as int (- v1-10 a3-0)) (the-as int a3-0))
        )
      )
    )
  (when (nonzero? (the-as int *texture-page-translate*))
    (dotimes (s5-1 (-> *texture-page-translate* length))
      (let* ((v1-16 (-> *texture-page-translate* s5-1))
             (a1-11 (-> *level* draw-level (-> v1-16 level-index)))
             )
        (if (and a1-11
                 (logtest? (the-as texture-enable-mask-u32 (-> *texture-pool* texture-enable-user)) (-> v1-16 texture-user))
                 )
            (texture-pool-method-14
              pool
              a1-11
              (the-as tpage-category (-> v1-16 level-texture-page))
              (the-as bucket-id (-> v1-16 bucket))
              )
            )
        )
      )
    )
  (dotimes (gp-1 6)
    (let ((v1-24 (-> *level* level (+ gp-1 6))))
      (let ((a0-23 gp-1))
        (cond
          ((zero? a0-23)
           405
           )
          ((= a0-23 1)
           414
           )
          ((= a0-23 2)
           423
           )
          ((= a0-23 3)
           432
           )
          ((= a0-23 4)
           441
           )
          ((= a0-23 5)
           450
           )
          )
        )
      (when (and (-> v1-24 display?) (nonzero? (-> v1-24 texture-mask 12 mask dword 0)))
        ;; SCAFFOLDING — decompiler lost bucket-id arg to car-info-full-method-16
        (none)
        )
      )
    )
  (dotimes (v1-33 19)
    (let ((a0-32 (-> *level* level v1-33)))
      (when (or (= (-> a0-32 status) 'active) (= (-> a0-32 status) 'reserved))
        (dotimes (a1-34 19)
          (set! (-> a0-32 closest-object a1-34) 4095996000.0)
          (set! (-> a0-32 texture-mask a1-34 mask quad) (the-as uint128 0))
          )
        )
      )
    )
  0
  (none)
  )

(kmemopen global "texture-dma-buffers")

(define *txt-dma-list* (new 'global 'dma-buffer 4096))

(kmemclose)

(defmethod texture-page-method-13 ((this texture-page) (mode tex-upload-mode))
  "Upload a texture page to VRAM immediately (jak3 calls this upload-now!).
   Cycle 90: jakx was missing the PC-port hook __pc-texture-upload-now
   (jak3 texture.gc:1612-1615). Without it, the only upload path was the
   PS2 dma-buffer-send-chain to #x1000a000 (VIF1 MMIO), which crashes on
   PC because that address falls inside fake-mapped EE memory and dma-chcr
   write does nothing useful — every prior attempt to dispatch from
   relocate via texture-page-default-allocate / common-boot-allocate
   crashed at addr=0x213300a020, which is the EE_base + 0x1000a020 offset
   the chcr write hits. With the PC-port hook in place, C++ TexturePool
   immediately registers m_textures[tex.dest[mip_idx]] for every texture
   in the page, and the DMA send is skipped under PC_PORT."
  ;; PC-port: hand the page to the C++ TexturePool synchronously. This
  ;; populates m_textures[tex.dest[mip_idx]] so Sprite3 lookup_texture
  ;; finds particle textures rather than logging 'Failed to find ...'.
  (#when PC_PORT
    (__pc-texture-upload-now this mode)
    )
  (let ((gp-0 *txt-dma-list*))
    (let ((v1-0 gp-0))
      (set! (-> v1-0 base) (-> v1-0 data))
      (set! (-> v1-0 end) (the-as pointer (+ (+ (-> v1-0 allocated-length) 28) (the-as int v1-0))))
      )
    (let ((s5-0 (texture-page-method-12 this gp-0 mode)))
      (dma-buffer-add-gs-set gp-0 (texflush 1))
      (let* ((v1-6 gp-0)
             (a0-7 (-> v1-6 base))
             )
        (set! (-> (the-as (pointer int64) a0-7)) #x70000000)
        (set! (-> (the-as (pointer uint64) a0-7) 1) (the-as uint 0))
        (set! (-> v1-6 base) (&+ a0-7 16))
        )
      ;; PC build: VIF1 MMIO write would crash. Skip — PC-port hook above
      ;; already did the equivalent work.
      (#unless PC_PORT
        (dma-buffer-send-chain (the-as dma-bank-source #x1000a000) gp-0)
        (dma-sync (the-as pointer #x1000a000) 0 0)
        )
      s5-0
      )
    )
  )

(defmethod texture-page-method-12 ((page texture-page) (buf dma-buffer) (mode tex-upload-mode))
  (local-vars (sv-16 int))
  (let ((v1-0 mode))
    (set! sv-16 (cond
                  ((= v1-0 (tex-upload-mode none))
                   0
                   )
                  ((= v1-0 (tex-upload-mode seg0-1))
                   (the-as int (+ (-> page segment 0 size) (-> page segment 1 size)))
                   )
                  ((= v1-0 (tex-upload-mode seg0-1-2))
                   (the-as int (-> page size))
                   )
                  (else
                    (the-as int (-> page segment (the-as int mode) size))
                    )
                  )
          )
    )
  (let* ((v1-7 (max 0 (the-as int mode)))
         (a3-4 (* (/ (+ (/ sv-16 64) 63) 64) 32))
         (t1-0 (shr (-> page segment v1-7 dest) 6))
         (a2-10 (-> page segment v1-7 block-data))
         )
    (upload-vram-data buf (the-as int t1-0) a2-10 a3-4 128)
    )
  sv-16
  )

