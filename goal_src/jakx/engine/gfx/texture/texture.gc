    ;; emitted by this function are PS2-only — on PC they reach DirectRenderer
    ;; via TextureUploadHandler::render and assert in handle_ad. Jak3 has the
    ;; same guard (texture.gc:719). The PC port instead consumes the PC_PORT vif
    ;; tag at end of upload-vram-pages → handle_upload_now to register textures.
    (return #f)
    )
