  )

(defmethod relocate ((this texture-page) (heap kheap) (filename (pointer uint8)))
  "Handle a texture page that has been loaded by the linker.
   jakx Cycle 89: minimally adapted from jak3 texture.gc:1886. The previous SCAFFOLDING
   stub left *texture-page-dir* entries[id].page = #f, so every lookup-texture-by-id-fast
   for sparticle adgif TBP missed -> Sprite3 'Failed to find texture at 5120' warning
   every frame in krastrn. This version JUST populates *texture-page-dir* entries and
   the per-entry link buffer.
   Cycle 90 attempted full dispatch via *texture-pool* allocate-func, but pages 1-3
   route through default-allocate (common-boot-allocate else branch) which calls
   method-13 -> __pc-texture-upload-now -> handle_upload_now. The resulting m_textures
   slot occupancy collides with later (texture-relocate) calls during background level
   load, hitting GpuTexture::remove_slot 'it != slots.end()' assertion. Real fix is
   to port jak3's add-level-tpage-dma + upload-vram-pages-pris-pc per-frame texture
   upload pipeline so level pages get registered to TexturePool with their correct
   TBP values, not via the boot-time default-allocate path that overlaps with
   subsequent goal texture-relocate calls. Until that lands, keep the minimal page-dir
   population so sparticle TBP lookup at least sees the page header."
  (cond
    ((or (not this) (not (file-info-correct-version? (-> this info) (file-kind tpage) 0)))
     (the-as texture-page #f)
     )
    (else
      (when (and *texture-page-dir*
                 (< (the-as uint (-> this id)) (the-as uint (-> *texture-page-dir* length))))
        (let* ((a3-0 (-> this id))
               (s4-0 (-> *texture-page-dir* entries a3-0))
               )
          (set! (-> s4-0 page) this)
          (if (not (-> s4-0 link))
              (set! (-> s4-0 link)
                    (the-as texture-link (malloc 'loading-level (* (max (-> s4-0 length) (-> this length)) 4)))
                    )
              )
          )
        )
      this
      )
    )
  )

(defun relocate-later ()
  "Unused in jak 2 and likely unsed in jak 3. Feature to postpone some texture copying until
   a later frame. This is only used in cases when texture data must be memcpy'd in RAM, to patch up a hole left
   by some data that is now permanently in VRAM, and no longer needed.
   Note that Jak2/Jak3 don't have this problem since level textures are now never permanent"
  (let ((gp-0 *texture-relocate-later*))
    (let ((s5-0 (-> gp-0 entry))
          (s4-0 (-> gp-0 page))
          )
      (ultimate-memcpy (the-as pointer (-> gp-0 dest)) (the-as pointer (-> gp-0 source)) (-> gp-0 move))
      (set! (-> s5-0 page) s4-0)
      (if (not (-> s5-0 link))
          (set! (-> s5-0 link)
                (the-as texture-link (malloc 'loading-level (* (max (-> s5-0 length) (-> s4-0 length)) 4)))
                )
          )
      )
    (set! (-> gp-0 memcpy) #f)
    )
  #f
  )

