;; og:preserve-this (jak3 port adapted for jakx — tex1 is uint64 not gs-tex1)
(defun adgif-shader<-texture! ((arg0 adgif-shader) (arg1 texture))
  ;; gs-tex1 bit layout: mxl[4:2]=3bits, mmag[5]=1bit, mmin[8:6]=3bits, l[20:19]=2bits
  ;; preserve the tfx field from current tex0 before rebuilding.
  ;; jakx Cycle 89 fix: prior hand-port used (shr tex0 3) which reads bits 3-4
  ;; (random TBP bits) instead of TFX at bits 35-36; that fed garbage into
  ;; :tfx and tripped Sprite3.cpp:685 ASSERT(reg.tfx() == MODULATE) in krastrn.
  (let ((tfx-save (the-as int (logand (shr (-> arg0 tex0) 35) 3))))
    (let* ((mxl-v (logand (+ (the-as int (-> arg1 num-mips)) -1) 7))
           (mmag-v (logand (-> arg1 tex1-control) 1))
           (mmin-v (logand (shr (-> arg1 tex1-control) 1) 7))
           (l-v (logand (the-as int (-> arg1 mip-shift)) 3))
           )
      (set! (-> arg0 tex1)
            (logior (logand (-> arg0 tex1) (the-as uint #xFFFFFFFFFFE7FE03))
                    (the-as uint (logior (shl mxl-v 2) (shl mmag-v 5) (shl mmin-v 6) (shl l-v 19)))
                    )
            )
      )
    (set! (-> arg0 tex0)
          (the-as uint (new 'static 'gs-tex0
                        :tcc #x1
                        :cld #x1
                        :cpsm (-> arg1 clutpsm)
                        :cbp (-> arg1 clutdest)
                        :tfx tfx-save
                        :th (the-as int (log2 (-> arg1 h)))
                        :tw (the-as int (log2 (-> arg1 w)))
                        :tbw (-> arg1 width 0)
                        :tbp0 (-> arg1 dest 0)
                        :psm (the-as int (-> arg1 psm))
                        )
                )
          )
    )
  (set! (-> arg0 miptbp1)
        (the-as uint (new 'static 'gs-miptbp
                      :tbp1 (-> arg1 dest 1)
                      :tbw1 (-> arg1 width 1)
                      :tbp2 (-> arg1 dest 2)
                      :tbw2 (-> arg1 width 2)
                      :tbp3 (-> arg1 dest 3)
                      :tbw3 (-> arg1 width 3)
                      )
              )
        )
  arg0
  )

(define *texture-pool* (new 'global 'texture-pool))
