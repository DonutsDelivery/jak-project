(defmethod texture-page-method-11 ((this texture-page) (new-dest int) (seg-id int))
  (let ((v1-5 (shr (- new-dest (the-as int (-> this segment seg-id dest))) 6)))
    (set! (-> this segment seg-id dest) (the-as uint new-dest))
    (when (nonzero? v1-5)
      (dotimes (a1-2 (-> this length))
        (when (-> this data a1-2)
          (let* ((a3-9 (-> this data a1-2))
                 (t0-0 (-> a3-9 num-mips))
                 )
            (if (zero? seg-id)
                (+! (-> a3-9 clutdest) v1-5)
                )
            (dotimes (t1-3 (the-as int t0-0))
              (let ((t2-0 t1-3)
                    (t3-0 t0-0)
                    )
                (if (= seg-id (if (>= (the-as uint 2) t3-0)
                                  (+ (- -1 t2-0) t3-0)
                                  (max 0 (- 2 t2-0))
                                  )
                       )
                    (+! (-> a3-9 dest t1-3) v1-5)
                    )
                )
              )
            )
          )
        )
      )
    )
