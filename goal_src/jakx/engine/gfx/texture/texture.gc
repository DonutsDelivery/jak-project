                   (upload-vram-data s3-0 (the-as int (* (+ sv-20 sv-40) 64)) (&+ sv-16 (shl sv-40 14)) (* sv-32 32) 128)
                   (+! s5-0 sv-32)
                   (set! sv-32 0)
                   0
                   )
                  (else
                    (set! (-> pool ids v1-30) sv-48)
                    (set! sv-32 (+ sv-32 1))
                    )
                  )
                )
              )
            (when (nonzero? sv-32)
              (upload-vram-data s3-0 (the-as int (* (+ sv-20 sv-40) 64)) (&+ sv-16 (shl sv-40 14)) (* sv-32 32) 128)
              (+! s5-0 sv-32)
              )
            (dma-buffer-add-gs-set s3-0 (texflush 1))

            ;; Cycle 91: PC_PORT hook ported from jak3 texture.gc:837. Emits a
            ;; vif-cmd pc-port tag containing the texture-page* and upload-mode
            ;; that TextureUploadHandler::render reads to call handle_upload_now,
            ;; which registers m_textures[tex.dest[mip_idx]] for every texture in
            ;; the page. Without this, the per-frame DMA path uploads texel data
            ;; but never tells C++ to populate the lookup table -> Sprite3 logs
            ;; 'Failed to find texture at TBP=N (sprite)'.
