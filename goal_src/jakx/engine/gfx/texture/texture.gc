      (when (not (-> v1-2 dma-buffer-overflow))
        (let ((t0-2 (-> v1-2 frames (-> v1-2 on-screen) global-buf)))
          (if (< (-> t0-2 real-buffer-end) (the-as int (&+ (-> t0-2 base) a0-1)))
              (set! (-> v1-2 dma-buffer-overflow) #t)
              )
