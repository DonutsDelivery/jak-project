         (f3-1 (/ (-> v1-1 fog-dists w) 255))
         (f4-2 (/ (-> v1-1 fog-dists z) 255))
         )
    (+ f4-2 (* (fmax 0.0 (fmin 1.0 (/ (- f0-0 f1-0) (- f2-0 f1-0)))) (- f3-1 f4-2)))
    )
  )

(defmethod palette-fade-controls-method-10 ((this palette-fade-controls) (arg0 int) (arg1 float) (arg2 float) (arg3 vector))
