(defmethod deactivate ((this time-of-day-proc))
  "Make a process dead, clean it up, remove it from the active pool, and return to dead pool."
  (if (nonzero? (-> this sun))
      ((method-of-object (-> this sun) sparticle-launch-control-method-19))
      )
  (if (nonzero? (-> this green-sun))
      ((method-of-object (-> this green-sun) sparticle-launch-control-method-19))
      )
  (if (nonzero? (-> this moon))
      ((method-of-object (-> this moon) sparticle-launch-control-method-19))
      )
  ((method-of-type process deactivate) this)
  )

(if (zero? time-of-day-effect)
    (set! time-of-day-effect nothing)
    )

