;; WARN: Return type mismatch object vs (pointer time-of-day-proc).
(defun start-time-of-day ()
  (with-pp
    (format 0 "PP=~D~%" pp)
    (format 0 "#f=~D~%" #f)
    (kill-by-name "time-of-day-proc" *active-pool*)
    (set! *time-of-day*
          (process-spawn time-of-day-proc :init init-time-of-day :name "time-of-day-proc" :to *bg-pool*)
          )
    (the-as (pointer time-of-day-proc) *time-of-day*)
    )
  )

