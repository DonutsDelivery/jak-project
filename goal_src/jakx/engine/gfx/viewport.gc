;;-*-Lisp-*-
(in-package goal)

(define-extern shadow-make-invert-buf (function none))
(define-extern init-warp (function none))
(define-extern init-hflip-zbuf (function none))

;; *viewport-array* global initialization.
;; The decompiled new-method calls view-get-math-camera which isn't in GAME.CGO yet,
;; so we allocate via structure-new (zeroed) and patch fields manually.
(define *viewport-array* (new 'global 'viewport-array))

;; Initialize all 3 viewport slots for single-player full-screen (screen-sx=512, screen-sy=416).
;; viewport-method-12 sets these; we replicate the screen-dimension subset needed by font rendering.
(dotimes (i 3)
  (set! (-> *viewport-array* data i math-camera) *math-camera*)
  (set! (-> *viewport-array* data i screen-sx) 512)
  (set! (-> *viewport-array* data i screen-sy) 416)
  ;; derived fields normally computed by viewport-method-11
  (set! (-> *viewport-array* data i screen-hx) (/ 512 2))
  (set! (-> *viewport-array* data i screen-hy) (/ 416 2))
  (set! (-> *viewport-array* data i screen-qx) (/ 256 2))
  (set! (-> *viewport-array* data i screen-qy) (/ 208 2))
  (set! (-> *viewport-array* data i screen-maxx) (+ 512 1792))
  (set! (-> *viewport-array* data i screen-maxy) (+ 416 1840))
  (set! (-> *viewport-array* data i screen-cx) (+ 256 1792))
  (set! (-> *viewport-array* data i screen-cy) (+ 208 1840))
  (set! (-> *viewport-array* data i ratio-x) 1.0)
  (set! (-> *viewport-array* data i ratio-y) 1.0)
  )

(set! (-> *viewport-array* num-viewports) (the-as uint 1))

(defmethod viewport-method-11 ((this viewport))
  (set! (-> this screen-hx) (/ (-> this screen-sx) 2))
  (set! (-> this screen-hy) (/ (-> this screen-sy) 2))
  (set! (-> this screen-qx) (/ (-> this screen-hx) 2))
  (set! (-> this screen-qy) (/ (-> this screen-hy) 2))
  (set! (-> this screen-maxx) (+ (-> this screen-sx) 1792))
  (set! (-> this screen-maxy) (+ (-> this screen-sy) 1840))
  (set! (-> this screen-cx) (+ (-> this screen-hx) 1792))
  (set! (-> this screen-cy) (+ (-> this screen-hy) 1840))
  (set! (-> this blur-hx) (/ (-> this blur-sx) 2))
  (set! (-> this blur-hy) (/ (-> this blur-sy) 2))
  (set! (-> this blur-cx) (+ (-> this blur-hx) 1792))
  (set! (-> this blur-cy) (+ (-> this blur-hy) 1840))
  (set! (-> this blur-scale) 0.0)
  (set! (-> this scissor)
        (new 'static 'gs-scissor :scax1 (+ (-> this screen-sx) -1) :scay1 (+ (-> this screen-sy) -1))
        )
  (set! (-> this scissor-on-screen)
        (the-as
          uint
          (logior (logior (logior (shr (shl (+ (-> this screen-sy) -1 (-> this miny-on-screen)) 53) 5)
                                  (shr (shl (+ (-> this screen-sx) -1 (-> this minx-on-screen)) 53) 37)
                                  )
                          (shr (shl (-> this miny-on-screen) 53) 21)
                          )
                  (shr (shl (-> this minx-on-screen) 53) 53)
                  )
          )
        )
  (set-vector!
    (-> this shadow-texoffset)
    (+ 0.5 (* 0.5 (the float (-> this screen-sx))))
    (+ 0.5 (* 0.5 (the float (-> this screen-sy))))
    0.0
    1.0
    )
  ;; SCAFFOLDING: PS2 display/GIF setup code - args mangled by decompiler, stub here
  (when (!= (-> this index) 2)
    (math-camera-method-9 (-> this math-camera))
    )
  0
  (none)
  )

(defmethod viewport-method-12 ((this viewport))
  (set! (-> this screen-sx) 512)
  (set! (-> this screen-sy) 416)
  (set! (-> this ratio-x) 1.0)
  (set! (-> this ratio-y) 1.0)
  (set! (-> this frame) (new 'static 'gs-frame :fbp #x196 :fbw #x8))
  (set! (-> this frame-a) (new 'static 'gs-frame :fbp #x196 :fbw #x8 :fbmsk #xffffff))
  (set! (-> this zbuf-on) (new 'static 'gs-zbuf :zbp #x12e :psm (gs-psm ct24)))
  (set! (-> this zbuf-off) (new 'static 'gs-zbuf :zbp #x12e :psm (gs-psm ct24) :zmsk #x1))
  (set! (-> this tex0) (new 'static 'gs-tex0 :tbp0 #x32c0 :tbw #x8 :tw #x9 :th #x9 :tcc #x1))
  (set! (-> this tex0-24) (new 'static 'gs-tex0 :tbp0 #x32c0 :tbw #x8 :tw #x9 :th #x9))
  (set! (-> this clamp) (new 'static 'gs-clamp
                          :wms (gs-tex-wrap-mode region-clamp)
                          :wmt (gs-tex-wrap-mode region-clamp)
                          :maxu #x1ff
                          :maxv #x19f
                          )
        )
  (set! (-> this copy-frame) (new 'static 'gs-frame :fbp #x22 :fbw #x8))
  (set! (-> this copy-tex0) (new 'static 'gs-tex0 :tbp0 #x440 :tbw #x8 :tw #x9 :th #x9 :tcc #x1))
  (set! (-> this glow-frame-1) (the-as uint #xffffff00080196))
  (set! (-> this glow-tex0-1) (the-as uint #xd540051c0))
  (set! (-> this glow-frame-2) (the-as uint #xffffff0001008e))
  (set! (-> this glow-tex0-2) (the-as uint #xe640232c0))
  (set! (-> this shadow-invert-frame) (the-as uint #xff0000000008012e))
  (set! (-> this shadow-dma-frame) (the-as uint #xffffff00080196))
  (set! (-> this shadow-dma-tex0) (the-as uint #x1e640232c0))
  (set-vector! (-> this shadow-texscale) 0.001953125 0.001953125 0.0 1.0)
  (set! (-> this blur-sx) 256)
  (set! (-> this blur-sy) 256)
  (set! (-> this blur-frame-0) (the-as uint #x4004e))
  (set! (-> this blur-frame-1) (the-as uint #x4006e))
  (set! (-> this blur-frame-a) (the-as uint #xffffff0004004e))
  (set! (-> this blur-tex0-0) (the-as uint #x2200109c0))
  (set! (-> this blur-tex0-1) (the-as uint #x220010dc0))
  (set! (-> this blur-tex0-a) (the-as uint #x6200109c0))
  (set! (-> this blur-clamp) (the-as uint #x3fc003fc00a))
  (set! (-> this blur-scissor) (the-as uint #xff000000ff0000))
  (set! (-> this minx-on-screen) 0)
  (set! (-> this miny-on-screen) 0)
  (viewport-method-11 this)
  0
  )

(defmethod viewport-method-13 ((this viewport))
  (set! (-> this screen-sx) 512)
  (set! (-> this ratio-x) 1.0)
  (set! (-> this ratio-y) 0.5)
  (cond
    ((zero? (-> this index))
