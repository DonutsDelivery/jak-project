     (set! (-> this shadow-dma-tex0) (the-as uint #x1e240232c0))
     (set-vector! (-> this shadow-texscale) 0.001953125 0.00390625 0.0 1.0)
     (set! (-> this blur-sx) 256)
     (set! (-> this blur-sy) 128)
     (set! (-> this blur-frame-0) (the-as uint #x4004e))
     (set! (-> this blur-frame-1) (the-as uint #x4006e))
