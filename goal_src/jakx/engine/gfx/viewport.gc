     0
     )
    ((= (-> this index) 1)
     (set! (-> this screen-sy) 192)
     (set! (-> this frame) (new 'static 'gs-frame :fbp #x1c6 :fbw #x8))
     (set! (-> this frame-a) (new 'static 'gs-frame :fbp #x1c6 :fbw #x8 :fbmsk #xffffff))
