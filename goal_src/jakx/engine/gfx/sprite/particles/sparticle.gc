(defun forall-particles ((arg0 function) (arg1 symbol) (arg2 symbol))
  (if arg1
      (forall-particles-runner
        (the-as (function sparticle-system sparticle-cpuinfo pointer none) arg0)
        (the-as sparticle-system *sp-particle-system-2d*)
        )
      )
  (if arg2
      (forall-particles-runner
        (the-as (function sparticle-system sparticle-cpuinfo pointer none) arg0)
        (the-as sparticle-system *sp-particle-system-3d*)
        )
      )
  0
  (none)
  )

(defun all-particles-50-to-60 ()
  (forall-particles-runner sparticle-50-to-60 (the-as sparticle-system *sp-particle-system-3d*))
  (none)
  )

(defun all-particles-60-to-50 ()
  (forall-particles-runner sparticle-60-to-50 (the-as sparticle-system *sp-particle-system-3d*))
  (none)
