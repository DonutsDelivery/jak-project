   (tie-envmap-scissor-trans-bucket  bucket-id)
   (tie-water-bucket                 bucket-id)
   (tie-scissor-water-bucket         bucket-id)
   (tie-envmap-water-bucket          bucket-id)
   (tie-envmap-scissor-water-bucket  bucket-id)
   )
