      (let* ((s1-0 (-> arg0 data gp-0))
             (gp-1 (-> arg0 prototypes prototype-array-tie))
             (s5-1 (-> gp-1 length))
             (s4-0 (-> *display* frames (-> *display* on-screen) global-buf))
             (s0-0 (-> s4-0 base))
             (s2-1 (&- (-> s4-0 end) (the-as uint (* (-> arg0 prototypes prototype-max-qwc) 16))))
             )
        (set! (-> *instance-tie-work* buffer-start) (the-as uint (-> s4-0 base)))
        (set! (-> *instance-tie-work* buffer-end) (the-as uint s2-1))
        (when *debug-segment*
          (if (>= (the-as uint s0-0) (the-as uint s2-1))
              (format *stdcon* "out of tie memory~%")
              )
          )
        (when (< (the-as uint s0-0) (the-as uint s2-1))
          (dotimes (v1-29 s5-1)
            (let ((a0-20 (-> gp-1 array-data v1-29)))
              (dotimes (a1-6 3)
                (set! (-> a0-20 next-clear a1-6) (the-as uint128 0))
                (set! (-> a0-20 count-clear a1-6) (the-as uint 0))
                )
              )
            )
          (let* ((s2-2 (&+ s1-0 32))
                 (s0-1 (+ (/ (-> s2-2 id) 8) #x3800 #x70000000))
                 (s1-1 (-> (the-as drawable-inline-array-instance-tie s1-0) length))
                 )
            (when (nonzero? s1-1)
              (let* ((v1-37 (logand (the-as int *gsf-buffer*) 8191))
                     (v1-39
                       (the-as
                         object
                         (logand (the-as int (&- (logand (the-as int (&-> gp-1 data -640)) 8191) (the-as uint v1-37))) 8191)
                         )
                       )
                     )
                (set! *instance-tie-work-copy* (the-as instance-tie-work (+ (the-as int *gsf-buffer*) (the-as int v1-39))))
                )
              (quad-copy! (the-as pointer *instance-tie-work-copy*) (the-as pointer *instance-tie-work*) 35)
              (set! (-> *instance-tie-work-copy* wait-to-spr) (the-as uint 0))
              (set! (-> *instance-tie-work-copy* wait-from-spr) (the-as uint 0))
              (set! (-> *instance-tie-work-copy* tfrag-dists) (the-as uint (-> arg1 bsp tfrag-closest)))
              (set! (-> *instance-tie-work-copy* alpha-dists) (the-as uint (-> arg1 bsp alpha-closest)))
              (set! (-> *instance-tie-work-copy* water-dists) (the-as uint (-> arg1 bsp water-closest)))
