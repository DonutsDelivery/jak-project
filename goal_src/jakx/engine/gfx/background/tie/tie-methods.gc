      (dotimes (a0-1 (-> v1-9 length))
        (let ((a1-4 (-> v1-9 array-data a0-1)))
          (when (logtest? (-> *display* vu1-enable-user) (vu1-renderer-mask etie-scissor))
            (let ((a2-4 0)
