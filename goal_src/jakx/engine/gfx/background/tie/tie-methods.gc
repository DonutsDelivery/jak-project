;;-*-Lisp-*-
(in-package goal)

;; name: tie-methods.gc
;; name in dgo: tie-methods
;; dgos: GAME

;; DECOMP BEGINS

(deftype tie-debug (structure)
  ((max-instance   uint32)
   (min-instance   uint32)
   (test-fragment  uint32)
   (frag-count     uint32)
   )
  )


(define *tie* (new 'global 'tie-debug))

;; ERROR: Failed store: (s.w! (+ v1-0 472) arg1) at op 1
;; ERROR: Failed store: (s.w! (+ v1-1 476) arg0) at op 3
(defun tie-debug-between ((arg0 uint) (arg1 uint))
  (let ((v1-0 *instance-tie-work*))
    (s.w! (+ v1-0 472) arg1)
    )
  (let ((v1-1 *instance-tie-work*))
    (s.w! (+ v1-1 476) arg0)
    )
  arg0
  )

;; ERROR: Failed store: (s.w! (+ a1-1 472) v1-1) at op 3
;; ERROR: Failed store: (s.w! (+ v1-2 476) arg0) at op 5
(defun tie-debug-one ((arg0 uint) (arg1 uint))
  (let ((v1-1 (+ arg1 -1 arg0))
        (a1-1 *instance-tie-work*)
        )
    (s.w! (+ a1-1 472) v1-1)
    )
  (let ((v1-2 *instance-tie-work*))
    (s.w! (+ v1-2 476) arg0)
    )
  arg0
  )

(defun tie-debug-frag-between ((arg0 uint) (arg1 uint))
  (set! (-> *tie* test-fragment) arg0)
  (let ((v0-0 (- arg1 arg0)))
    (set! (-> *tie* frag-count) v0-0)
    v0-0
    )
  )

(defun tie-debug-frag-one ((arg0 uint) (arg1 uint))
  (set! (-> *tie* test-fragment) arg0)
  (set! (-> *tie* frag-count) arg1)
  arg1
  )

;; WARN: Return type mismatch symbol vs none.
(defun walk-tie-generic-prototypes ()
  (none)
  )

(define *pke-hack* (new 'global 'vector))

