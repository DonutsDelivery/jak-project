                  )
                (set! (-> *prototype-tie-work* wide-level-index) (the-as uint (-> (the-as level s2-3) index)))
                (when (>= (the-as int (-> *instance-tie-work* buffer-end)) (the-as int (-> s4-0 base)))
                  (set! (-> *prototype-tie-work* wait-to-spr) (the-as uint 0))
