;; vehicle-controls-flag - enum for vehicle control flags
(defenum vehicle-controls-flag
  :type uint32
  :bitfield #t
  )

;; vehicle-controls - needed by pilot-info and vehicle.gc
(deftype vehicle-controls (structure)
  ((steering    float)
   (throttle    float)
   (brake       float)
   (lean-z      float)
   (handbrake   float)
   (flags       vehicle-controls-flag)
   (prev-flags  vehicle-controls-flag)
   )
  )

;; pilot-info - needed by scene.gc (-> *target* pilot vehicle)
(deftype pilot-info (basic)
  ((entity                   basic)
   (vehicle                  handle)
   (left-right-bias          float)
   (left-right-interp        float)
   (front-back-interp        float)
   (up-down-interp           float)
   (stance                   uint8)
   (seat-index               int8)
   (backup-nav-radius        float)
   (gun?                     symbol)
   (controls                 vehicle-controls  :inline)
   )
  )

