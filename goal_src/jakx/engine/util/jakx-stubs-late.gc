;; title-control lives in TITLE.DGO (title-obs.o), which loads after GAME.CGO.
;; spawn-title-control is our wrapper in title-obs.gc; level.gc calls it as a
;; plain function by name, so only the extern is needed here (no type refs).
(define-extern spawn-title-control (function none))

