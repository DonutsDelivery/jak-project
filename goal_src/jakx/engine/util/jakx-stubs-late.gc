;; view type is defined in view-h.gc

;; entity-by-name: ported from jak3/engine/entity/entity.gc:102.
;; Walks active levels' BSP actors/nav-meshes/race-meshes/cameras looking for a
;; name match. Called from cam-master-set-entity every frame via
;; (update *setting-control*). Without an impl, the extern null-derefs to
;; 0x2123000000 once (update *setting-control*) is enabled in the display-loop.
(defun entity-by-name ((arg0 string))
  (if (not arg0)
      (return (the-as entity #f))
      )
  (dotimes (s5-0 (-> *level* length))
    (let ((s4-0 (-> *level* level s5-0)))
      (when (= (-> s4-0 status) 'active)
        (let ((s3-0 (-> s4-0 bsp actors)))
          (when (nonzero? s3-0)
            (dotimes (s2-0 (-> s3-0 length))
              (let ((s1-0 (-> s3-0 data s2-0 actor)))
                (if (string= (res-lump-struct s1-0 'name string) arg0)
                    (return s1-0)
                    )
                )
              )
            )
          )
        (let ((s3-1 (-> s4-0 bsp nav-meshes)))
          (when (nonzero? s3-1)
            (dotimes (s2-1 (-> s3-1 length))
              (let ((s1-1 (-> s3-1 s2-1)))
                (if (string= (res-lump-struct s1-1 'name string) arg0)
                    (return s1-1)
                    )
                )
              )
            )
          )
        (let ((s3-2 (-> s4-0 bsp race-meshes)))
          (when (nonzero? s3-2)
            (dotimes (s2-2 (-> s3-2 length))
              (let ((s1-2 (-> s3-2 s2-2)))
                (if (string= (res-lump-struct s1-2 'name string) arg0)
                    (return s1-2)
                    )
                )
              )
            )
          )
        (let ((s4-1 (-> s4-0 bsp cameras)))
          (when (nonzero? s4-1)
            (dotimes (s3-3 (-> s4-1 length))
              (let ((s2-3 (-> s4-1 s3-3)))
                (if (string= (res-lump-struct s2-3 'name string) arg0)
                    (return s2-3)
                    )
                )
              )
            )
          )
        )
      )
    )
  (the-as entity #f)
  )

;; add-blackout: ported from jak3/engine/game/main.gc:104.
;; apply-settings (settings.gc) calls this every frame from (update *setting-control*).
;; It updates display bgcolor / pmode alpha for the fade-to-black transition.
;; Without a real impl, the extern null-derefs to 0x2123000000 at first call.
(defun add-blackout ((arg0 time-frame) (r int) (g int) (b int) (arg4 int))
  "Update display settings to do blackout with GS pmode alp."
  (let ((v1-0 *display*))
    (let ((a0-1 (new 'static 'array time-frame 2 (seconds 0) (seconds 0))))
      (set! (-> v1-0 bgcolor r) r)
      (set! (-> v1-0 bgcolor g) g)
      (set! (-> v1-0 bgcolor b) b)
      (set! (-> v1-0 pmode alp) (- 255 arg4))
      (set! (-> a0-1 0) 0)
      (set! (-> a0-1 1) 0)
      )
    (if (nonzero? arg4)
        (set! (-> v1-0 force-sync) (the-as uint (max 4 (the-as int (-> v1-0 force-sync)))))
        )
    )
  0
  )

;; set-mh-primary-target / set-ff-primary-target / set-kg-primary-target:
;; jakx metal-head / Freedom Fighters / Krimzon Guard AI primary-target setters.
;; Referenced by apply-settings when *city-mode* is 'ctywide. Not reached at boot
;; (*city-mode* is #f), but stubbed so the externs resolve. Real ports can land
;; later when the faction AI is hooked up.
;; og:preserve-this — stubs; real impls depend on faction AI that isn't ported yet.
(defun set-mh-primary-target ((arg0 handle) (arg1 float))
  (none)
  )
(defun set-ff-primary-target ((arg0 handle) (arg1 float))
  (none)
  )
(defun set-kg-primary-target ((arg0 handle) (arg1 float))
  (none)
  )

;; process-entity-set!: binds a process to its entity + level. Declared extern
;; at engine/common-obs/generic-obs.gc:20 with no body; called from
;; title-control-init, manipy-init, and ~5 other sites. Ported verbatim from
;; jak3 engine/entity/entity.gc:477.
(defun process-entity-set! ((arg0 process) (arg1 entity))
  (set! (-> arg0 entity) (the-as entity-actor arg1))
  (if arg1
      (set! (-> arg0 level) (-> arg1 extra level))
      (set! (-> arg0 level) (-> *level* level-default))
      )
  arg1
  )
