;; process-entity-set!: binds a process to its entity + level. Declared extern
;; at engine/common-obs/generic-obs.gc:20 with no body; called from
;; title-control-init, manipy-init, and ~5 other sites. Ported verbatim from
;; jak3 engine/entity/entity.gc:477.
(defun process-entity-set! ((arg0 process) (arg1 entity))
  (set! (-> arg0 entity) (the-as entity-actor arg1))
  (if arg1
      (set! (-> arg0 level) (-> arg1 extra level))
      (set! (-> arg0 level) (-> *level* level-default))
      )
  arg1
  )

;; task-node-reset + update-task-masks — also called from reset-actors (ported
;; from jak3) and from initialize! movie/debug branches. jak3 bodies in
;; engine/game/task/task-control.gc:1524 (reset) and :87 (update). For Phase
;; 2/3 stub as no-ops — nothing in the title/menu path depends on task nodes
;; being in any particular state.
(defun task-node-reset ((arg0 symbol))
  0
  )
(defun update-task-masks ((arg0 symbol))
  0
  )

;; update — method on entity-perm. Method slot declared in entity-h.gc
;; but no body in jakx. Called from reset-actors's task-perm-list / perm-list
;; iteration. Null method dispatch = 0x2123000000 null crash.
;; Ported verbatim from jak3 engine/entity/entity.gc:1925.
(defmethod update ((this entity-perm) (arg0 symbol) (arg1 entity-perm-status))
  (cond
    ((= arg0 'game)
     (logclear! (-> this status) arg1)
     )
    ((task-complete? *game-info* (-> this task))
     (if (or (= arg0 'try) (= arg0 'life))
         (logclear! (-> this status) (logior (if (logtest? (-> this status) (entity-perm-status bit-4))
                                                 524
                                                 0
                                                 )
                                             #x8203
                                             )
                    )
         (logclear! (-> this status) (logior (if (logtest? (-> this status) (entity-perm-status bit-4))
                                                 524
                                                 0
                                                 )
                                             515
                                             )
                    )
         )
     )
    (else
      (logclear! (-> this status) (logclear
                                    (logior arg1 (if (logtest? (-> this status) (entity-perm-status bit-4))
                                                     524
                                                     0
                                                     )
                                            )
                                    (if (logtest? (-> this status) (entity-perm-status bit-14))
                                        32
                                        0
                                        )
                                    )
                 )
      )
    )
  (when (not (logtest? (-> this status) (entity-perm-status bit-5)))
    (set! (-> this user-uint64) (the-as uint 0))
    0
    )
  this
  )

;; open! — method 12 on game-task-node-info. Declared in task-control-h.gc
;; but has no defmethod body in jakx. Called from initialize!'s spawned lambda
;; ((open! (-> *game-info* sub-task-list (game-task-node city-start-start)) 'event)).
;; Without a body, the method dispatch hits a null function pointer and
;; segfaults at 0x2123000000 (null in EE) on the next kernel dispatch.
;; Real jak3 body at engine/game/task/task-control.gc:956 (~50 lines) unlocks
;; next-task-node logic. For Phase 2/3 bringup, stub to no-op — nothing in
;; the title/menu path depends on task nodes actually opening.
(defmethod open! ((this game-task-node-info) (arg0 symbol))
  0
  )

;; task-node-open! — plain function, extern at task-control-h.gc:64.
;; Same story: lambda in initialize! calls it on (-> reset-spec node) when
;; reset-spec is non-#f. For our boot path reset-spec = #f so this call is
;; guarded away — but a dispatching call would crash. Stub matches the extern
;; signature (function game-task-node symbol int).
(defun task-node-open! ((arg0 game-task-node) (arg1 symbol))
  0
  )

;; start (player lifecycle) now lives in goal_src/jakx/engine/target/logic-target.gc
;; after the real target-init/target-init! port landed. The stub that used to
;; live here (which returned #f and skipped process-spawn) has been removed;
;; start now spawns a real target process so *target* can become non-#f.

;; jakx entity.gc top-level initializer (decompiler_out/jakx/entity_disasm.gc:5).
;; Without this, actors-update's (when *spawn-actors*) gate never opens and no
;; BSP entities ever get birthed. entity-h.gc declares it as define-extern;
;; the real entity.gc provides the value. (*compact-actors* is already defined
;; above; *vis-actors* is not yet used by any ported code.)
(define *spawn-actors* #t)

;; Ported from jak3 engine/entity/entity.gc:1970. Required by game-info.gc's initialize! 'boot lambda for Phase 3.
(defun reset-actors ((arg0 symbol))
  (let* ((v1-0 arg0)
         (perm
           (cond
             ((or (= v1-0 'life) (= v1-0 'debug))
              (the-as
                entity-perm-status
                (entity-perm-status bit-0 error dead no-kill bit-5 subtask-complete bit-9 bit-12 bit-15)
                )
              )
             ((= v1-0 'try)
              (the-as
                entity-perm-status
                (entity-perm-status bit-0 error dead no-kill bit-5 subtask-complete bit-9 bit-12 bit-15)
                )
              )
             ((= v1-0 'game)
              (the-as entity-perm-status (entity-perm-status
                                           bit-0
                                           error
                                           dead
                                           no-kill
                                           bit-4
                                           bit-5
                                           subtask-complete
                                           complete
                                           bit-9
                                           bit-10
                                           save
                                           bit-12
                                           bit-13
                                           bit-15
                                           )
                      )
              )
             (else
               (the-as
                 entity-perm-status
                 (entity-perm-status bit-0 error dead no-kill bit-4 bit-5 subtask-complete bit-9 bit-10 bit-12 bit-15)
                 )
               )
             )
           )
         (s4-0 *game-info*)
         )
    (dotimes (s3-0 (-> *level* length))
      (let ((v1-4 (-> *level* level s3-0)))
        (when (or (= (-> v1-4 status) 'active) (= (-> v1-4 status) 'alive) (= (-> v1-4 status) 'loaded))
          (when (-> v1-4 part-engine)
            (set! (-> v1-4 part-engine length) 0)
            0
            )
          (when (-> v1-4 entity)
            (let ((s2-0 (-> v1-4 bsp level entity)))
              (dotimes (s1-0 (-> s2-0 length))
                (let ((s0-0 (-> s2-0 data s1-0 entity)))
                  (if (not (and (-> s0-0 extra process) (logtest? (-> s0-0 extra process mask) (process-mask no-kill))))
                      (kill! s0-0)
                      )
                  (update (-> s0-0 extra perm) arg0 (the-as entity-perm-status perm))
                  )
                )
              )
            )
          )
        )
      )
    (let ((s4-1 (-> s4-0 perm-list)))
      (dotimes (s3-2 (-> s4-1 length))
        (update (-> s4-1 data s3-2) arg0 (the-as entity-perm-status perm))
        )
      )
    )
  (let ((s5-1 (lambda ((arg0 process)) (if (not (logtest? (-> arg0 mask) (process-mask no-kill)))
                                           (deactivate arg0)
                                           )
                      )
              )
        )
    (iterate-process-tree *pusher-pool* s5-1 *null-kernel-context*)
    (iterate-process-tree *entity-pool* s5-1 *null-kernel-context*)
    )
  (if #t
      (task-node-reset arg0)
      )
  (dotimes (s5-2 (-> *level* length))
    (let ((s4-2 (-> *level* level s5-2)))
      (when (= (-> s4-2 status) 'active)
        (let ((s3-3 (the-as (function level none) (get-callback-symbol-value-by-slot! (-> s4-2 info) 35))))
          (if (and s3-3 (type? s3-3 function))
              (s3-3 s4-2)
              )
          )
        )
      )
    )
  (set! (-> *ACTOR-bank* birth-max) 1000)
  (update-task-masks arg0)
  0
  (none)
  )

;; --- Entity birth system ports (entity.gc not yet ported) ---

;; ported from jak3 entity.gc:1906. Five-line trivial port; was define-extern'd
;; in entity-h.gc with no body, causing every actor's init-from-entity! to
;; null-dispatch (addr 0x2123000000) the moment bsp-init-actors! wires up the
;; entity-links-array. Found cycle 54 by isolating Path B atoll regression.
(defun process-drawable-from-entity! ((arg0 process-drawable) (arg1 entity-actor))
  (logior! (-> arg0 mask) (process-mask actor-pause))
  (vector-copy! (-> arg0 root trans) (-> arg1 extra trans))
  (quaternion-copy! (-> arg0 root quat) (-> arg1 quat))
  (vector-identity! (-> arg0 root scale))
  (none)
  )

;; activate a process from BSP entity data and run its init-from-entity!
;; ported from entity.gc:3990
(defun init-entity ((arg0 process) (arg1 entity-actor) (arg2 type))
  (activate arg0 *entity-pool* (the-as string (-> arg1 pad)) (the-as pointer #x70004000))
  (set! (-> arg0 entity) arg1)
  (set! (-> arg0 level) (-> arg1 extra level))
  (set! (-> arg1 extra process) arg0)
  (run-now-in-process arg0 (method-of-object arg0 init-from-entity!) arg0 arg1)
  (none)
  )

;; base entity.birth! — just a debug-print stub (ported from entity.gc:325)
(defmethod birth! ((this entity))
  (format #t "birth ~A~%" this)
  this
  )

;; entity-actor.birth! — ported from entity.gc:4000
;; Looks up etype in *entity-info*, allocates from dead pool, and runs init-from-entity!.
;; Falls back to birth-viewer for unknown types. Sets bit-0 on failure to suppress retries.
(defmethod birth! ((this entity-actor))
  (let ((s5-1 (-> this etype)))
    ;; Guard: if etype is null skip this entity entirely (avoids null-deref in type-type?).
    (when (zero? (the-as int s5-1))
      (format 0 "[birth!] entity aid=#x~X has null etype — skipping~%" (-> this aid))
      (logior! (-> this extra perm status) (entity-perm-status bit-0))
      (goto cfg-21))
    ;; Prevent process-nettable types with method 40 from auto-spawning.
    (when (not (logtest? (-> this extra kill-mask) (task-mask never)))
      (when (and (type-type? s5-1 process-nettable) (nonzero? (-> s5-1 method-table 40)))
        (format 0 "WARNING: preventing ~A from auto-spawning~%" this)
        (logior! (-> this extra kill-mask) (task-mask never))
        (set! this (the-as entity-actor #f))
        (goto cfg-21)))
    (let* ((v1-11 (entity-info-lookup s5-1))
           (s4-0 (get-process
                   *default-dead-pool*
                   s5-1
                   (if v1-11 (-> v1-11 heap-size) #x4000)
                   0)))
      (cond
        ((not s4-0)
         (format 0 "[birth!] no process slot for etype ~A~%" s5-1))
        ((begin
           (set! (-> s4-0 type) s5-1)
           (and s5-1
                (valid? s5-1 type (the-as string #f) #f 0)
                (valid? (method-of-object s4-0 init-from-entity!) function (the-as string #f) #f 0)))
         (init-entity s4-0 this s5-1))
        (else
          (when (not (birth-viewer s4-0 this))
            (format 0 "[birth!] no init-from-entity! for type ~A on entity ~A~%" s5-1 this)
            (logior! (-> this extra perm status) (entity-perm-status bit-0)))))))
  (label cfg-21)
  this
  )

;; entity.kill! — ported from entity.gc:331
(defmethod kill! ((this entity))
  (format #t "kill ~A~%" this)
  this
  )

;; Called by entity-actor.kill! when the entity's process has already died.
;; Clears error/no-kill flags and nulls the process pointer.
;; ported from entity.gc:4048
(defun entity-deactivate-handler ((arg0 process) (arg1 entity-actor))
  (when (= arg0 (-> arg1 extra process))
    (logclear! (-> arg1 extra perm status) (entity-perm-status error no-kill))
    (set! (-> arg1 extra process) #f)
    )
  (none)
  )

;; entity-actor.kill! — ported from entity.gc:4058
(defmethod kill! ((this entity-actor))
  (let ((a0-1 (-> this extra process)))
    (if a0-1
        (deactivate a0-1)
        (entity-deactivate-handler a0-1 this)
        )
    )
  this
  )

;; Cycle 54 Path B (allow-list per orchestrator inbox decision):
;; Returns #t if the actor's process class is ported into jakx and safe to
;; spawn from bsp-init-actors!. Conservative default: empty allow-list — every
;; actor is filtered out, so entity-links-array stays empty and the per-frame
;; auto-spawn dispatcher has nothing to walk. As actor classes get ported into
;; goal_src/jakx/levels/, add their etype to the cond branches.
;; Forward type decls — net-training-obs.o loads after this file in GAME.CGO,
;; but the type-symbols must be visible at compile time of bsp-actor-type-allowed?.
;; The types themselves resolve at runtime once net-training-obs.o is linked in.
(declare-type training-marker process-drawable)
(declare-type training-wall process-drawable)
(declare-type training-bollard process-drawable)
(declare-type eco-green process-drawable)

(defun bsp-actor-type-allowed? ((et type))
  (cond
    ((zero? (the-as int et)) #f)
    ((= et training-marker) #t)
    ((= et training-wall) #t)
    ((= et training-bollard) #t)
    ((= et eco-green) #t)
    (else #f)))

;; Minimal port of jak3 entity.gc:1652 bsp-header.birth method.
;; Just the essential work:
;;   (1) allocate the level's entity-links-array if empty
;;   (2) populate it by inlining jak3's add-to-level! logic from bsp.actors
;; add-to-level! is declared in the entity deftype but never defmethod'd in jakx
;; entity.gc (not yet ported), so calling it would invoke a null slot → SEGFAULT.
;; Skips the camera birth loop and actor-groups init (which touch *camera*/*target*).
;;
;; Cycle 54 Path B: per-actor body gated by bsp-actor-type-allowed? — actors
;; whose process class isn't on the allow-list are skipped (no slot insertion).
;; Empty allow-list = entity-links remains length 0; safe boot baseline.
(defun bsp-init-actors! ((bsp bsp-header))
  (let* ((lev (-> bsp level))
         (lgrp *level*)
         (actor-count (if (nonzero? (-> bsp actors))
                          (-> bsp actors length)
                          0))
         (allowed-count 0))
    (format 0 "[bsp-init-actors!] level=~A actor-count=~D~%" (-> lev name) actor-count)
    (cond
      ((not (-> lev entity))
       (let ((saved-loading-level loading-level))
         (set! loading-level (-> lev heap))
         (set! (-> lev entity) (new 'loading-level 'entity-links-array actor-count))
         (set! loading-level saved-loading-level)))
      ((< (-> lev entity allocated-length) actor-count)
       (format 0 "[bsp-init-actors!] ERROR: entity table too small (~D < ~D)~%"
               (-> lev entity allocated-length) actor-count)))
    (set! (-> lev entity length) 0)
    (set! (-> lgrp entity-link) #f)
    (when (nonzero? (-> bsp actors))
      (dotimes (i (-> bsp actors length))
        (let* ((idx (if (nonzero? (-> bsp actor-birth-order))
                        (logand (-> bsp actor-birth-order i) 8191)
                        i))
               (actor (-> bsp actors data idx actor)))
          (format 0 "[bsp-init-actors!] actor[~D] etype=~A raw=~X aid=~X~%" i (-> actor etype) (-> actor etype) (-> actor aid))
          (when (bsp-actor-type-allowed? (-> actor etype))
            (+! allowed-count 1)
            ;; Grab the next empty slot from the entity-links-array.
            ;; Inlined from jak3 add-to-level! (entity.gc:663) — that method
            ;; is declared but not defmethod'd in jakx yet.
            (let ((slot (-> lev entity data (-> lev entity length))))
              (+! (-> lev entity length) 1)
              (set! (-> slot process) #f)
              (set! (-> slot entity) actor)
              (set! (-> actor extra) slot)
              (cond
                ((-> lgrp entity-link)
                 (let* ((head (-> lgrp entity-link))
                        (nxt (-> head next-link)))
                   (set! (-> head next-link) slot)
                   (set! (-> slot prev-link) head)
                   (set! (-> slot next-link) nxt)
                   (set! (-> nxt prev-link) slot)))
                (else
                  (set! (-> slot prev-link) slot)
                  (set! (-> slot next-link) slot)))
              (set! (-> lgrp entity-link) slot)
              (vector-copy! (-> slot trans) (-> actor trans))
              (set! (-> slot perm aid) (the-as actor-id (-> actor aid)))
              (set! (-> slot level) lev))))))
    (format 0 "[bsp-init-actors!] entity-links populated len=~D (allowed=~D of ~D)~%"
            (-> lev entity length) allowed-count actor-count))
  (none))

;; --- Ports from jak3 collide-shape.gc (for target-init! bringup) ---

(defun cshape-reaction-default ((arg0 control-info) (arg1 collide-query) (arg2 vector) (arg3 vector))
  (cshape-reaction-update-state arg0 arg1 arg3)
  (let ((a1-1 (new 'stack-no-clear 'vector)))
    (vector-copy! a1-1 arg3)
    (when (and (not (logtest? (-> arg0 prev-status) (collide-status on-surface)))
               (not (logtest? (-> arg0 status) (collide-status touch-wall)))
               )
      (let ((f0-1 (- 1.0 (-> arg0 surf impact-fric))))
        (when (< f0-1 1.0)
          (let ((v1-9 (new-stack-vector0))
                (f1-3 (vector-dot (-> arg0 dynam gravity-normal) a1-1))
                )
            0.0
            (vector-! v1-9 a1-1 (vector-float*! v1-9 (-> arg0 dynam gravity-normal) f1-3))
            (let* ((f2-2 (vector-length v1-9))
                   (f3-0 f2-2)
                   )
              (if (< f1-3 0.0)
                  (set! f1-3 (* f1-3 f0-1))
                  )
              (vector+!
                a1-1
                (vector-float*! a1-1 (-> arg0 dynam gravity-normal) f1-3)
                (vector-float*! v1-9 v1-9 (/ f2-2 f3-0))
                )
              )
            )
          )
        )
      )
    (vector-reflect-flat! arg2 a1-1 (-> arg0 surface-normal))
    )
  (-> arg0 status)
  )

(defmethod move-to-point! ((this collide-shape) (arg0 vector))
  (let ((v1-0 (new 'stack-no-clear 'vector)))
    (vector-! v1-0 arg0 (-> this trans))
    (vector-copy! (-> this trans) arg0)
    (let ((a1-2 (-> this root-prim)))
      (countdown (a0-1 (-> this total-prims))
        (vector+! (-> a1-2 prim-core world-sphere) (-> a1-2 prim-core world-sphere) v1-0)
        (set! (-> a1-2 prim-core world-sphere w) (-> a1-2 local-sphere w))
        (&+! a1-2 80)
        )
      )
    )
  0
  (none)
  )

;; ported from decompiler_out/jakx/collide-shape_disasm.gc:546 — bounding-sphere
;; transform. For each prim in the shape's prim-list, transform local-sphere into
;; world-sphere using the bone transform indexed by prim->transform-index. VU0
;; inline asm for SIMD ops. transform-index encoding:
;;   >= 0  : bone-index, transform via node-list bone (mul-mat-vec + perspective)
;;   == -2 : root-trans-only (world = local + this.trans)
;;   == -3 : root-rotated (vector-orient-by-quat + add this.trans)
;; Cycle 56 cascade dep — needed before training-marker init-from-entity! call.
(defmethod collide-shape-method-46 ((this collide-shape))
  (local-vars (v1-8 float) (a1-5 float) (a1-7 float))
  (rlet ((acc :class vf)
         (Q :class vf)
         (vf0 :class vf)
         (vf1 :class vf)
         (vf2 :class vf)
         (vf3 :class vf)
         (vf4 :class vf)
         (vf5 :class vf)
         (vf6 :class vf)
         )
    (init-vf0-vector)
    (let ((s5-0 (-> this root-prim))
          (v1-1 (-> this process node-list))
          )
      (cond
        ((nonzero? v1-1)
         (countdown (a0-1 (-> this total-prims))
           (let ((a1-0 (-> s5-0 transform-index)))
             (cond
               ((>= a1-0 0)
                (let ((a1-4 (-> v1-1 data a1-0 bone transform)))
                  (.lvf vf5 (&-> a1-4 trans quad))
                  (.lvf vf1 (&-> s5-0 local-sphere quad))
                  (.lvf vf2 (&-> a1-4 rvec quad))
                  (.mul.w.vf acc vf5 vf0)
                  (.div.vf Q vf0 vf5 :fsf #b11 :ftf #b11)
                  (.lvf vf3 (&-> a1-4 uvec quad))
                  (.add.mul.x.vf acc vf2 vf1 acc)
                  (.lvf vf4 (&-> a1-4 fvec quad))
                  )
                (.add.mul.y.vf acc vf3 vf1 acc)
                (.add.mul.z.vf.xyz vf1 vf4 vf1 acc)
                (.mul.vf.xyz vf1 vf1 Q)
                (.svf (&-> s5-0 prim-core world-sphere quad) vf1)
                (.mov a1-5 vf1)
                )
               (else
                 (when (= a1-0 -2)
                   (.lvf vf1 (&-> s5-0 local-sphere quad))
                   (.lvf vf2 (&-> this trans quad))
                   (.add.vf.xyz vf1 vf1 vf2)
                   (.svf (&-> s5-0 prim-core world-sphere quad) vf1)
                   (.mov a1-7 vf1)
                   )
                 )
               )
             )
           (&+! s5-0 80)
           )
         )
        (else
          (countdown (s4-0 (-> this total-prims))
            (case (-> s5-0 transform-index)
              ((-3)
               (let ((s3-0 (new 'stack-no-clear 'vector)))
                 (vector-orient-by-quat! s3-0 (-> s5-0 local-sphere) (the-as quaternion (-> this rot)))
                 (let ((a0-5 (-> s5-0 prim-core)))
                   (let ((v1-5 (-> this trans)))
                     (.lvf vf4 (&-> s3-0 quad))
                     (.lvf vf5 (&-> v1-5 quad))
                     )
                   (.mov.vf.w vf6 vf0)
                   (.add.vf.xyz vf6 vf4 vf5)
                   (.svf (&-> a0-5 world-sphere quad) vf6)
                   )
                 )
               (set! (-> s5-0 prim-core world-sphere w) (-> s5-0 local-sphere w))
               )
              ((-2)
               (.lvf vf1 (&-> s5-0 local-sphere quad))
               (.lvf vf2 (&-> this trans quad))
               (.add.vf.xyz vf1 vf1 vf2)
               (.svf (&-> s5-0 prim-core world-sphere quad) vf1)
               (.mov v1-8 vf1)
               )
              )
            (&+! s5-0 80)
            )
          )
        )
      )
    0
    )
  (none)
  )

