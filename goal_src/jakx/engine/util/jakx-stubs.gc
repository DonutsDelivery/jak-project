;;-*-Lisp-*-
(in-package goal)

;; Simplified stubs for Jak 3 types not in Jak X
;; Loaded after focus.o

;; Forward declarations
(declare-type gun process-drawable)
(declare-type board process-drawable)
(declare-type target-turret process-focusable)
(declare-type process-taskable process-focusable)
(declare-type wings process-drawable)
(declare-type flut process-focusable)

;; Enemy system
(deftype enemy-info (basic)
  ()
  (:methods
    (copy-enemy-info! (_type_ _type_) none)
    )
  )

(deftype enemy (process-focusable)
  ()
  (:methods
    (enemy-method-50 (_type_) none)
    )
  )

(deftype nav-enemy-info (basic)
  ()
  )

(deftype nav-enemy (enemy)
  ()
  )

;; Collectables
(deftype collectable (process-drawable)
  ()
  )

;; Sync methods are needed by generic-obs
(defmethod get-norm! ((this sync-info) (arg0 int))
  0.0
  )

(defmethod get-phase-offset ((this sync-info))
  0.0
  )

(defmethod get-scaled-val! ((this sync-info) (arg0 float) (arg1 int))
  0.0
  )

(defmethod get-timeframe-offset! ((this sync-info) (arg0 time-frame) (arg1 int))
  (the time-frame 0)
  )

;; Process types
(deftype fma-sphere (process-drawable) ())

(defenum process-taskable-flags
  :type uint32
  :bitfield #t
  (ptf0 0)
  (ptf1 1)
  (ptf2 2)
  (ptf3 3)
  (ptf4 4)
  (ptf5 5)
  (ptf6 6)
  (ptf7 7)
  )

(deftype process-taskable (process-focusable)
  ((task     game-task-control)
   (flags    process-taskable-flags)
   )
  (:methods
    (init-collision! (_type_) none)
    (init-skeleton! (_type_) none)
    (init-defaults! (_type_) none)
    (get-art-element (_type_) art-element)
    )
  )
(deftype voicebox (process-drawable) ())
(deftype bug-report (process) ())
(deftype blocking-plane (process-drawable) ())

