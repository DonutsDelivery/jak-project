;; Stub functions
(defun spawn-prim-beam-tracker ((arg0 prim-beam-tracker-params) (arg1 symbol) (arg2 process))
  (the-as process #f)
  )

;; Jak X is a racing game and has no "target" (playable jak character).
;; jak3's (stop ...) kills the target process; here we just update game-info mode.
(defun stop ((arg0 symbol))
  (when *target*
    (kill-by-name "target" *active-pool*)
    (set! *target* (the-as process #f))
    )
  (set! (-> *game-info* mode) arg0)
  0
  )

;; Blackout (transition fade) system is display-dependent and unused during early boot.
(defun set-blackout-frames ((arg0 time-frame))
  0
  (none)
  )

;; Jak3 defines `on` in main.gc to spawn the display process; jakx main.gc is empty.
;; Stub for now — display won't actually render, but boot can continue past (on #t) call in play.
(defun on ((arg0 symbol))
  (the-as process #f)
  )

;; jak3 defines demo?/kiosk? in main.gc — jakx main.gc is empty.
(defun demo? ()
  (or (= *kernel-boot-message* 'demo) (= *kernel-boot-message* 'demo-shared))
  )

(defun kiosk? ()
  (= *kernel-boot-message* 'kiosk)
  )
(define *region-debug-inspect* #f)

;; PC port subtitle system (jak3-specific)
(define *subtitle3* (the-as (pointer process) #f))
(define *subtitle3-text* (the-as basic #f))

;; set-master-mode lives in jak3 main.gc, which is emptied in jakx.
;; Port a simplified version — the full jak3 impl depends on *progress-process*,
;; sound groups, and other globals that are not fully wired up during early
;; bringup. The minimum needed for initialize! *game-info* 'boot to finish is
;; to update *master-mode* + *last-master-mode* without crashing.
(define *last-master-mode* 'game)

(defun set-master-mode ((arg0 symbol))
  "Change the master mode. Minimal jakx bringup stub — skips sound-group
   ops and progress-process logic until those subsystems are live."
  (when (!= arg0 *master-mode*)
    (set! *last-master-mode* *master-mode*)
    (set! *master-mode* arg0)
    ;; og:preserve-this — skip (apply-settings *setting-control*) during bringup;
    ;; it crashes today (settings agent is fixing it).
    )
  0
  (none)
  )

;; title-fade-out / title-progress / activate-progress — all touch *screen-filter*
;; which has no instance in jakx yet. Stubbed no-op for Phase 2 startup body.
;; Port real impls when *screen-filter* is wired up.
;; activate-progress already has an extern decl at engine/ui/progress/progress-h.gc:11
;; as (function process symbol none), so this def must match that exactly.
(defun title-fade-out ((arg0 float))
  0
  )

(defun title-progress ((arg0 symbol))
  0
  )

(defun activate-progress ((arg0 process) (arg1 symbol))
  0
  (none)
  )
