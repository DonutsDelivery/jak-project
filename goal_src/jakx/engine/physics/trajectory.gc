       (set! (-> arg0 initial-speed) (/ (-> arg0 x) (* (-> arg0 time) (cos (-> arg0 initial-tilt)))))
       #t
       )
      (else
        (set! (-> arg0 time) 0.0)
        (set! (-> arg0 initial-speed) 0.0)
        #f
        )
      )
    )
  )

