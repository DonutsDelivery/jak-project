;;-*-Lisp-*-
(in-package goal)

;; name: trajectory-h.gc
;; name in dgo: trajectory-h
;; dgos: GAME

;; DECOMP BEGINS

(deftype trajectory (structure)
  ((initial-position  vector  :inline)
   (initial-velocity  vector  :inline)
   (time              float)
   (gravity           meters)
   )
  (:methods
    (compute-trans-at-time (_type_ float vector) vector)
    (compute-transv-at-time (_type_ float vector) vector)
    (compute-time-until-apex (_type_) float)
    (setup-from-to-duration! (_type_ vector vector float float) int)
    (setup-from-to-xz-vel! (_type_ vector vector float float) int)
    (setup-from-to-y-vel! (_type_ vector vector float float) int)
    (setup-from-to-height! (_type_ vector vector float float) int)
    (setup-from-to-duration-and-height! (_type_ vector vector float float) int)
    (debug-draw (_type_) none)
    )
  )


;; type impact-control is defined here, but it is unknown to the decompiler

;; ERROR: function has no type analysis. Cannot decompile.

;; ERROR: function has no type analysis. Cannot decompile.

;; type point-tracker is defined here, but it is unknown to the decompiler

;; ERROR: function has no type analysis. Cannot decompile.

;; ERROR: function has no type analysis. Cannot decompile.

;; type combo-tracker is defined here, but it is unknown to the decompiler

(method-set! (the-as type combo-tracker) 3 L13)

(deftype traj2d-params (structure)
  ((x              float)
   (y              float)
   (gravity        float)
   (initial-tilt   float)
   (initial-speed  float)
   (time           float)
   )
  )


(deftype traj3d-params (structure)
  ((gravity           float)
   (initial-tilt      float)
   (initial-speed     float)
   (time              float)
   (src               vector  :inline)
   (dest              vector  :inline)
   (diff              vector  :inline)
   (initial-velocity  vector  :inline)
   )
  )


(deftype cubic-curve (structure)
  ((mat  matrix  :inline)
   )
  (:methods
    (cubic-curve-method-9 (_type_ vector vector vector vector) int)
    (cubic-curve-method-10 (_type_ vector float) vector)
    (cubic-curve-method-11 (_type_ vector float) vector)
    (cubic-curve-method-12 (_type_ vector float) vector)
    (cubic-curve-method-13 (_type_) int)
    )
  )
