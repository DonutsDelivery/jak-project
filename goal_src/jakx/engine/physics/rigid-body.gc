          (set! (-> a2-3 fvec quad) a1-12)
          (set! (-> a2-3 trans quad) a3-1)
          )
        (set! (-> s5-0 rbody2) #f)
        (set! (-> s5-0 proc2) #f)
        (when (-> s5-0 cquery best-other-prim)
          (set! (-> s5-0 proc2) (the-as process-focusable (-> s5-0 cquery best-other-prim cshape process)))
