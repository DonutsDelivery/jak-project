(defmethod rigid-body-control-method-14 ((this rigid-body-control) (arg0 float))
  (vector+*! (-> this position) (-> this position) (-> this lin-velocity) arg0)
  (let ((s4-0 (new 'stack-no-clear 'quaternion)))
