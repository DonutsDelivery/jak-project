   (disturbed-time      uint32)
   (perf                rb-perf-data)
   )
  ;; jakx slots 59-88 = jak3 slots 28-55 + 2 extra
  (:state-methods
    idle    ;; 59
    active  ;; 60
    )
  (:methods
    (rigid-body-object-method-30 (_type_) object)                              ;; 61
