(deftype rigid-body-queue (structure)
  ((count    int8)
   (manager  uint64)
   (array    handle  128)
   )
  (:methods
    (rigid-body-queue-method-9 (_type_ process) none)
    (rigid-body-queue-method-10 (_type_) none)
