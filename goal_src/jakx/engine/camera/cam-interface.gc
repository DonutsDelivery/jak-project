;;-*-Lisp-*-
(in-package goal)

;; name: cam-interface.gc
;; name in dgo: cam-interface
;; dgos: GAME

(declare-type camera-combiner process)
(declare-type camera-master process)
(define-extern view-get-active-camera-combiner (function camera-combiner))
(define-extern view-get-active-math-camera (function math-camera))
(define-extern view-get-math-camera (function int math-camera))
(define-extern view-get-active-camera (function camera-master))
(define-extern view-set-active-camera (function camera-master none))
(define-extern view-set-active-camera-combiner (function camera-combiner none))
(define-extern view-push-context (function int none))
(define-extern view-pop-context (function int none))
(define-extern *view-count* int)

;; DECOMP BEGINS

(defun position-in-front-of-camera! ((arg0 vector) (arg1 float) (arg2 float))
  (rlet ((vf0 :class vf)
         (vf4 :class vf)
         (vf5 :class vf)
         (vf6 :class vf)
         )
    (init-vf0-vector)
    (vector-float*! arg0 (-> (view-get-active-math-camera) inv-camera-rot fvec) arg1)
    (vector+float*! arg0 arg0 (-> (view-get-active-math-camera) inv-camera-rot uvec) arg2)
    (let ((s4-4 arg0))
      (let ((s5-1 arg0)
            (v1-2 (-> (view-get-active-math-camera) trans))
            )
        (.lvf vf4 (&-> s5-1 quad))
        (.lvf vf5 (&-> v1-2 quad))
        )
      (.mov.vf.w vf6 vf0)
      (.add.vf.xyz vf6 vf4 vf5)
      (.svf (&-> s4-4 quad) vf6)
      )
    arg0
    )
  )

(defun position-in-front-of-screen! ((arg0 vector) (arg1 float) (arg2 vector))
  (rlet ((vf0 :class vf)
         (vf4 :class vf)
         (vf5 :class vf)
         (vf6 :class vf)
         )
    (init-vf0-vector)
    (let ((s3-1 (vector-negate! (new 'stack-no-clear 'vector) (-> (view-get-active-math-camera) inv-camera-rot fvec)))
          (s4-2
            (vector-float*! (new 'stack-no-clear 'vector) (-> (view-get-active-math-camera) inv-camera-rot fvec) arg1)
            )
          )
      (let ((s1-0 s4-2))
        (let ((s2-1 s4-2)
              (v1-1 (-> (view-get-active-math-camera) trans))
              )
          (.lvf vf4 (&-> s2-1 quad))
          (.lvf vf5 (&-> v1-1 quad))
          )
        (.mov.vf.w vf6 vf0)
        (.add.vf.xyz vf6 vf4 vf5)
        (.svf (&-> s1-0 quad) vf6)
        )
      (reverse-transform-point! arg0 s4-2 s3-1 arg2)
      )
    arg0
    )
  )

(defun matrix-local->world ((arg0 symbol) (arg1 symbol))
  (if arg0
      (-> (view-get-active-math-camera) inv-camera-rot-smooth)
      (-> (view-get-active-math-camera) inv-camera-rot)
      )
  )

(defun matrix-world->local ((arg0 symbol) (arg1 object))
  (-> (view-get-active-math-camera) camera-rot)
  )

(define-perm *camera-dummy-vector* vector (vector-reset! (new 'global 'vector)))

(define-perm *camera-dummy-velocity* vector (vector-reset! (new 'global 'vector)))

(defun camera-pos ()
  (cond
    ((view-get-active-camera-combiner)
     (-> (view-get-active-camera-combiner) trans)
     )
    ((view-get-active-math-camera)
     (-> (view-get-active-math-camera) trans)
     )
    (else
      *camera-dummy-vector*
      )
    )
  )

(defun camera-vel ()
  (local-vars (at-0 int))
  (with-pp
    (rlet ((vf0 :class vf)
           (vf1 :class vf)
           (vf2 :class vf)
           )
      (init-vf0-vector)
      (cond
        ((view-get-active-camera-combiner)
         (let ((gp-0 *camera-dummy-velocity*))
           (.lvf vf1 (&-> (-> (view-get-active-camera-combiner) velocity) quad))
           (let ((f0-0 (-> pp clock frames-per-second)))
             (.mov at-0 f0-0)
             )
           (.mov vf2 at-0)
           (.mov.vf.w vf1 vf0)
           (.mul.x.vf.xyz vf1 vf1 vf2)
           (.svf (&-> gp-0 quad) vf1)
           gp-0
           )
         )
        (else
          (vector-reset! *camera-dummy-velocity*)
          )
        )
      )
    )
  )

(defun math-camera-pos ()
  (-> (view-get-active-math-camera) trans)
  )

(defun math-camera-nearest-dist-sq ((arg0 vector))
  (let ((s5-0 (the-as math-camera #f))
        (f30-0 10000000000.0)
        )
    (dotimes (s4-0 *view-count*)
      (let ((s3-0 (view-get-math-camera s4-0)))
        (when s3-0
          (let* ((a1-0 (-> s3-0 trans))
                 (f0-0 (vector-vector-distance-squared arg0 a1-0))
                 )
            (when (or (< f0-0 f30-0) (not s5-0))
              (set! f30-0 f0-0)
              (set! s5-0 s3-0)
              )
            )
          )
        )
      )
    f30-0
    )
  )

(defun math-camera-nearest ((arg0 vector))
  (let ((gp-0 (the-as math-camera #f)))
    (let ((f30-0 10000000000.0))
      (dotimes (s4-0 *view-count*)
        (let ((s3-0 (view-get-math-camera s4-0)))
          (when s3-0
            (let* ((a1-0 (-> s3-0 trans))
                   (f0-0 (vector-vector-distance-squared arg0 a1-0))
                   )
              (when (or (< f0-0 f30-0) (not gp-0))
                (set! f30-0 f0-0)
                (set! gp-0 s3-0)
                )
              )
            )
          )
        )
      )
    gp-0
    )
  )

(defun math-camera-nearest-matrix ((arg0 vector))
  (-> (math-camera-nearest arg0) inv-camera-rot)
  )

(defun math-camera-nearest-dist ((arg0 vector))
  (sqrtf (math-camera-nearest-dist-sq arg0))
  )

(defun camera-matrix ()
  (if (view-get-active-camera-combiner)
      (-> (view-get-active-camera-combiner) inv-camera-rot)
      (-> (view-get-active-math-camera) inv-camera-rot)
      )
  )

(defun math-camera-matrix ()
  (-> (view-get-active-math-camera) inv-camera-rot)
  )

(defun camera-angle ()
  (let ((f30-0 (-> (view-get-active-math-camera) camera-rot rvec x))
        (f0-0 (-> (view-get-active-math-camera) camera-rot rvec z))
        )
    (atan f0-0 f30-0)
    )
  )

;; WARN: Return type mismatch object vs symbol.
(defbehavior camera-teleport-to-entity process ((arg0 entity-actor))
  (let ((gp-0 (new 'stack-no-clear 'transformq)))
    (set! (-> gp-0 trans quad) (-> arg0 extra trans quad))
    (quaternion-copy! (the-as quaternion (-> gp-0 rot)) (-> arg0 quat))
    (vector-identity! (-> gp-0 scale))
    (the-as symbol (send-event (view-get-active-camera) 'teleport-to-transformq gp-0))
    )
  )

(defun camera-teleport-to-entity-named ((arg0 string))
  (let ((a0-3 (as-type (entity-by-name arg0) entity-actor)))
    (if a0-3
        (camera-teleport-to-entity (the-as entity-actor a0-3))
        (format #t "sorry, couldn't find an actor named '~S'~%" arg0)
        )
    )
  0
  )

(defun camera-teleport-to-location ((arg0 float) (arg1 float) (arg2 float))
  (let ((gp-0 (new 'stack-no-clear 'transformq)))
    (set-vector! (-> gp-0 trans) (* 4096.0 arg0) (* 4096.0 arg1) (* 4096.0 arg2) 1.0)
    (quaternion-identity! (the-as quaternion (-> gp-0 rot)))
    (vector-identity! (-> gp-0 scale))
    (send-event (view-get-active-camera) 'teleport-to-transformq gp-0)
    )
  0
  )
