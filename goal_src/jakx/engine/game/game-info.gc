(kmemopen global "game-info-tables")

;; top-level game-info initialization
(let ((gp-0 *game-info*))
  (set! (-> gp-0 task-counter) (the-as uint 1))
  (when (zero? (-> gp-0 perm-list))
    (set! (-> gp-0 perm-list) (new 'global 'entity-perm-array 64))
    (set! (-> gp-0 perm-list length) 0)
    0
    )
  (when (zero? (-> gp-0 play-list))
    (set! (-> gp-0 play-list) (new 'global 'boxed-array game-task-info 936))
    )
  (when (not (-> gp-0 sub-task-list))
    (set! (-> gp-0 sub-task-list) #f)
    )
  (when (zero? (-> gp-0 game-score))
    (set! (-> gp-0 game-score) (new 'global 'boxed-array float 10))
    )
  (dotimes (s5-0 2)
    (when (not (-> gp-0 player-info s5-0 current-continue))
      (game-info-method-17 gp-0 (the-as symbol s5-0))
      )
    (when (not (-> gp-0 player-info s5-0 last-continue))
      (set! (-> gp-0 player-info s5-0 last-continue) (the-as continue-point *default-continue*))
      )
    )
  (set! (-> gp-0 want-auto-save) #f)
  (set! (-> gp-0 auto-save-proc) (the-as uint #f))
  (set! (-> gp-0 task-counter) (the-as uint 1))
  (set! (-> gp-0 total-deaths) 0)
  (set! (-> gp-0 continue-deaths) -1)
  (set! (-> gp-0 demo-state) (the-as uint 0))
  (set! (-> gp-0 pause-menu) (the-as uint #f))
  (set! (-> gp-0 fragile-vehicle) #f)
  (set! (-> gp-0 playing-grand-prix?) (the-as grand-prix #f))
  (set! (-> gp-0 distance) 0.0)
  (set! (-> gp-0 goal) 0.0)
  (set! (-> gp-0 turbo-disabled) (the-as int8 -1))
  (dotimes (v1-47 2)
    (set! (-> gp-0 controller v1-47) (the-as handle #f))
    )
  (dotimes (v1-50 2)
    (set! (-> gp-0 player-info v1-50 vehicle) (the-as handle #f))
    (set! (-> gp-0 player-info v1-50 camera-inside-view) #f)
    )
  )

(kmemclose)
