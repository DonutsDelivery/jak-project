;; definition for method 16 of type game-info
;; WARN: Return type mismatch game-info vs int.
(defmethod game-info-method-16 ((this game-info) (arg0 level))
  (when (or (not arg0) (= arg0 'game-task))
    )
  (when (= arg0 'entity-perm)
    (format #t "~Tentity-perm:~%")
    (let ((s5-0 (-> this perm-list)))
      (dotimes (s4-0 (-> s5-0 length))
        (format #t "~T~T~`entity-perm`P~%" (-> s5-0 data s4-0))
        )
      )
    )
  (the-as int this)
  )

