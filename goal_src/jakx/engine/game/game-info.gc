;; definition for method 28 of type game-info
;; WARN: Return type mismatch float vs (pointer float).
(defmethod game-info-method-28 ((this game-info) (arg0 int))
  (let ((v1-0 0)
        (a0-1 0)
        )
    0.0
    (let ((a1-2 (-> *game-info* sub-task-list)))
      (dotimes (a2-0 (-> a1-2 length))
        (when (nonzero? a2-0)
          (let ((a3-3 (-> a1-2 a2-0)))
            (when (and (-> *game-info* play-list (-> a3-3 task) play-continue)
                       (-> *game-info* play-list (-> a3-3 task) single-player)
                       (>= (-> a3-3 adv-score) 0)
                       )
              (+! v1-0 3)
              (+! a0-1 (-> a3-3 medals 0))
              )
            )
          )
        )
      )
    (dotimes (a1-5 4)
      (+! v1-0 3)
      (+! a0-1 (-> *game-info* grand-prix a1-5 trophy))
      )
    (the-as (pointer float) (/ (* 100.0 (the float a0-1)) (the float v1-0)))
    )
  )

