;; definition for function position->stream
;; WARN: Return type mismatch int vs none.
(defun position->stream ((stream string) (arg1 symbol) (newline? symbol))
  (format
    stream
    "bug-report ~S ~S ~DK "
    *user*
    arg1
    (shr (* (dma-buffer-length (-> *display* frames (-> *display* last-screen) global-buf)) 16) 10)
    )
  (if newline?
      (format stream "~%")
      )
  (let* ((s4-1 format)
         (s3-1 stream)
         (s2-1 "nick ~S continue ~S ")
         (v1-9 (lookup-level-info (-> *load-state* vis-nick)))
         (a2-2 (if v1-9
                   (-> v1-9 name)
                   )
               )
         (v1-11 (-> *game-info* player-info 0 current-continue))
         )
    (s4-1 s3-1 s2-1 a2-2 (if v1-11
                             (-> v1-11 name)
                             )
          )
    )
  (if newline?
      (format stream "~%")
      )
  (dotimes (s4-2 6)
    (if (or (= (-> *level* level s4-2 status) 'active)
            (= (-> *level* level s4-2 status) 'alive)
            (= (-> *level* level s4-2 status) 'loaded)
            )
        (format stream "level ~D ~-8A ~-8A " s4-2 (-> *level* level s4-2 name) (-> *level* level s4-2 display?))
        (format stream "level ~D ~-8A ~-8A " s4-2 #f #f)
        )
    (if newline?
        (format stream "~%")
        )
    )
  (let ((s4-3 6)
        (s3-2 17)
        )
    (while (>= s3-2 s4-3)
      (if (or (= (-> *level* level s4-3 status) 'active)
              (= (-> *level* level s4-3 status) 'alive)
              (= (-> *level* level s4-3 status) 'loaded)
              )
          (format stream "~-8A" (-> *level* level s4-3 name))
          (format stream "~-8A" #f)
          )
      (if (and (zero? (+ s4-3 -6 -5)) newline?)
          (format stream "~%")
          )
      (+! s4-3 1)
      )
    )
  (format stream "~%")
  (format stream "music ~-8S~%sound " (-> *setting-control* user-current music))
  (format stream "~-8S~%" (-> *level* sound-bank 0 str-name))
  (dotimes (s4-4 6)
    (format stream "~-8S " (-> *level* sound-bank (+ s4-4 1) str-name))
    )
  (if newline?
      (format stream "~%")
      )
  (let ((v1-63 (target-pos 0)))
    (format stream "target ~m ~m ~m " (-> v1-63 x) (-> v1-63 y) (-> v1-63 z))
    )
  (if newline?
      (format stream "~%")
      )
  (let ((v1-67 (math-camera-pos)))
    (format stream "camera-trans ~m ~m ~m " (-> v1-67 x) (-> v1-67 y) (-> v1-67 z))
    )
  (if newline?
      (format stream "~%")
      )
  (let* ((a1-20 (math-camera-matrix))
         (v1-71 (matrix->quaternion (new 'stack-no-clear 'quaternion) a1-20))
         )
    (format stream "camera-rot ~f ~f ~f ~f" (-> v1-71 x) (-> v1-71 y) (-> v1-71 z) (-> v1-71 w))
    )
  (format stream "~%")
  0
  (none)
  )

