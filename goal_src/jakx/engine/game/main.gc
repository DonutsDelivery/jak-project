(define *screen-filter-array* (new 'static 'boxed-array :type screen-filter
                                (new 'static 'screen-filter :draw? #f :bucket #x31b)
                                (new 'static 'screen-filter :draw? #f :bucket #x31b :idx 1)
                                (new 'static 'screen-filter :draw? #f :bucket #x31b :idx 2)
                                )
        )

(define *screen-filter* (-> *screen-filter-array* 2))

(defmethod draw ((this screen-filter))
  "Add DMA data to our bucket to draw the filter."
  (local-vars (v1-1 float))
  (rlet ((vf0 :class vf)
         (vf1 :class vf)
         (vf2 :class vf)
         (vf3 :class vf)
         (vf4 :class vf)
         )
    (init-vf0-vector)
    (when (not (paused?))
      (.lvf vf4 (&-> this extra quad))
      (.lvf vf1 (&-> this color-dest quad))
      (.lvf vf2 (&-> this color quad))
      (.sub.vf vf3 vf1 vf2)
      (.add.x.vf.y vf4 vf4 vf4)
      (.min.w.vf.y vf4 vf4 vf0)
      (.max.y.vf.y vf4 vf4 vf0)
      (.mul.y.vf vf3 vf3 vf4)
      (.add.vf vf1 vf2 vf3)
      (.svf (&-> this extra quad) vf4)
      (.svf (&-> this color quad) vf1)
      (.mov v1-1 vf1)
      )
    (when (nonzero? (-> this frames))
      (+! (-> this frames) -1)
      (when (<= (-> this frames) 0)
        (disable this)
        (return 0)
        )
      )
    (let ((f0-0 0.1))
      (when (and (>= f0-0 (fabs (- (-> this color-dest x) (-> this color x))))
                 (>= f0-0 (fabs (- (-> this color-dest y) (-> this color y))))
                 (>= f0-0 (fabs (- (-> this color-dest z) (-> this color z))))
                 (>= f0-0 (fabs (- (-> this color-dest w) (-> this color w))))
                 (>= f0-0 (-> this color w))
                 )
        (disable this)
        (return 0)
        )
      )
    (with-dma-buffer-add-bucket ((s4-0 (-> *display* frames (-> *display* on-screen) global-buf))
                                 (the-as bucket-id (-> this bucket))
                                 )
      (let ((v1-29 (-> *viewport-array* data (-> this idx))))
        (dma-buffer-add-gs-set s4-0
                               (test-1 (-> this ztest))
                               (frame-1 (-> v1-29 frame))
                               (zbuf-1 (-> v1-29 zbuf-on))
                               (scissor-1 (-> v1-29 scissor))
                               )
        )
      (let ((t1-0
              (logior (logior (logior (shr (shl (the int (-> this color w)) 56) 32) (shr (shl (the int (-> this color z)) 56) 40))
                              (shr (shl (the int (-> this color y)) 56) 48)
                              )
                      (shr (shl (the int (-> this color x)) 56) 56)
                      )
              )
            )
        (draw-sprite2d-xy
          s4-0
          -256
          (- (-> *viewport-array* default screen-hy))
          512
          (-> *viewport-array* default screen-sy)
          (the-as rgba t1-0)
          (-> this depth)
          )
        )
      (let ((v1-43 (-> *viewport-array* default)))
        (dma-buffer-add-gs-set s4-0
                               (test-1 (-> this ztest))
                               (frame-1 (-> v1-43 frame))
                               (zbuf-1 (-> v1-43 zbuf-on))
                               (scissor-1 (-> v1-43 scissor))
                               )
        )
      )
    0
    )
  )

(defmethod setup ((this screen-filter)
                                   (arg0 vector)
                                   (arg1 vector)
                                   (arg2 float)
                                   (arg3 bucket-id)
                                   (arg4 int)
                                   (arg5 int)
                                   (arg6 symbol)
                                   )
  (set! (-> this draw?) #t)
  (set! (-> this color quad) (-> arg0 quad))
  (set! (-> this color-src quad) (-> arg0 quad))
  (set! (-> this color-dest quad) (-> arg1 quad))
  (set! (-> this extra x) arg2)
  (set! (-> this extra y) 0.0)
  (set! (-> this bucket) (the-as int arg3))
  (set! (-> this depth) arg4)
  (set! (-> this ztest) (the-as uint arg5))
  (set! (-> this lock-vsync?) #f)
  (set! (-> this frames) (the-as int arg6))
  0
  )

(defmethod disable ((this screen-filter))
  (set! (-> this draw?) #f)
  0
  )

