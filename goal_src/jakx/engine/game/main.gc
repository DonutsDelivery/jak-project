;;-*-Lisp-*-
(in-package goal)

;; Ported from jak3 — minimal display loop for jakx early bringup.
;; jak3 version: goal_src/jak3/engine/game/main.gc:1645

;; This stripped display-loop:
;;   - skips the math-engine "matrix" subprocess (actors/joints not driven yet)
;;   - skips display-loop-main (level loading, camera updates, AI, etc.)
;;   - just runs display-sync + display-frame-finish each tick so GOAL
;;     submits DMA chains to the C renderer every frame
;;
;; The stub `on` in jakx-stubs.gc is overridden here (load order puts main.o
;; after jakx-stubs.o in game.gd).

;; *dproc* and *run* are declared in main-h.gc. We set *run* so our loop runs.
(set! *run* #t)

(defun paused? ()
  "Are we paused? Counts any type of pause/menu/freeze. Ported from jak3 main.gc:122."
  (or (= *master-mode* 'pause) (= *master-mode* 'progress) (= *master-mode* 'menu) (= *master-mode* 'freeze))
  )

(defun movie? ()
  "Are we in a movie? Ported from jak3 main.gc:127."
  (logtest? (-> *kernel-context* prevent-from-run) (process-mask movie))
  )

(defbehavior display-loop process ()
  "Display loop — progressively matching jak3's full version (main.gc:1645).
   Currently adds: update *setting-control*, update *pc-settings* in main loop.
   Still skipped vs jak3: matrix-engine process, time-of-day-context init,
   actor-hash, collide-rider-pool prep, blerc-init, vblank-handler install,
   display-loop-main body. Re-enable as their dependencies settle."
  (stack-size-set! (-> self main-thread) 512)

  (let ((disp *display*))
    (set! *teleport* #t)

    ;; og:preserve-this — now safe: subagent fixed target-pos, entity-by-name,
    ;; and add-blackout (all were declared extern with no impl). Verified the
    ;; full update method runs clean end-to-end.
    (update *setting-control*)


    (set! (-> disp frames 0 start-time)
          (timer-count (the-as timer-bank #x10000800)))
    (set! (-> disp frames 1 start-time)
          (timer-count (the-as timer-bank #x10000800)))
    (set! (-> disp dog-ratio) 1.0)

    ;; warmup: first display-sync runs display-frame-start which sets up
    ;; the bucket chain on the on-screen frame.
    (display-sync disp)

    (while *run*
      (set! *artist-all-visible* #t)
      (set! *external-cam-mode* 'locked)
      (set-vector! (-> *math-camera* trans) -67563.0 900000.0 -299048.0 1.0)
      (set-vector! (-> *save-camera-inv-rot* rvec) 1.0 0.0 0.0 0.0)
      (set-vector! (-> *save-camera-inv-rot* uvec) 0.0 0.0 1.0 0.0)
      (set-vector! (-> *save-camera-inv-rot* fvec) 0.0 -1.0 0.0 0.0)
      ;; og:preserve-this — tell C++ loader which levels to load each frame.
      ;; level-update calls __pc-set-levels internally but is too heavy to call here.
      (#when PC_PORT
        (let ((lev-names (new 'stack-no-clear 'array 'string 10)))
          (dotimes (i 10) (set! (-> lev-names i) "none"))
          (dotimes (i (-> *level* length))
            (let ((lev (-> *level* level i)))
              (when (or (= (-> lev status) 'active) (= (-> lev status) 'alive) (= (-> lev status) 'loaded) (= (-> lev status) 'loading))
                (set! (-> lev-names i) (symbol->string (level-method-13 lev))))))
          (__pc-set-levels lev-names)))
      (update-camera)
      ;; Seed non-zero mood times on active levels so background DMA packets
      ;; get non-zero itimes (otherwise all geometry renders black).
      ;; update-time-of-day→init-weather! gates on level-get-target-inside
      ;; which returns #f without a target process, so we bypass it here.
      (dotimes (i (-> *level* length))
        (let ((lev (-> *level* level i)))
          (when (= (-> lev status) 'active)
            (set! (-> lev mood-context times 0 x) 1.0)
            (set! (-> lev mood-context times 0 y) 1.0)
            (set! (-> lev mood-context times 0 z) 1.0)
            (set! (-> lev mood-context times 0 w) 1.0)
            (update-mood-itimes (-> lev mood-context)))))
      (*draw-hook*)
      (display-frame-finish disp)
      ;; og:preserve-this — load common.TXT into *common-text*. Ported from jak3
      ;; main.gc:1519 (display-loop-main). Guarded by *level-text-file-load-flag*
      ;; internally — one-shot on first call, then the flag clears.
      ;; Without this, title-menu's (while (not *common-text*) (suspend)) loops
      ;; forever and the title menu never draws.
      (load-level-text-files -1)
      (display-sync disp)
      (suspend)
      ;; og:preserve-this — PC port per-frame hook deferred: (update *setting-control*)
      ;; crashes at boot with *pc-settings* active too. Isolating one at a time.
      ;; (#when PC_PORT (update *pc-settings*))
      )
    )

  (set! *dproc* #f)
  (format 0 "display is off #<#x~X>.~%" self)
  0
  )

(defun on ((arg0 symbol))
  "Start the display process. Spawned once from play-boot or similar."
  (when (not *dproc*)
    (set! *run* #t)
    (set! *dproc* (ppointer->process (process-spawn-function
                                       process
                                       display-loop
                                       :name "display"
                                       :from *4k-dead-pool*
                                       :to *display-pool*
                                       :stack *kernel-dram-stack*
                                       )))
    )
  *dproc*
  )

;; WARN: Return type mismatch time-frame vs none.
(defun set-letterbox-frames ((arg0 time-frame))
  "Enable letterbox for the given amount of time."
  (with-pp
    (set! (-> *game-info* letterbox-time)
          (the-as
            uint
            (+ (-> *display* base-clock frame-counter)
               (the int (/ (* (the float arg0) (-> *display* game-clock clock-ratio)) (-> pp clock clock-ratio)))
               )
            )
          )
    (none)
    )
  )

;; ERROR: Failed store: (s.w! (+ v1-14 8) 0) at op 54
;; ERROR: Failed store: (s.w! (+ v1-14 12) 0) at op 55
(defun letterbox ((arg0 bucket-id) (arg1 float))
  "Draw letterbox"
  (let* ((s2-0 (-> *viewport-array* default screen-sy))
         (s4-0 (-> *display* frames (-> *display* on-screen) global-buf))
         (s5-0 (-> s4-0 base))
         )
    (draw-sprite2d-xy-absolute s4-0 0 0 512 (the int (* 46.0 arg1)) (new 'static 'rgba :a #x80) #x3fffff)
    (draw-sprite2d-xy-absolute
      s4-0
      0
      (- s2-0 (the int (* 46.0 arg1)))
      512
      (+ (the int (* 46.0 arg1)) 1)
      (new 'static 'rgba :a #x80)
      #x3fffff
      )
    (let ((a3-2 (-> s4-0 base)))
      (when (!= s5-0 a3-2)
        (let ((v1-14 (-> s4-0 base)))
          (set! (-> (the-as (pointer int64) v1-14)) #x20000000)
          (s.w! (+ v1-14 8) 0)
          (s.w! (+ v1-14 12) 0)
          (set! (-> s4-0 base) (&+ v1-14 16))
          )
        (dma-bucket-insert-tag
          (-> *display* frames (-> *display* on-screen) bucket-group)
          arg0
          s5-0
          (the-as (pointer dma-tag) a3-2)
          )
        )
      )
    )
  0
  (none)
  )

(defun set-blackout-frames ((arg0 time-frame))
  "Enable blackout for the given amount of time."
  (with-pp
    (if (zero? arg0)
        (set! (-> *game-info* blackout-time) (the-as uint (-> *display* base-clock frame-counter)))
        (set! (-> *game-info* blackout-time)
              (the-as
                uint
                (max
                  (the-as int (-> *game-info* blackout-time))
                  (+ (-> *display* base-clock frame-counter)
                     (the int (/ (* (the float arg0) (-> *display* game-clock clock-ratio)) (-> pp clock clock-ratio)))
                     arg0
                     )
                  )
                )
              )
        )
    (none)
    )
  )

(defun blackout ((arg0 bucket-id))
  "Draw blackout as a sprite."
  (with-dma-buffer-add-bucket ((s4-0 (-> *display* frames (-> *display* on-screen) global-buf))
                               arg0
                               )
    (draw-sprite2d-xy-absolute
      s4-0
      0
      0
      512
      (-> *viewport-array* default screen-sy)
      (new 'static 'rgba :a #x80)
      #x3fffff
      )
    )
  0
  (none)
  )

