(deftype disc-error-proc (process-drawable)
  ((error  basic)
   (bmask  uint32)
   )
  (:states disc-idle)
  )

(defstate disc-idle (disc-error-proc)
  :enter (behavior () (none)) ;; SCAFFOLDING: L115 not decompiled
  :exit (behavior () (sound-group-continue (the-as sound-group #xffffffff)) (none))
  :trans (behavior () (buzz-stop! 0) (buzz-stop! 1) (none))
  :code sleep-code
  )

;; ERROR: function has no type analysis. Cannot decompile.

;; ERROR: function was not converted to expressions. Cannot decompile.

(defun on ((arg0 symbol))
  "Start the display process."
  (when (not *dproc*)
    (when (not arg0)
      (if (= (-> *level* level0 status) 'inactive)
          (bg 'halfpipe)
          )
      )
    (set! *run* #t)
    (set! *dproc* (ppointer->process (process-spawn-function
                                       process
                                       display-loop
                                       :name "display"
                                       :from *4k-dead-pool*
                                       :to *display-pool*
                                       :stack *kernel-dram-stack*
                                       )
                                     )
          )
    (cond
      ((or (level-group-method-10 *level* 'loaded)
           (level-group-method-10 *level* 'alive)
           (level-group-method-10 *level* 'active)
           )
       (activate-levels! *level*)
       (when (not arg0)
         (let ((gp-1 (entity-by-type camera-start)))
           (when (and gp-1 (type? gp-1 entity-actor))
             (while (not (camera-teleport-to-entity gp-1))
               (suspend)
               )
             )
           )
         )
       (if (and (= *kernel-boot-message* 'art-group) *kernel-boot-art-group*)
           (anim-tester-add-object *kernel-boot-art-group*)
           )
       )
      (else
        ;; 2026-05-03 cycle diag: lifting this kill ran display-loop into
        ;; (update *setting-control*) → segfault 0x2123000000, then with that
        ;; skipped → FPE in update-camera → camera/setting-control init cascade.
        ;; Conclusion: display-loop can't run without a loaded level driving
        ;; setting-control + camera state. Original kill restored — wait for
        ;; bg / level-get-for-use port before re-trying.
        (kill-by-name "display" *active-pool*)
        (set! *dproc* #f)
        )
      )
    )
  *dproc*
  )

(defun off ()
  "Stop the display process."
  (let ((t9-0 stop)
        (a0-0 'debug)
        )
    0
    (t9-0 a0-0)
    )
  (dotimes (gp-0 (-> *level* length))
    (let ((a0-2 (-> *level* level gp-0)))
      (if (= (-> a0-2 status) 'active)
          (deactivate a0-2)
          )
      )
    )
  (set! *run* #f)
  0
  (none)
  )
