(defun add-blackout ((a0-0 time-frame) (a1-0 int) (a2-0 int) (a3-0 int) (t0-0 int))
  "Update display settings to do blackout with GS pmode alp."
  (local-vars
    (v0-0 int)
    (v1-0 display)
    (a0-1 none)
    (a0-2 uint)
    (a1-1 int)
    (a1-2 int)
    (a1-3 gs-bgcolor)
    (a1-4 gs-bgcolor)
    (a1-5 gs-bgcolor)
    (a1-6 gs-bgcolor)
    (a1-7 gs-bgcolor)
    (a1-8 gs-bgcolor)
    (a1-9 gs-bgcolor)
    (a1-10 gs-pmode)
    (a1-11 gs-pmode)
    (a1-12 gs-pmode)
    (a2-1 int)
    (a2-2 int)
    (a2-3 int)
    (a2-4 int)
    (a2-5 int)
    (a2-6 int)
    (a2-7 int)
    (a2-8 int)
    (a2-9 int)
    (a2-10 int)
    (a2-12 int)
    (a2-13 int)
    (t1-0 gs-bgcolor)
    (t1-1 gs-bgcolor)
    (t1-2 int)
    (t2-0 int)
    )
  (when (begin
          (set! v1-0 *display*)
          (set! a0-1 (the-as none L564))
          (set! t1-0 (-> v1-0 bgcolor))
          (set! t2-0 -256)
          (set! t1-1 (logand t1-0 t2-0))
          (set! a1-1 (sll a1-0 56))
          (set! a1-2 (srl a1-1 56))
          (set! a1-3 (logior t1-1 a1-2))
          (set! (-> v1-0 bgcolor) a1-3)
          (set! a1-4 (-> v1-0 bgcolor))
          (set! t1-2 -65281)
          (set! a1-5 (logand a1-4 t1-2))
          (set! a2-1 (sll a2-0 56))
          (set! a2-2 (srl a2-1 48))
          (set! a1-6 (logior a1-5 a2-2))
          (set! (-> v1-0 bgcolor) a1-6)
          (set! a1-7 (-> v1-0 bgcolor))
          (set! a2-3 -16711681)
          (set! a1-8 (logand a1-7 a2-3))
          (set! a2-4 (sll a3-0 56))
          (set! a2-5 (srl a2-4 40))
          (set! a1-9 (logior a1-8 a2-5))
          (set! (-> v1-0 bgcolor) a1-9)
          (set! a1-10 (-> v1-0 pmode))
          (set! a2-6 -65281)
          (set! a1-11 (logand a1-10 a2-6))
          (set! a2-7 255)
          (set! a2-8 (- a2-7 t0-0))
          (set! a2-9 (sll a2-8 56))
          (set! a2-10 (srl a2-9 48))
          (set! a1-12 (logior a1-11 a2-10))
          (set! (-> v1-0 pmode) a1-12)
          (s.d! a0-1 0)
          (s.d! (+ a0-1 8) 0)
          (nonzero? t0-0)
          )
    (set! a2-12 4)
    (set! a0-2 (-> v1-0 force-sync))
    (set! a2-13 (max.si a2-12 a0-2))
    (set! (-> v1-0 force-sync) (the-as uint a2-13))
    )
  (set! v0-0 0)
  (ret-value v0-0)
  )

(defun paused? ()
  "Are we paused? Counts any type of pause/menu/freeze."
  (or (= *master-mode* 'pause) (= *master-mode* 'progress) (= *master-mode* 'menu) (= *master-mode* 'freeze))
  )

(defun movie? ()
  "Are we in a movie?"
  (logtest? (-> *kernel-context* prevent-from-run) (process-mask movie))
  )

(defun scene-select? ()
  (and (>= (-> *game-info* demo-state) (the-as uint 100)) (< (-> *game-info* demo-state) (the-as uint 200)))
  )

(defun demo? ()
  "Is this a demo version?"
  (or (= *kernel-boot-message* 'demo) (= *kernel-boot-message* 'demo-shared))
  )

(defun kiosk? ()
  "Is this a kiosk version of the game?"
  (= *kernel-boot-message* 'kiosk)
  )

(defun beta? ()
  "Is this a beta version?"
  (= *kernel-boot-message* 'beta)
  )

