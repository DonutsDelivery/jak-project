(deftype fact-info-enemy (fact-info)
  ((speed             float)
   (idle-distance     meters)
   (notice-top        meters)
   (notice-bottom     meters)
   (cam-horz          meters)
   (cam-vert          meters)
   (cam-notice-dist   meters)
   (enemy-options     uint32)
   (trig-dist         meters)
   (trig-actor-group  uint32)
   (trig-mask-count   int8)
   (trig-mask         uint8  2)
   )
  (:methods
    (new (symbol type) _type_)
    (fact-info-enemy-method-12 (_type_ int) none)
    )
  )

;; ERROR: failed type prop at 19: Could not figure out load: (set! s2 (l.w (+ gp 4)))

(deftype fact-info-crate (fact-info)
  ((suck-count  int32)
   )
  (:methods
    (new (symbol type) _type_)
    )
  )

