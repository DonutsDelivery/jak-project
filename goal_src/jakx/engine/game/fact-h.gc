(deftype fact-info (basic)
  ((process              process)
   (pickup-amount        float   :offset  12)
   (pickup-spawn-amount  float   :offset  16)
   (options              uint32  :offset  24)
   (fade-time            uint64  :offset  32)
   )
  (:methods
    (new (symbol type) _type_)
    (fact-info-method-9 () none)
    (fact-info-method-10 () none)
    (fact-info-method-11 () int)
    )
  )

