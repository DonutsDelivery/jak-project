(defun rings-water-spawn ((arg0 float) (arg1 vector) (arg2 vector) (arg3 float) (arg4 float))
  (let* ((v1-0 arg2)
         (f30-0 (sqrtf (+ (* (-> v1-0 x) (-> v1-0 x)) (* (-> v1-0 z) (-> v1-0 z)))))
         )
    (set! (-> *part-id-table* 139 init-specs 4 initial-valuef) (+ 24576.0 arg0))
    (set! (-> *part-id-table* 139 init-specs 19 initial-valuef) (+ 49152.0 arg0))
    (set! (-> *part-id-table* 139 init-specs 1 initial-valuef) (* 0.0000036621095 f30-0))
    (set! (-> *part-id-table* 139 init-specs 2 initial-valuef) (/ f30-0 10))
    (set! (-> *part-id-table* 139 init-specs 13 initial-valuef) 0.7111111)
    (set! (-> *part-id-table* 139 init-specs 3 initial-valuef) arg3)
    (set! (-> *part-id-table* 139 init-specs 5 initial-valuef) arg3)
    (launch-particles :system *sp-particle-system-3d* (-> *part-id-table* 139) arg1)
    (set! (-> *part-id-table* 142 init-specs 1 initial-valuef) (* 0.000004150391 f30-0))
    (set! (-> *part-id-table* 142 init-specs 16 initial-valuef) arg0)
    (launch-particles :system *sp-particle-system-3d* (-> *part-id-table* 142) arg1)
    (when (< f30-0 4096.0)
      (set! (-> *part-id-table* 138 init-specs 2 random-rangef) arg4)
      (launch-particles :system *sp-particle-system-3d* (-> *part-id-table* 138) arg1)
      )
    )
  0
  )

