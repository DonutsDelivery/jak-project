;; DECOMP BEGINS

(defun check-water-level-drop ((arg0 sparticle-system) (arg1 sparticle-cpuinfo) (arg2 vector))
  (when (and (< (-> arg2 y) (the-as float (-> arg1 user-uint32))) (< (-> arg1 vel-sxvel y) 0.0))
    (let ((s4-0 (new 'stack-no-clear 'vector)))
      (sp-kill-particle arg0 arg1)
      (set-vector! s4-0 (-> arg2 x) (the-as float (-> arg1 user-uint32)) (-> arg2 z) 1.0)
      (launch-particles :system *sp-particle-system-3d* (-> *part-id-table* 160) s4-0)
      )
    )
  0
  (none)
  )

;; WARN: Return type mismatch symbol vs none.
(defun check-water-level-drop-and-die ((arg0 sparticle-system) (arg1 sparticle-cpuinfo) (arg2 vector))
  (if (and (< (-> arg2 y) (the-as float (-> arg1 user-uint32))) (< (-> arg1 vel-sxvel y) 0.0))
      (sp-kill-particle arg0 arg1)
      )
  #f
  )

(defun check-water-level-drop-and-die-motion ((arg0 sparticle-system) (arg1 sparticle-cpuinfo) (arg2 vector))
  (if (and (< (-> arg2 y) (the-as float (-> arg1 user-uint32))) (< (-> arg1 vel-sxvel y) 0.0))
      (sp-kill-particle arg0 arg1)
      )
  ((the-as (function sparticle-system sparticle-cpuinfo vector none) sparticle-motion-blur) arg0 arg1 arg2)
  (none)
  )

;; WARN: Return type mismatch symbol vs none.
(defun check-water-level-above-and-die ((arg0 sparticle-system) (arg1 sparticle-cpuinfo) (arg2 vector))
  (if (>= (-> arg2 y) (the-as float (-> arg1 user-uint32)))
      (sp-kill-particle arg0 arg1)
      )
  (none)
  )

(defun check-water-level-drop-motion ((arg0 sparticle-system) (arg1 sparticle-cpuinfo) (arg2 vector))
  (when (and (< (-> arg2 y) (the-as float (-> arg1 user-uint32))) (< (-> arg1 vel-sxvel y) 0.0))
    (let ((s3-0 (new 'stack-no-clear 'vector)))
      (sp-kill-particle arg0 arg1)
      (set-vector! s3-0 (-> arg2 x) (the-as float (-> arg1 user-uint32)) (-> arg2 z) 1.0)
      (launch-particles :system *sp-particle-system-3d* (-> *part-id-table* 160) s3-0)
      (set! (-> *part-id-table* 161 init-specs 15 initial-valuef) (-> s3-0 y))
      (launch-particles (-> *part-id-table* 161) s3-0)
      )
    )
  ((the-as (function sparticle-system sparticle-cpuinfo vector none) sparticle-motion-blur) arg0 arg1 arg2)
  (none)
  )

(when (or (zero? *water-simple-alpha-curve-in*) (!= loading-level global))
