                                  :one-over-x-deltas (new 'static 'vector :data (new 'static 'array float 4 1.0 1.0 1.0 1.0))
                                  )
        )

(define *curve-wsplash-alpha*
  (new 'static 'curve2d-fast
    :xs (new 'static 'vector :data (new 'static 'array float 4 0.0 -0.1 -1.0 -2.0))
