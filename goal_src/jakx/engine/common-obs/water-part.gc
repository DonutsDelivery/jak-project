                                  :one-over-x-deltas (new 'static 'vector :data (new 'static 'array float 4 1.0 1.0 1.0 1.0))
                                  )
        )

(define *curve-wsplash-scale-y*
  (new 'static 'curve2d-fast
    :xs (new 'static 'vector :data (new 'static 'array float 4 0.0 -0.4 -0.7 -1.0))
    :ys (new 'static 'vector :data (new 'static 'array float 4 0.0 2.0 0.5 0.0))
    :one-over-x-deltas (new 'static 'vector :data (new 'static 'array float 4 5.0 -5.0000005 -1.6666666 1.0))
    )
  )

(define *part-water-splash-curve-settings*
  (new 'static 'particle-curve-settings :lifetime-base #x11d :lifetime-offset #x1e)
