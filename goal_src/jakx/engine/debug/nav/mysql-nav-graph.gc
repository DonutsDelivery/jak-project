    (mysql-nav-graph-method-20 (_type_) none)
    (mysql-nav-graph-method-21 (_type_) none)
    (mysql-nav-graph-method-22 (_type_) none)
    (mysql-nav-graph-method-23 (_type_) none)
    )
  )

