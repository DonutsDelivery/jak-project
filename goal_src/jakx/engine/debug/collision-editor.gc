(deftype collision-editor-edited-proc (process-drawable)
  ()
  (:state-methods
    idle
    )
  )


(defstate idle (collision-editor-edited-proc)
  :virtual #t
  :code sleep-code
  :post (behavior ()
    (transform-post)
    )
  )

