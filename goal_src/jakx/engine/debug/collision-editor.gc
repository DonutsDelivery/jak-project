(deftype collision-editor-default-proc (process-drawable)
  ()
  (:state-methods
    idle
    )
  )


(defstate idle (collision-editor-default-proc)
  :virtual #t
  :trans (behavior ()
    (deactivate self)
    )
  :code sleep-code
  )

