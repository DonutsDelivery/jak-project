    (when (begin
            (set! t9-35 (the-as none flush-cache))
            (set! a0-122 (the-as none 0))
            (call!)
            (set! t9-36 (the-as none paused?))
            (set! v0-36 (the-as none (call!)))
            (not v0-36)
            )
      (when (begin (set! v1-253 (the-as none *stats-buffer*)) v1-253)
        (set! a0-123 (the-as none (l.wu (+ s4-0 36))))
        (set! v1-255 (the-as none (l.wu (+ s5-0 4))))
        (set! a2-43 (the-as none (+ s5-0 28)))
        (set! s4-1 (the-as none (l.wu (+ a0-123 4))))
        (set! s5-1 (the-as none (+ a0-123 28)))
        (set! s3-10 (the-as none (l.wu (+ a0-123 8))))
        (set! t9-37 (the-as none format))
        (set! a0-124 (the-as none *stdcon*))
        (set! a1-69 (the-as none L365))
        (set! a2-44 (the-as none (- v1-255 a2-43)))
        (call!)
        (set! t9-38 (the-as none format))
        (set! a0-125 (the-as none *stdcon*))
        (set! a1-70 (the-as none L364))
        (set! a2-45 (the-as none (- s4-1 s5-1)))
        (call!)
        (set! t9-39 (the-as none format))
        (set! a0-126 (the-as none *stdcon*))
        (set! a1-71 (the-as none L363))
        (set! a2-46 (the-as none s4-1))
        (call!)
        (set! t9-40 (the-as none format))
        (set! a0-127 (the-as none *stdcon*))
        (set! a1-72 (the-as none L362))
        (set! a2-47 (the-as none s3-10))
        (call!)
        (set! v1-256 (the-as none v0-40))
        )
      )
    (set! v1-257 (the-as none *setting-control*))
    (set! v1-258 (the-as none (l.wu (+ v1-257 68))))
    (set! a0-128 (the-as none *video-params*))
    (s.w! (+ a0-128 48) v1-258)
    (set! v0-41 (the-as none a0-0))
    (ret-value v0-41)
    )
  )

;; WARN: disable def twice: 62. This may happen when a cond (no else) is nested inside of another conditional, but it should be rare.
(defun determine-pause-mode ()
  (when (and (not *progress-process*)
             (or (!= *master-mode* 'freeze) (and *debug-segment*
                                                 (logtest? (-> *cpad-list* cpads 0 button0-rel 0) 9)
                                                 (logtest? (-> *cpad-list* cpads 0 button0-abs 0) 2)
                                                 )
                 )
             )
    (if (or (and (!= *master-mode* 'progress)
                 (or (logtest? (-> *cpad-list* cpads 0 button0-rel 0) 8) (logtest? (-> *cpad-list* cpads 1 button0-rel 0) 8))
                 )
            (and *debug-segment* (logtest? (-> *cpad-list* cpads 0 button0-rel 0) 1))
            (let ((v1-26 (cond
                           ((= *master-mode* 'menu)
                            (or (logtest? (-> *cpad-list* cpads 0 button0-rel 0) #x3204)
                                (logtest? (-> *cpad-list* cpads 1 button0-rel 0) #x3204)
                                )
                            )
                           ((= *master-mode* 'progress)
                            #f
                            )
                           (*cam-layout*
                             #f
                             )
                           (else
                             #f
                             )
                           )
                         )
                  )
              v1-26
              )
            (or (and (logtest? (-> *cpad-list* cpads 0 valid) 128)
                     (-> *setting-control* user-current allow-in-game-menu)
                     (>= (-> *display* base-clock frame-counter) (the-as time-frame (-> *game-info* blackout-time)))
                     (= (-> *setting-control* user-current bg-a) 0.0)
                     (and (= (-> *setting-control* user-current bg-a-force) 0.0)
                          (< (seconds 1003) (-> *display* real-clock frame-counter))
                          )
                     )
                (and (logtest? (-> *cpad-list* cpads 0 button0-rel 0) 512)
                     (or (= *master-mode* 'pause) (= *master-mode* 'menu))
                     )
                *pause-lock*
                )
            )
        (toggle-pause)
        )
    )
  (when (and *progress-process* (!= *master-mode* 'progress))
    )
  0
  (none)
  )

(defun calc-ratio ((arg0 int) (arg1 int))
  (let ((f0-1 (the float (sar (- arg0 arg1) 48))))
    (if (< f0-1 0.0)
        (set! f0-1 (+ 65536.0 f0-1))
        )
    (/ f0-1 (the float *ticks-per-frame*))
    )
  )

(defun display-sync ((arg0 display))
  (if (not (-> *setting-control* user-current mpeg-mode?))
      (sync-path 0 0)
      )
  (let* ((s4-0 (-> arg0 last-screen))
         (s2-0 (shl (timer-count (the-as timer-bank #x10000800)) 48))
         (s5-0 (shl (-> arg0 frames s4-0 start-time) 48))
         (a1-1 (shl (-> arg0 vblank-start-time 0) 48))
         (s1-0 (shl (-> arg0 vblank-start-time 1) 48))
         )
    (set! *ticks-per-frame* (max 9000 (min #x2ee0 (sar (- s1-0 a1-1) 48))))
    (let ((f28-0 (the float *ticks-per-frame*))
          (s3-0 (sar (- s2-0 s5-0) 48))
          (f30-1 (fmax 1.0 (calc-ratio (the-as int s2-0) (the-as int s5-0))))
          )
      (/ (the float (sar (- s2-0 (the-as uint s1-0)) 48)) f28-0)
      (let ((f28-1 (/ (the float (sar (- s2-0 (the-as uint s1-0)) 48)) f28-0))
            (f26-0 (fmax 1.0 (fmin 4.0 (-> *display* dog-ratio))))
            )
        (if (< (the-as int s3-0) 0)
            (set! s3-0 (+ #x10000 s3-0))
            )
        (set! (-> arg0 frames s4-0 run-time) s3-0)
        (if (not (-> *setting-control* user-current mpeg-mode?))
            (set! f30-1 (cond
                          ((-> arg0 run-half-speed)
                           (syncv 0)
                           (let ((a0-8 (shl (timer-count (the-as timer-bank #x10000800)) 48)))
                             (when (and (< (calc-ratio (the-as int a0-8) (the-as int s5-0)) 2.0) (< f28-1 0.9))
                               (if (not (-> *setting-control* user-current mpeg-mode?))
                                   (syncv 0)
                                   )
                               )
                             )
                           2.0
                           )
                          ((< 1.0 f30-1)
                           (when (> (-> arg0 force-sync) 0)
                             (syncv 0)
                             (+! (-> arg0 force-sync) -1)
                             (let ((a0-12 (shl (timer-count (the-as timer-bank #x10000800)) 48)))
                               (set! f30-1 (calc-ratio (the-as int a0-12) (the-as int s5-0)))
                               )
                             )
                           f30-1
                           )
                          ((and (= f30-1 1.0) (< f30-1 f26-0))
                           (while (< f30-1 f26-0)
                             (let ((a0-14 (shl (timer-count (the-as timer-bank #x10000800)) 48)))
                               (set! f30-1 (calc-ratio (the-as int a0-14) (the-as int s5-0)))
                               )
                             (if (< f30-1 0.0)
                                 (set! f30-1 f26-0)
                                 )
                             )
                           1.0
                           )
                          (else
                            (if (< f28-1 0.9)
                                (syncv 0)
                                )
                            f30-1
                            )
                          )
                  )
            )
        )
      (let ((s4-1 (-> arg0 on-screen)))
        (let ((v1-60 (timer-count (the-as timer-bank #x10000800))))
          (let ((a0-19 (sar (- (shl v1-60 48) s5-0) 48)))
            (if (< (the-as int a0-19) 0)
                (set! a0-19 (+ #x10000 a0-19))
                )
            (+! (-> arg0 total-run-time) a0-19)
            )
          (set! (-> arg0 frames s4-1 start-time) v1-60)
          )
        (when (not (-> *setting-control* user-current mpeg-mode?))
          (set-graphics-mode)
          (let ((s5-1 (-> arg0 frames s4-1 calc-buf)))
            (when (nonzero? (dma-buffer-length s5-1))
              (+! s4-1 1)
              (if (< 1 s4-1)
                  (set! s4-1 0)
                  )
              (set! (-> arg0 last-screen) (-> arg0 on-screen))
              (set! (-> arg0 on-screen) s4-1)
              (when *debug-segment*
                (set! *profile-interrupt-segment* (-> *display* frames (-> *display* last-screen) profile-array data 1))
                (set! (-> *profile-interrupt-segment* depth) 0)
                (set! (-> *profile-interrupt-segment* max-depth) 1)
                )
              (if (not (-> *display* dma-buffer-overflow))
                  (dma-buffer-send-chain (the-as dma-bank-source #x10009000) s5-1)
                  )
              )
            )
          )
        (determine-pause-mode)
        (when (and (nonzero? *screen-shot-work*) (= (-> *screen-shot-work* count) -1) (!= (-> *screen-shot-work* size) -1))
          (let ((v1-95 (-> *screen-shot-work* size)))
            (set! (-> *screen-shot-work* count) (* v1-95 v1-95))
            )
          (set-master-mode 'pause)
          )
        (display-frame-start arg0 s4-1 f30-1)
        )
      )
    )
  (none)
  )
