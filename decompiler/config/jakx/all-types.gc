  )




(deftype driver-info (structure)
  ((skel            basic     :offset-assert 0)
   (turn-back-anim  int8      :offset-assert 4)
   (turn-front-anim int8      :offset-assert 5)
   (up-down-anim    int8      :offset-assert 6)
   (intro-anim uint8 4 :offset-assert 7)
   (head-node       int8      :offset-assert 11)
   (arm0-node       int8      :offset-assert 12)
   (arm1-node       int8      :offset-assert 13)
   (arm0-dist       float     :offset-assert 16)
   (arm1-dist       float     :offset-assert 20)
   )
  :method-count-assert 9
  :size-assert         #x18
  :flag-assert         #x900000018
  )




  




  



(deftype driver (process-focusable)
  (;; GOAL_offset = MIPS_offset + 4 (BasicType::get_offset() correction).
   ;; process-focusable ends at GOAL 256; driver fields start there.
   ;; info-head-node/arm0/arm1-node were already at correct GOAL offsets (263/264/265).
   ;; helmet requires GOAL 16B alignment: first slot ≥ 372 = 384 (accepts GOAL align, MIPS 380).
   (info-skel          basic               :offset 256) ;; MIPS 252
   (info-turn-back     int8                :offset 260) ;; MIPS 256
   (info-turn-front    int8                :offset 261) ;; MIPS 257
   (info-up-down       int8                :offset 262) ;; MIPS 258
   (info-head-node     int8                :offset 263) ;; MIPS 259
   (info-arm0-node     int8                :offset 264) ;; MIPS 260
   (info-arm1-node     int8                :offset 265) ;; MIPS 261
   (info-intro         uint8  4            :offset 266) ;; MIPS 262-265
   (info-arm0-dist     float               :offset 272) ;; MIPS 268
   (info-arm1-dist     float               :offset 276) ;; MIPS 272
   (vehicle            handle              :offset 280) ;; MIPS 276
   (speech-time        uint8       8       :offset 288) ;; uint64 but 4-byte aligned — MIPS 284
   (driver-unk292      uint8       8       :offset 296) ;; MIPS 292
   (anim-vel           uint8       16      :offset 304) ;; vector inline, not 16-byte aligned at 304 — MIPS 300
   (anim-pos           uint8       16      :offset 320) ;; vector inline, not 16-byte aligned at 320 — MIPS 316
   (turn-back-anim     int8                :offset 336) ;; MIPS 332
   (turn-front-anim    int8                :offset 337) ;; MIPS 333
   (up-down-anim       int8                :offset 338) ;; MIPS 334
   (intro-anim         uint8       4       :offset 339) ;; MIPS 335
   (jmod-head          basic               :offset 344) ;; MIPS 340
   (arm-ik             uint8       12      :offset 348) ;; MIPS 344
   (looking-at         uint8       8       :offset 360) ;; uint64 but 4-byte aligned — MIPS 356
   (looking-at-timeout int32               :offset 368) ;; MIPS 364
   (helmet             helmet      :inline :offset 384) ;; MIPS 368 (16B mem-aligned; GOAL 384 = next 16B GOAL slot)
   (driver-tail        uint8       4       :offset 400) ;; MIPS 396
   )
  :method-count-assert 67
  :size-assert         #x194
  :flag-assert         #x4301100194
  (:state-methods
    idle  ;; 59
    intro ;; 60
    die   ;; 61
    )
  (:methods
    (driver-method-62 (_type_) none) ;; 62
    (driver-method-63 (_type_) int) ;; 63
    (driver-method-64 (_type_) int) ;; 64
    (driver-method-65 (_type_ uint int) none) ;; 65
    (driver-method-66 (_type_) none) ;; 66
    )
  )



