   (min-offset   int32     :offset-assert 4)
   (blocks uint8 4 :offset-assert 8)
   )
  :method-count-assert 10
  :size-assert         #x88
  :flag-assert         #xa00000088
  (:methods
    (dma-block-list-method-9 (_type_) none) ;; 9
    )
  )
|#



