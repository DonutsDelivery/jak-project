    (hud-item-method-18 (_type_ object object object) none) ;; 18
    (hud-item-method-19 (_type_) symbol) ;; 19
    (hud-item-method-20 (_type_ object) int) ;; 20
    (hud-item-method-21 (_type_) int) ;; 21
    (hud-item-method-22 (_type_) int) ;; 22
    (hud-item-method-23 (_type_ time-frame object object object) int) ;; 23
    )
  )



(deftype hud-effect (basic)
  ((message      symbol :offset-assert 4)
   (active       basic  :offset-assert 8)
