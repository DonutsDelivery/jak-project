    (medius-cache-method-10 (_type_ int) none) ;; 10
    (medius-cache-method-11 (_type_) none) ;; 11
    (medius-cache-method-12 (_type_) int) ;; 12
    (medius-cache-method-13 (_type_) none) ;; 13
    (medius-cache-method-14 (_type_) none) ;; 14
    )
  )



