;; this-way (process-drawable subtype with idle state — was pre-parent)
(deftype this-way (process-drawable)
  ()
  :method-count-assert 51
  :size-assert         #xf8
  :flag-assert         #x33007000f8
  (:methods
    (idle () _type_ :state) ;; 50
