  (pause-sound 5)
  (stop-sound 6)
  (continue-sound 7)
  (set-param 8)
  (set-master-volume 9)
  (pause-group 10)
  (stop-group 11)
  (continue-group 12)
  (get-irx-version 13)
  (set-language 14)
  (set-reverb 15)
  (shutdown 16)
  (list-sounds 17)
  (set-fps 18)
