(deftype stat-info (structure)
  ((text-id      uint32  :offset-assert 0)
   (taskname     symbol  :offset-assert 4)
   (name         symbol  :offset-assert 8)
   (offset       int32   :offset-assert 12)
   (tp           uint64  :offset-assert 16)
   (scale        float   :offset-assert 24)
   (format-scale float   :offset-assert 28)
   (flags        uint64  :offset-assert 32)
   (init         int32   :offset-assert 40)
   (min-div      int32   :offset-assert 44)
   )
  :method-count-assert 15
  :size-assert         #x30
  :flag-assert         #xf00000030
  (:methods
    (stat-info-method-9 (_type_ uint) none) ;; 9
    (stat-info-method-10 (_type_ object object object) symbol) ;; 10
    (stat-info-method-11 (_type_ object object) symbol) ;; 11
    (stat-info-method-12 (_type_ object object) symbol) ;; 12
    (stat-info-method-13 (_type_ object object object) none) ;; 13
    (stat-info-method-14 (_type_ string) int) ;; 14
    )
  )



