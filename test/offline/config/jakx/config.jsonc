{
  // Bootstrap config for jakx offline-test.
  // Start with CGOs (engine code) — level DGOs can be added later as they decompile.
  // Keep the dgos list minimal during Phase-0 so offline-test is fast and the
  // _REF.gc corpus stays small + curated. Expand as more files reach real-clean.
  "dgos": [
    "CGO/KERNEL.CGO",
    "CGO/GAME.CGO",
    "CGO/ENGINE.CGO",
    "CGO/COMMON.CGO",
    "CGO/ART.CGO",
    // Level DGOs — added so compile-audit can test all emitted files, not just CGO subset.
    "DGO/ATL.DGO",
    "DGO/ATOLLART.DGO",
    "DGO/ATOLLS.DGO",
    "DGO/ATX.DGO"
  ],

  // Skip goalc-compiling these (they decompile but we know the output won't compile
  // yet — e.g., top-level lambdas, asm tricks, weird type layouts).
  "skip_compile_files": [
    "types-h",
    "hfrag-h",
    "joint",
    "subdivide",
    "shadow-cpu-h",
    "foreground",
    "tie-methods",
    "scene-actor",
    // jakx: unresolved <static-data-LN> placeholder for *net-play-mode-text-ids*
    // (L178). Decomp output matches REF but goalc can't compile the placeholder
    // until static-array inlining for the jakx symbol layout lands.
    "game-task-h",
    // jakx: (method-set! ... Lnn) pattern — inspect method installed via code label
    // reference. Content matches REF but goalc can't resolve raw label symbols.
    "tie-h",
    "sky-h",
    "shrubbery-h",
    "minimap-h",
    // jakx: talker-speech-class.name (string at struct offset 0) confuses static-ref
    // decompiler → *talker-speech* #f fallback → TypeCheck fail.
    "ambient-h",
    // jakx: lightning-probe-vars.probe-dirs (inline-array vector) at static L33+64
    // holds a raw runtime address → decompile_at_label "unknown data" → *lightning-probe-vars* #f.
    // Jak3 has the same upstream limitation for the same reason (runtime-address in static data).
    // Not addressable from config; this is a decompiler structural gap.
    "lightning-h",
    // jakx: (the-as TYPE Lnn) static label references not resolvable by goalc.
    "mood-tables",
    // jakx: (set! a1-0 L440) raw label ref in (method inspect mysql-nav-graph).
    // Content matches REF; goalc can't resolve label symbol.
    "mysql-nav-graph",
    // jakx: L13/L14 raw label refs (same static-ref pattern as mood-tables).
    "file-io",
    "game-info-h",
    "net-mgr-medius-players-h"
  ],

  // Skip goalc-compiling these specific functions/methods inside otherwise-good files.
  // Most of these are inherited from jak3 (same decompiler, same edge cases).
  // Trim as jakx's real-clean set shrinks.
  "skip_compile_functions": [
    // gcommon
    "qmem-clear!",
    "(method 9 inline-array-class-uint32)",
    "(method 9 inline-array-class-uint64)",
    "breakpoint-range-set!",
    "valid?",
    // gkernel
    "(method 10 process)",
    "(method 14 dead-pool)",
    // gstate
    "enter-state",
    // math
    "logf",
    "log2f",
    "cube-root",
    "lerp-scale",
    "rand-vu-init",
    "rand-vu",
    "rand-vu-nostep",
    // matrix
    "matrix-axis-sin-cos-vu!",
    "matrix-axis-sin-cos!",
    "matrix-3x3-normalize!",
    // geometry
    "closest-pt-in-triangle",
    "circle-circle-xz-intersect",
    "calculate-basis-functions-vector!",
