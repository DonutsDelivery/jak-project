;;-*-Lisp-*-
(in-package goal)

;; definition for method 11 of type racer-state
;; INFO: Used lq/sq
(defmethod end-lap ((this racer-state) (arg0 process-drawable))
  (let ((v1-0 (process->ppointer arg0)))
    (set! (-> this racer)
          (the-as handle (logior (if (the-as (pointer process-drawable) v1-0)
                                     (shl (-> (the-as (pointer process-drawable) v1-0) 0 pid) 32)
                                     0
                                     )
                                 (the-as uint v1-0)
                                 )
                  )
          )
    )
  (when arg0
    (set! (-> this position quad) (-> arg0 root trans quad))
    (set! (-> this last-race-mesh-position quad) (-> arg0 root trans quad))
    )
  (set! (-> this flags) (the-as uint 40))
  (set! (-> this lap-count) 0)
  (set! (-> this lap-distance) 0.0)
  (set! (-> this lap-quadrant) 3)
  (set! (-> this lap) 0.0)
  (set! (-> this prev-racer-lap) 0.0)
  (set! (-> this next-racer-lap) 0.0)
  (set! (-> this last-slice) 0)
  (set! (-> this last-race-line) #f)
  0
  )

;; definition for method 9 of type race-state
(defmethod race-state-method-9 ((this race-state) (arg0 process-drawable) (arg1 int))
  (if (< arg1 10)
      ((method-of-type racer-state end-lap) (the-as racer-state (+ (+ (* 96 arg1) 112) (the-as int this))) arg0)
      )
  0
  )

;; definition for method 10 of type race-state
(defmethod race-state-method-10 ((this race-state))
  (with-pp
    (dotimes (s5-0 (-> this racer-count))
      (let ((v1-3 (the-as object (+ (+ (* 96 s5-0) 112) (the-as int this))))
            (a1-0 (new 'stack-no-clear 'event-message-block))
            )
        (set! (-> a1-0 from) (process->ppointer pp))
        (set! (-> a1-0 num-params) 0)
        (set! (-> a1-0 message) 'race-deactivate)
        (let ((t9-0 send-event-function)
              (v1-4 (-> (the-as racer-state v1-3) racer))
              )
          (t9-0
            (and (nonzero? (l32-false-check v1-4)) (let ((a2-1 (-> v1-4 0)))
                                                     (if (= (-> v1-4 pid) (-> a2-1 pid))
                                                         a2-1
                                                         )
                                                     )
                 )
            a1-0
            )
          )
        )
      )
    #f
    )
  )

;; definition for symbol *race-state*, type race-state
(define *race-state* (new 'static 'race-state))




