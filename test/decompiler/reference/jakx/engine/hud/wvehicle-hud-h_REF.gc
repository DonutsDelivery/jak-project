  (format #t "~2Thud-right-display-shine: #<hud-sprite @ #x~X>~%" (-> this hud-right-display-shine))
  (format #t "~2Thud-left-ammo-counter-1: #<hud-sprite @ #x~X>~%" (-> this hud-left-ammo-counter-1))
  (format #t "~2Thud-left-ammo-counter-2: #<hud-sprite @ #x~X>~%" (-> this hud-left-ammo-counter-2))
  (format #t "~2Thud-left-light-underlay: #<hud-sprite @ #x~X>~%" (-> this hud-left-light-underlay))
  (format #t "~2Thud-left-light-ctrl-1: #<hud-sprite @ #x~X>~%" (-> this hud-left-light-ctrl-1))
