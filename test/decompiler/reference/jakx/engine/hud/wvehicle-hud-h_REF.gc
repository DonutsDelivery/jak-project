;;-*-Lisp-*-
(in-package goal)

;; definition of type fx-struct
(deftype fx-struct (structure)
  ((offset-x    int32)
   (offset-y    int32)
   (scale-x     basic)
   (scale-y     basic)
   (alpha       basic)
   (angle       basic)
   (total-time  uint32)
   )
  )

;; definition for method 3 of type fx-struct
(defmethod inspect ((this fx-struct))
  (when (not this)
    (set! this this)
    (goto cfg-4)
    )
  (format #t "[~8x] ~A~%" this 'fx-struct)
  (format #t "~1Toffset-x: ~D~%" (-> this offset-x))
  (format #t "~1Toffset-y: ~D~%" (-> this offset-y))
  (format #t "~1Tscale-x: ~A~%" (-> this scale-x))
  (format #t "~1Tscale-y: ~A~%" (-> this scale-y))
  (format #t "~1Talpha: ~A~%" (-> this alpha))
  (format #t "~1Tangle: ~A~%" (-> this angle))
  (format #t "~1Ttotal-time: ~D~%" (-> this total-time))
  (label cfg-4)
  this
  )

;; definition of type hud-vehicle
(deftype hud-vehicle (hud)
  ((weapon-texture                    uint8       49      :offset 6364)
   (gun-texture                       basic               :overlay-at (-> weapon-texture 0))
   (missile-texture                   basic               :overlay-at (-> weapon-texture 4))
   (grenade-texture                   basic               :overlay-at (-> weapon-texture 8))
   (taserram-texture                  basic               :overlay-at (-> weapon-texture 12))
   (mine-texture                      basic               :overlay-at (-> weapon-texture 16))
   (shield-texture                    basic               :overlay-at (-> weapon-texture 20))
   (target-texture                    uint8       2       :offset 6560)
   (slot-roulette-active?             uint8       2       :offset 6568)
   (button-out?                       uint8       2       :offset 6576)
   (weapon-picked?                    uint8       2       :offset 6584)
   (slot-roulette-start-time          uint8       2       :offset 6592)
   (roulette-counter                  uint8       2       :offset 6600)
   (weapon-color                      uint8       2       :offset 6608)
   (selected-weapon                   uint8       2       :offset 6610)
   (powerup-level                     int32               :offset 6612)
   (last-light-level                  int8                :offset 6616)
   (light-bar-part-right-init         basic               :offset 6620)
   (light-bar-part-right-filled       basic               :offset 6624)
   (light-bar-part-left-init          basic               :offset 6628)
   (light-bar-part-left-filled        basic               :offset 6632)
   (current-light-eco                 float               :offset 6636)
   (current-green-eco                 float               :offset 6640)
   (current-blue-eco                  float               :offset 6644)
   (slot-weapon-color                 uint8       2       :offset 6648)
   (incoming?                         basic               :offset 6652)
   (light-eco-level                   float               :offset 6656)
   (light-eco-level-fx-start-time     uint32              :offset 6660)
   (split-screen-offset-left-x        float               :offset 6664)
   (split-screen-offset-right-x       float               :offset 6668)
   (split-screen-offset-y             float               :offset 6672)
   (hud-right-ammo-counter-1          hud-sprite  :inline :overlay-at (-> sprites-raw 0))
   (hud-right-ammo-counter-2          hud-sprite  :inline :overlay-at (-> sprites-raw 64))
   (hud-right-light-underlay          hud-sprite  :inline :overlay-at (-> sprites-raw 128))
   (hud-right-light-ctrl-1            hud-sprite  :inline :overlay-at (-> sprites-raw 192))
