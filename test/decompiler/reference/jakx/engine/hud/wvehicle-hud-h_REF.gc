   (hud-right-light-ctrl-3            hud-sprite  :inline :overlay-at (-> sprites-raw 320))
   (hud-right-light-bar               hud-sprite  :inline :overlay-at (-> sprites-raw 384))
   (hud-right-turbo-underlay          hud-sprite  :inline :overlay-at (-> sprites-raw 448))
   (hud-right-turbo-ctrl-1            hud-sprite  :inline :overlay-at (-> sprites-raw 512))
   (hud-right-turbo-ctrl-2            hud-sprite  :inline :overlay-at (-> sprites-raw 576))
   (hud-right-turbo-bar               hud-sprite  :inline :overlay-at (-> sprites-raw 640))
   (hud-right-display-weapon-field    hud-sprite  :inline :overlay-at (-> sprites-raw 704))
   (hud-right-upper-left              hud-sprite  :inline :overlay-at (-> sprites-raw 768))
   (hud-right-upper-right             hud-sprite  :inline :overlay-at (-> sprites-raw 832))
   (hud-right-lower-right             hud-sprite  :inline :overlay-at (-> sprites-raw 896))
   (hud-right-lower-left              hud-sprite  :inline :overlay-at (-> sprites-raw 960))
   (hud-right-ammo-counter-overlay    hud-sprite  :inline :overlay-at (-> sprites-raw 1024))
   (hud-right-ammo-counter-overlay-2  hud-sprite  :inline :overlay-at (-> sprites-raw 1088))
   (hud-right-weapon-icon-shadow      hud-sprite  :inline :overlay-at (-> sprites-raw 1152))
   (hud-right-weapon-icon             hud-sprite  :inline :overlay-at (-> sprites-raw 1216))
   (hud-right-display-shine           hud-sprite  :inline :overlay-at (-> sprites-raw 1280))
   (hud-left-ammo-counter-1           hud-sprite  :inline :overlay-at (-> sprites-raw 1344))
   (hud-left-ammo-counter-2           hud-sprite  :inline :overlay-at (-> sprites-raw 1408))
   (hud-left-light-underlay           hud-sprite  :inline :overlay-at (-> sprites-raw 1472))
   (hud-left-light-ctrl-1             hud-sprite  :inline :overlay-at (-> sprites-raw 1536))
   (hud-left-light-ctrl-2             hud-sprite  :inline :overlay-at (-> sprites-raw 1600))
   (hud-left-light-ctrl-3             hud-sprite  :inline :overlay-at (-> sprites-raw 1664))
   (hud-left-light-bar                hud-sprite  :inline :overlay-at (-> sprites-raw 1728))
   (hud-left-health-underlay          hud-sprite  :inline :overlay-at (-> sprites-raw 1792))
   (hud-left-health-ctrl-1            hud-sprite  :inline :overlay-at (-> sprites-raw 1856))
   (hud-left-health-ctrl-2            hud-sprite  :inline :overlay-at (-> sprites-raw 1920))
   (hud-left-health-bar               hud-sprite  :inline :overlay-at (-> sprites-raw 1984))
   (hud-left-display-weapon-field     hud-sprite  :inline :overlay-at (-> sprites-raw 2048))
   (hud-left-upper-left               hud-sprite  :inline :overlay-at (-> sprites-raw 2112))
   (hud-left-upper-right              hud-sprite  :inline :overlay-at (-> sprites-raw 2176))
   (hud-left-lower-left               hud-sprite  :inline :overlay-at (-> sprites-raw 2240))
   (hud-left-lower-right              hud-sprite  :inline :overlay-at (-> sprites-raw 2304))
   (hud-left-ammo-counter-overlay     hud-sprite  :inline :overlay-at (-> sprites-raw 2368))
   (hud-left-ammo-counter-overlay-2   hud-sprite  :inline :overlay-at (-> sprites-raw 2432))
   (hud-left-weapon-icon-shadow       hud-sprite  :inline :overlay-at (-> sprites-raw 2496))
   (hud-left-weapon-icon              hud-sprite  :inline :overlay-at (-> sprites-raw 2560))
   (hud-left-display-shine            hud-sprite  :inline :overlay-at (-> sprites-raw 2624))
   (hud-turbo-disabled                hud-sprite  :inline :overlay-at (-> sprites-raw 2688))
   )
  (:methods
    (hud-vehicle-method-30 (_type_) none)
    (hud-vehicle-method-31 (_type_) none)
    (hud-vehicle-method-32 (_type_) none)
    (hud-vehicle-method-33 (_type_) none)
    (hud-vehicle-method-34 (_type_) none)
    (hud-vehicle-method-35 (_type_) none)
    (hud-vehicle-method-36 (_type_) none)
    (hud-vehicle-method-37 (_type_) none)
    (hud-vehicle-method-38 (_type_) none)
    (hud-vehicle-method-39 (_type_) none)
    )
  )

;; definition for method 3 of type hud-vehicle
(defmethod inspect ((this hud-vehicle))
  (when (not this)
    (set! this this)
    (goto cfg-4)
    )
  (let ((t9-0 (method-of-type hud inspect)))
    (t9-0 this)
    )
  (format #t "~2Tweapon-texture[49] @ #x~X~%" (-> this weapon-texture))
  (format #t "~2Tgun-texture: ~A~%" (-> this gun-texture))
  (format #t "~2Tmissile-texture: ~A~%" (-> this missile-texture))
  (format #t "~2Tgrenade-texture: ~A~%" (-> this grenade-texture))
