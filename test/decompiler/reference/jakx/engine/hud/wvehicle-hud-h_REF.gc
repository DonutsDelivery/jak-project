  (format #t "~2Thud-right-light-ctrl-3: #<hud-sprite @ #x~X>~%" (-> this hud-right-light-ctrl-3))
  (format #t "~2Thud-right-light-bar: #<hud-sprite @ #x~X>~%" (-> this hud-right-light-bar))
  (format #t "~2Thud-right-turbo-underlay: #<hud-sprite @ #x~X>~%" (-> this hud-right-turbo-underlay))
