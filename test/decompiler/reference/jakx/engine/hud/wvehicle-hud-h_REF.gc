  (format #t "~2Thud-left-weapon-icon-shadow: #<hud-sprite @ #x~X>~%" (-> this hud-left-weapon-icon-shadow))
  (format #t "~2Thud-left-weapon-icon: #<hud-sprite @ #x~X>~%" (-> this hud-left-weapon-icon))
