  )

;; definition for symbol *default-fast-curve*, type curve2d-fast
(define *default-fast-curve* (new 'static 'curve2d-fast
                               :xs (new 'static 'vector :data (new 'static 'array float 4 0.0 -1.0 -2.0 -3.0))
                               :ys (new 'static 'vector :data (new 'static 'array float 4 0.0 1.0 2.0 3.0))
                               :one-over-x-deltas (new 'static 'vector :data (new 'static 'array float 4 1.0 1.0 1.0 1.0))
                               )
        )




