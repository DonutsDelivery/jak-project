                           ((= v1-2 -973)
                            "medius-game-name-not-found"
                            )
                           ((= v1-2 -995)
                            "medius-login-failed"
                            )
                           ((= v1-2 -977)
                            "medius-game-not-found"
                            )
                           ((= v1-2 -953)
                            "medius-account-banned"
                            )
                           ((= v1-2 -979)
                            "medius-invalid-request-msg"
                            )
                           ((= v1-2 -956)
                            "medius-max-exceeded"
                            )
                           ((= v1-2 -958)
                            "medius-data-already-exists"
                            )
                           ((= v1-2 3)
