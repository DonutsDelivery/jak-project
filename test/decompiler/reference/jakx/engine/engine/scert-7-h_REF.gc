  (format #t "[~8x] ~A~%" this 'medius-get-total-rankings-request)
  (format #t "~1Tmessage-id[21] @ #x~X~%" (-> this message-id))
  (let ((t9-2 format)
        (a0-3 #t)
        (a1-2 "~1Tladder-type: #x~X : ~S~%")
        (a2-2 (-> this ladder-type))
        (v1-2 (-> this ladder-type))
