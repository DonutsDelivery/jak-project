;; definition of type anonymous-0
(deftype anonymous-0 (structure)
  ((error-threshold-magnitude  float)
   (pf-threshold-callback      basic  :overlay-at error-threshold-magnitude)
   )
  )

;; definition for method 3 of type anonymous-0
(defmethod inspect ((this anonymous-0))
  (when (not this)
    (set! this this)
