  (format #t "~1Telement-size: ~D~%" (-> this element-size))
  (format #t "~1Telement-count: ~D~%" (-> this element-count))
  (format #t "~1Te-type: ~D~%" (-> this e-type))
  (format #t "~1Tupdate-schedule: #<net-type-broadcast-schedule @ #x~X>~%" (-> this update-schedule))
  (label cfg-4)
  this
  )

