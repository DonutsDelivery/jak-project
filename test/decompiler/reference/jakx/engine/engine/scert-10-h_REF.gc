                           ((= v1-2 3)
                            "mgcl-alert-high"
                            )
                           ((= v1-2 #xffffff)
                            "extra-mgclalert-code"
                            )
                           ((= v1-2 1)
                            "mgcl-alert-low"
                            )
                           (else
                             "*unknown*"
                             )
