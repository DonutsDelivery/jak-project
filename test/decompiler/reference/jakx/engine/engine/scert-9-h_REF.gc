    (-> this my-add-to-buddy-list-fwd-confirmation-request-callback-user-data)
    )
  (format #t "~1Tmy-error-message-callback: ~A~%" (-> this my-error-message-callback))
  (format #t "~1Tmy-error-message-callback-user-data: ~A~%" (-> this my-error-message-callback-user-data))
