;; definition of type medius-world-report
(deftype medius-world-report (structure)
  ((session-key         uint8  17)
   (medius-world-id     int32)
   (player-count        int32)
   (game-name           uint8  64)
   (game-stats          uint8  256)
   (min-players         int32)
   (max-players         int32)
   (game-level          int32)
   (player-skill-level  int32)
   (rules-set           int32)
   (generic-field1      int32)
   (generic-field2      int32)
   (generic-field3      int32)
   (world-status        int32)
   )
  )

;; definition for method 3 of type medius-world-report
(defmethod inspect ((this medius-world-report))
  (when (not this)
    (set! this this)
    (goto cfg-19)
    )
  (format #t "[~8x] ~A~%" this 'medius-world-report)
  (format #t "~1Tsession-key[17] @ #x~X~%" (-> this session-key))
  (format #t "~1Tmedius-world-id: ~D~%" (-> this medius-world-id))
  (format #t "~1Tplayer-count: ~D~%" (-> this player-count))
  (format #t "~1Tgame-name[64] @ #x~X~%" (-> this game-name))
  (format #t "~1Tgame-stats[256] @ #x~X~%" (-> this game-stats))
  (format #t "~1Tmin-players: ~D~%" (-> this min-players))
  (format #t "~1Tmax-players: ~D~%" (-> this max-players))
  (format #t "~1Tgame-level: ~D~%" (-> this game-level))
  (format #t "~1Tplayer-skill-level: ~D~%" (-> this player-skill-level))
  (format #t "~1Trules-set: ~D~%" (-> this rules-set))
  (format #t "~1Tgeneric-field1: ~D~%" (-> this generic-field1))
  (format #t "~1Tgeneric-field2: ~D~%" (-> this generic-field2))
  (format #t "~1Tgeneric-field3: ~D~%" (-> this generic-field3))
  (let ((t9-14 format)
        (a0-15 #t)
        (a1-14 "~1Tworld-status: #x~X : ~S~%")
        (a2-14 (-> this world-status))
        (v1-2 (-> this world-status))
        )
    (t9-14 a0-15 a1-14 a2-14 (cond
                               ((= v1-2 2)
                                "world-active"
                                )
                               ((= v1-2 1)
                                "world-staging"
                                )
                               ((= v1-2 5)
                                "world-pending-connect-to-game"
                                )
                               ((= v1-2 4)
                                "world-pending-creation"
                                )
                               ((= v1-2 #xffffff)
                                "extra-medius-world-status"
                                )
                               ((= v1-2 3)
                                "world-closed"
                                )
                               ((zero? v1-2)
                                "world-inactive"
                                )
                               (else
                                 "*unknown*"
                                 )
                               )
           )
    )
  (label cfg-19)
  this
  )

