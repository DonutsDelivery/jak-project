                            )
                           ((= v1-2 -975)
                            "medius-game-name-exists"
                            )
                           ((= v1-2 #xffffff)
                            "extra-medius-callback-status"
                            )
                           ((= v1-2 -943)
                            "medius-password-not-uccompliant"
                            )
                           ((= v1-2 -944)
                            "medius-account-not-uccompliant"
                            )
                           ((= v1-2 -967)
                            "medius-filter-failed"
                            )
                           ((= v1-2 -974)
