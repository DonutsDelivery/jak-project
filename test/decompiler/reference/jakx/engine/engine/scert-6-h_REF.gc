  (format #t "~1Tladder-stat: ~D~%" (-> this ladder-stat))
  (format #t "~1Tladder-position: ~D~%" (-> this ladder-position))
  (format #t "~1Ttotal-rankings: ~D~%" (-> this total-rankings))
  (format #t "~1Tend-of-list: ~D~%" (-> this end-of-list))
  (label cfg-133)
  this
  )




