  (let ((t9-6 format)
        (a0-7 #t)
        (a1-6 "~1Tconnection-class: #x~X : ~S~%")
        (a2-6 (-> this connection-class))
        (v1-3 (-> this connection-class))
        )
    (t9-6 a0-7 a1-6 a2-6 (cond
                           ((= v1-3 1)
