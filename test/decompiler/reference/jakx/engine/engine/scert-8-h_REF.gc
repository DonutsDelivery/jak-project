                            "wireless"
                            )
                           (else
                             "*unknown*"
                             )
                           )
          )
    )
  (format #t "~1Tstats[256] @ #x~X~%" (-> this stats))
  (label cfg-155)
  this
  )

;; definition of type medius-player-report
(deftype medius-player-report (structure)
  ((session-key      uint8  17)
   (medius-world-id  int32)
   (stats            uint8  256)
   )
  )

;; definition for method 3 of type medius-player-report
(defmethod inspect ((this medius-player-report))
  (when (not this)
    (set! this this)
    (goto cfg-4)
    )
  (format #t "[~8x] ~A~%" this 'medius-player-report)
  (format #t "~1Tsession-key[17] @ #x~X~%" (-> this session-key))
  (format #t "~1Tmedius-world-id: ~D~%" (-> this medius-world-id))
  (format #t "~1Tstats[256] @ #x~X~%" (-> this stats))
  (label cfg-4)
  this
  )

