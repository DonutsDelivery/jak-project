  (format #t "~1Tladder-stat-index: ~D~%" (-> this ladder-stat-index))
  (let ((t9-3 format)
        (a0-4 #t)
        (a1-3 "~1Tsort-order: #x~X : ~S~%")
        (a2-3 (-> this sort-order))
        (v1-2 (-> this sort-order))
        )
    (t9-3 a0-4 a1-3 a2-3 (cond
                           ((= v1-2 #xffffff)
                            "extra-medius-sort-order"
                            )
                           ((= v1-2 1)
                            "medius-descending"
                            )
                           ((zero? v1-2)
                            "medius-ascending"
                            )
                           (else
                             "*unknown*"
                             )
                           )
          )
    )
  (format #t "~1Tstart-position: ~D~%" (-> this start-position))
  (format #t "~1Tpage-size: ~D~%" (-> this page-size))
  (label cfg-11)
  this
  )

