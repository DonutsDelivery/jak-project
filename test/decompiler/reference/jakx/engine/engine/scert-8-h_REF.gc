  (when (not this)
    (set! this this)
    (goto cfg-4)
    )
  (format #t "[~8x] ~A~%" this 'medius-send-clan-message-request)
  (format #t "~1Tmessage-id[21] @ #x~X~%" (-> this message-id))
  (format #t "~1Tsession-key[17] @ #x~X~%" (-> this session-key))
  (format #t "~1Tmessage[200] @ #x~X~%" (-> this message))
  (label cfg-4)
  this
  )

