                            )
                           ((zero? v1-2)
                            "medius-ascending"
                            )
                           (else
                             "*unknown*"
                             )
                           )
          )
    )
  (format #t "~1Tstart-position: ~D~%" (-> this start-position))
  (format #t "~1Tpage-size: ~D~%" (-> this page-size))
  (label cfg-11)
  this
  )

