                            )
                           ((= v1-2 -994)
                            "medius-registration-failed"
                            )
                           ((= v1-2 -968)
                            "medius-text-string-invalid"
                            )
                           ((= v1-2 -949)
                            "medius-dnassignature-logged-in"
                            )
                           ((= v1-2 -981)
                            "medius-num-filters-at-max"
                            )
                           ((= v1-2 -973)
                            "medius-game-name-not-found"
                            )
                           ((= v1-2 -995)
