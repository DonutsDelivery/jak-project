  ((message-id        uint8  21)
   (connection-class  int32)
   )
  )

;; definition for method 3 of type medius-session-begin-request
(defmethod inspect ((this medius-session-begin-request))
  (when (not this)
    (set! this this)
    (goto cfg-13)
    )
  (format #t "[~8x] ~A~%" this 'medius-session-begin-request)
  (format #t "~1Tmessage-id[21] @ #x~X~%" (-> this message-id))
  (let ((t9-2 format)
        (a0-3 #t)
        (a1-2 "~1Tconnection-class: #x~X : ~S~%")
        (a2-2 (-> this connection-class))
        (v1-2 (-> this connection-class))
        )
    (t9-2 a0-3 a1-2 a2-2 (cond
                           ((= v1-2 1)
                            "ethernet"
                            )
                           ((= v1-2 #xffffff)
                            "extra-medius-connection-type"
                            )
                           ((zero? v1-2)
                            "modem"
                            )
                           ((= v1-2 2)
                            "wireless"
                            )
                           (else
                             "*unknown*"
                             )
                           )
          )
    )
  (label cfg-13)
  this
  )

