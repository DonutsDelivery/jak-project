                            )
                           ((= v1-2 8)
                            "medius-filter-generic-field-2"
                            )
                           (else
                             "*unknown*"
                             )
                           )
          )
    )
  (let ((t9-4 format)
        (a0-5 #t)
        (a1-4 "~1Tcomparison-operator: #x~X : ~S~%")
        (a2-4 (-> this comparison-operator))
        (v1-3 (-> this comparison-operator))
        )
    (t9-4 a0-5 a1-4 a2-4 (cond
                           ((= v1-3 2)
                            "equal-to"
                            )
                           ((= v1-3 1)
                            "less-than-or-equal-to"
                            )
                           ((= v1-3 4)
                            "greater-than"
                            )
                           ((= v1-3 3)
                            "greater-than-or-equal-to"
                            )
                           ((= v1-3 #xffffff)
                            "extra-medius-comparison-operator"
                            )
                           ((zero? v1-3)
                            "less-than"
                            )
                           ((= v1-3 5)
                            "not-equals"
                            )
                           (else
                             "*unknown*"
                             )
                           )
          )
    )
  (format #t "~1Tbaseline-value: ~D~%" (-> this baseline-value))
  (label cfg-42)
  this
  )

