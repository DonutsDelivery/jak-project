  (let ((t9-4 format)
        (a0-5 #t)
        (a1-4 "~1Tclient-status: #x~X : ~S~%")
        (a2-4 (-> this client-status))
        (v1-2 (-> this client-status))
        )
    (t9-4 a0-5 a1-4 a2-4 (cond
                           ((= v1-2 4)
                            "client-status-joined"
                            )
                           ((= v1-2 3)
                            "client-status-joining"
                            )
                           ((= v1-2 5)
