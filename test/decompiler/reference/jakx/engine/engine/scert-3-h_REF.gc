                            )
                           ((= v1-2 14)
                            "net-error-timed-out"
                            )
                           ((= v1-2 #xffffff)
                            "extra-net-error-code"
                            )
                           ((= v1-2 30)
                            "net-error-unknown"
                            )
                           ((= v1-2 2)
                            "net-error-connection-lost"
                            )
                           ((= v1-2 24)
