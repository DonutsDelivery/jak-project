;; definition of type medius-add-to-buddy-list-confirmation-response
(deftype medius-add-to-buddy-list-confirmation-response (structure)
  ((message-id           uint8  21)
   (status-code          int32)
   (target-account-id    int32)
   (target-account-name  uint8  32)
