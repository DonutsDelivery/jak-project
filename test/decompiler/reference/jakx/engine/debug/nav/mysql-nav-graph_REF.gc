;; type mysql-nav-node is defined here, but it is unknown to the decompiler

(method-set! (the-as type mysql-nav-node) 3 L286)

;; definition of type mysql-nav-node-array
(deftype mysql-nav-node-array (inline-array-class)
  ()
  )

;; definition for method 3 of type mysql-nav-node-array
(defmethod inspect ((this mysql-nav-node-array))
  (when (not this)
    (set! this this)
    (goto cfg-4)
    )
  (format #t "[~8x] ~A~%" this (-> this type))
  (format #t "~1Tlength: ~D~%" (-> this length))
  (format #t "~1Tallocated-length: ~D~%" (-> this allocated-length))
  (format #t "~1Tdata[0] @ #x~X~%" (-> this _data))
  (label cfg-4)
  this
  )

(set! (-> mysql-nav-node-array heap-base) (the-as uint 80))

