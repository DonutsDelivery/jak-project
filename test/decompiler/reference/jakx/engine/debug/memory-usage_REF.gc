      (let ((v1-2 (-> this data s3-0)))
        (+! s5-0 (-> v1-2 used))
        (+! s4-0 (-> v1-2 total))
        (format
          #t
          "~3D: ~20S ~7D     ~8D       ~8D~%"
          s3-0
          (-> v1-2 name)
          (-> v1-2 count)
          (-> v1-2 used)
          (-> v1-2 total)
          )
        )
      )
    (format #t "total:                               ~8D       ~8D~%" s5-0 s4-0)
    )
  (format #t "-------------------------------------------------------------~%")
  this
  )

