;; definition for method 3 of type basic-reserved
(defmethod inspect ((this basic-reserved))
  (when (not this)
    (set! this this)
    (goto cfg-4)
    )
  (format #t "[~8x] ~A~%" this (-> this type))
  (label cfg-4)
  this
  )

;; definition of type part-id
(deftype part-id (uint32)
  ()
  )

