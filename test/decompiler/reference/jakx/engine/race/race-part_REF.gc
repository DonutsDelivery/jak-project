;; definition for function spt-birth-func-brightness-collectoid-dust
(defun spt-birth-func-brightness-collectoid-dust ((arg0 sparticle-system) (arg1 sparticle-cpuinfo) (arg2 sprite-vec-data-3d))
  (let ((s5-0 (+ (mod (the-as int (rand-uint31-gen *random-generator*)) 51) 100))
        (s3-0 (+ (logand 0 (rand-uint31-gen *random-generator*)) 150))
        (s4-0 (+ (mod (the-as int (rand-uint31-gen *random-generator*)) 101) 50))
        (v1-7 (+ (mod (the-as int (rand-uint31-gen *random-generator*)) 101) 50))
        )
    (set! (-> arg2 r-g-b-a x) (the float (- s5-0 (the-as int s3-0))))
    (set! (-> arg2 r-g-b-a y) (the float (- s5-0 s4-0)))
    (set! (-> arg2 r-g-b-a z) (the float (- s5-0 v1-7)))
    )
  )

