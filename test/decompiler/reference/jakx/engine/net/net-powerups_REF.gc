   )
  )

;; definition for method 3 of type eco-powerup-draw
(defmethod inspect ((this eco-powerup-draw))
  (when (not this)
    (set! this this)
    (goto cfg-4)
    )
  (let ((t9-0 (method-of-type powerup-draw inspect)))
    (t9-0 this)
    )
  (format #t "~2Tvehicle-handle: ~D~%" (-> this vehicle-handle))
  (label cfg-4)
  this
  )

;; definition for method 55 of type eco-powerup-draw
;; INFO: function output is handled by mips2c
(defmethod-mips2c "(method 55 eco-powerup-draw)" 55 eco-powerup-draw)

;; failed to figure out what this is:
(defstate idle (eco-powerup-draw)
  :virtual #t
  :post (behavior ()
    (if (and (nonzero? (-> self part)) (< (-> self draw cur-lod) 1))
        (sparticle-launch-control-method-16 (-> self part) (-> self root trans))
        )
    (ja-post)
    )
  )

