;;-*-Lisp-*-
(in-package goal)

;; definition for symbol *clan-pending-deltas-valid*, type object
(define *clan-pending-deltas-valid* (the-as object #f))

;; definition for symbol *clan-pending-deltas*, type object
(define *clan-pending-deltas* (the-as object #f))

;; definition of type medius-cached-info-clan
(deftype medius-cached-info-clan (medius-cached-info)
  ((name            uint8                      32  :offset  24)
   (leader-acct-id  int32                          :offset  56)
   (leader-name     uint8                      32  :offset  60)
   (stats           uint8                      256 :offset  92)
   (members         medius-player-index-array      :offset 348)
   (ladder-stats    net-clan-ladder-stats          :offset 352)
   (pad             uint8                      32  :offset 356)
   )
  (:methods
    (medius-cached-info-clan-method-12 (_type_) none)
    )
  )

;; definition for method 3 of type medius-cached-info-clan
(defmethod inspect ((this medius-cached-info-clan))
  (when (not this)
    (set! this this)
    (goto cfg-4)
    )
  (format #t "[~8x] ~A~%" this (-> this type))
  (format #t "~1Tmedius-id: ~D~%" (-> this medius-id))
  (format #t "~1Taccessed-time: ~D~%" (-> this accessed-time))
  (format #t "~1Tfetched-time: ~D~%" (-> this fetched-time))
  (format #t "~1Tstatus: ~D~%" (-> this status))
  (format #t "~1Tname[32] @ #x~X~%" (-> this name))
  (format #t "~1Tleader-acct-id: ~D~%" (-> this leader-acct-id))
  (format #t "~1Tleader-name[32] @ #x~X~%" (-> this leader-name))
  (format #t "~1Tstats[256] @ #x~X~%" (-> this stats))
  (format #t "~1Tmembers: #<medius-player-index-array @ #x~X>~%" (-> this members))
  (format #t "~1Tladder-stats: #<net-clan-ladder-stats @ #x~X>~%" (&-> this ladder-stats))
  (label cfg-4)
  this
  )

;; definition of type medius-clan
(deftype medius-clan (medius-cache-index)
  ()
  (:methods
    (medius-clan-method-11 (_type_) none)
    )
  )

;; definition for method 3 of type medius-clan
(defmethod inspect ((this medius-clan))
  (when (not this)
    (set! this this)
    (goto cfg-4)
    )
  (format #t "[~8x] ~A~%" this 'medius-clan)
  (format #t "~1Tid: ~D~%" (-> this id))
  (label cfg-4)
  this
  )

;; definition of type medius-clan-index-array
(deftype medius-clan-index-array (medius-cache-index-array)
  ()
  )

;; definition for method 3 of type medius-clan-index-array
(defmethod inspect ((this medius-clan-index-array))
  (when (not this)
    (set! this this)
    (goto cfg-4)
    )
  (format #t "[~8x] ~A~%" this 'medius-clan-index-array)
  (format #t "~1Tct: ~D~%" (-> this ct))
  (format #t "~1Tmax-ct: ~D~%" (-> this max-ct))
  (format #t "~1Tdata[0] @ #x~X~%" (-> this data))
  (label cfg-4)
  this
  )

;; definition of type medius-incoming-clan-invite
(deftype medius-incoming-clan-invite (structure)
  ((clan-id    int32)
   (invite-id  int32)
   (clan-name  uint8  32)
   )
  )

;; definition for method 3 of type medius-incoming-clan-invite
(defmethod inspect ((this medius-incoming-clan-invite))
  (when (not this)
    (set! this this)
    (goto cfg-4)
    )
  (format #t "[~8x] ~A~%" this 'medius-incoming-clan-invite)
  (format #t "~1Tclan-id: ~D~%" (-> this clan-id))
  (format #t "~1Tinvite-id: ~D~%" (-> this invite-id))
  (format #t "~1Tclan-name[32] @ #x~X~%" (-> this clan-name))
  (label cfg-4)
  this
  )

;; definition of type medius-clan-challenge
(deftype medius-clan-challenge (structure)
  ((send-clan-id  int32)
   (recv-clan-id  int32)
   (challenge-id  int32)
   (status        int32)
   )
  )

;; definition for method 3 of type medius-clan-challenge
(defmethod inspect ((this medius-clan-challenge))
  (when (not this)
    (set! this this)
    (goto cfg-4)
    )
  (format #t "[~8x] ~A~%" this 'medius-clan-challenge)
  (format #t "~1Tsend-clan-id: ~D~%" (-> this send-clan-id))
  (format #t "~1Trecv-clan-id: ~D~%" (-> this recv-clan-id))
  (format #t "~1Tchallenge-id: ~D~%" (-> this challenge-id))
  (format #t "~1Tstatus: ~D~%" (-> this status))
  (label cfg-4)
  this
  )

