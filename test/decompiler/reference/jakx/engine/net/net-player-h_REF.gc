  )

;; definition for symbol *team-colors*, type object
(define *team-colors*
  (the-as object
    (new 'static 'array uint32 8 #x800000ff #x80ff0000 #x8000ff00 #x80dede00 #x80ffffff #x80008080 #x0 #x0)
    )
  )

