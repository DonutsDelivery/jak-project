((method-of-object *medius-player-cache* medius-cache-method-12))

;; definition of type medius-player
(deftype medius-player (medius-cache-index)
  ()
  (:methods
    (medius-player-method-11 () none)
    (medius-player-method-12 () none)
    (medius-player-method-13 () none)
    )
  )

;; definition for method 3 of type medius-player
(defmethod inspect ((this medius-player))
  (when (not this)
    (set! this this)
    (goto cfg-4)
    )
  (format #t "[~8x] ~A~%" this 'medius-player)
  (format #t "~1Tid: ~D~%" (-> this id))
  (label cfg-4)
  this
  )

;; definition of type medius-player-index-array
(deftype medius-player-index-array (medius-cache-index-array)
  ()
  )

;; definition for method 3 of type medius-player-index-array
(defmethod inspect ((this medius-player-index-array))
  (when (not this)
    (set! this this)
    (goto cfg-4)
    )
  (format #t "[~8x] ~A~%" this 'medius-player-index-array)
  (format #t "~1Tct: ~D~%" (-> this ct))
  (format #t "~1Tmax-ct: ~D~%" (-> this max-ct))
  (format #t "~1Tdata[0] @ #x~X~%" (-> this data))
  (label cfg-4)
  this
  )

