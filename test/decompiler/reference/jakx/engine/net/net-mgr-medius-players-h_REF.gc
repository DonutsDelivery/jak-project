;;-*-Lisp-*-
(in-package goal)

;; definition of type net-player-stats
(deftype net-player-stats (structure)
  ((stats-version    int8)
   (current-clan     int32)
   (last-channel-id  int32)
   )
  )

;; definition for method 3 of type net-player-stats
(defmethod inspect ((this net-player-stats))
  (when (not this)
    (set! this this)
    (goto cfg-4)
    )
  (format #t "[~8x] ~A~%" this 'net-player-stats)
  (format #t "~1Tstats-version: ~D~%" (-> this stats-version))
  (format #t "~1Tcurrent-clan: ~D~%" (-> this current-clan))
  (format #t "~1Tlast-channel-id: ~D~%" (-> this last-channel-id))
  (label cfg-4)
  this
  )

;; definition of type medius-cached-info-player
(deftype medius-cached-info-player (medius-cached-info)
  ((name              uint8                       32  :offset  24)
   (format-name       uint8                       160 :offset  56)
   (online-state-ptr  medius-player-online-state      :offset 216)
   (stats-ptr         net-player-stats                :offset 356)
   (ladder-stats-ptr  net-player-ladder-stats         :offset 368)
   (pad               uint8                       312 :offset 372)
   )
  )

;; definition for method 3 of type medius-cached-info-player
(defmethod inspect ((this medius-cached-info-player))
  (when (not this)
    (set! this this)
    (goto cfg-4)
    )
  (format #t "[~8x] ~A~%" this (-> this type))
  (format #t "~1Tmedius-id: ~D~%" (-> this medius-id))
  (format #t "~1Taccessed-time: ~D~%" (-> this accessed-time))
  (format #t "~1Tfetched-time: ~D~%" (-> this fetched-time))
  (format #t "~1Tstatus: ~D~%" (-> this status))
  (format #t "~1Tname[32] @ #x~X~%" (-> this name))
  (format #t "~1Tformat-name[160] @ #x~X~%" (-> this format-name))
  (format #t "~1Tonline-state: #<medius-player-online-state @ #x~X>~%" (&-> this online-state-ptr))
  (format #t "~1Tstats: #<net-player-stats @ #x~X>~%" (&-> this stats-ptr))
  (format #t "~1Tladder-stats: #<net-player-ladder-stats @ #x~X>~%" (&-> this ladder-stats-ptr))
  (label cfg-4)
  this
  )

