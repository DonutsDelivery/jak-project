;;-*-Lisp-*-
(in-package goal)

;; definition of type eco-perm
(deftype eco-perm (structure)
  ((time          int32)
   (owner         int8)
   (hit-by-local  int8)
   (flags         uint64)
   )
  )

;; definition for method 3 of type eco-perm
(defmethod inspect ((this eco-perm))
  (when (not this)
    (set! this this)
    (goto cfg-4)
    )
  (format #t "[~8x] ~A~%" this 'eco-perm)
  (format #t "~1Ttime: ~D~%" (-> this time))
  (format #t "~1Towner: ~D~%" (-> this owner))
  (format #t "~1Thit-by-local: ~D~%" (-> this hit-by-local))
  (format #t "~1Tflags: ~D~%" (-> this flags))
  (label cfg-4)
  this
  )

;; definition of type eco
(deftype eco (process-drawable)
  ()
  (:state-methods
    running
    die
    )
  (:methods
    (eco-method-52 (_type_) none)
    (eco-method-53 (_type_) int)
    (eco-method-54 (_type_) none)
    (eco-method-55 (_type_) int)
    )
  )

;; definition for method 3 of type eco
(defmethod inspect ((this eco))
  (when (not this)
    (set! this this)
    (goto cfg-4)
    )
  (let ((t9-0 (method-of-type process-drawable inspect)))
    (t9-0 this)
    )
  (label cfg-4)
  this
  )

;; definition of type eco-mgr
(deftype eco-mgr (process-nettable)
  ()
  (:state-methods
    running
    die
    )
  (:methods
    (eco-mgr-method-44 (_type_) int)
    (eco-mgr-method-45 (_type_) none)
    (eco-mgr-method-46 (_type_) none)
    (eco-mgr-method-47 (_type_) symbol)
    (eco-mgr-method-48 (_type_) none)
    (eco-mgr-method-49 (_type_) int)
    (eco-mgr-method-50 (_type_) int)
    )
  )

;; definition for method 3 of type eco-mgr
(defmethod inspect ((this eco-mgr))
  (when (not this)
    (set! this this)
    (goto cfg-4)
    )
  (let ((t9-0 (method-of-type process-nettable inspect)))
    (t9-0 this)
    )
  (label cfg-4)
  this
  )

;; definition for function eco-mgr-init-remote
;; INFO: function output is handled by mips2c
(def-mips2c eco-mgr-init-remote (function none))

;; definition for method 41 of type eco-mgr
(defmethod process-nettable-method-41 ((this eco-mgr) (arg0 object))
  (ppointer->process (process-spawn eco-mgr :init eco-mgr-init-remote :name "eco-mgr"))
  )

;; definition for method 37 of type eco-mgr
;; WARN: Return type mismatch int vs none.
(defmethod process-nettable-method-37 ((this eco-mgr) (arg0 net-process-class-info))
  (set! (-> (the-as (pointer symbol) (+ (* (-> arg0 msg-count) 4) (the-as int (-> arg0 msg-map)))) 3)
        'req-owner
        )
  (+! (-> arg0 msg-count) 1)
  (set! (-> (the-as (pointer symbol) (+ (* (-> arg0 msg-count) 4) (the-as int (-> arg0 msg-map)))) 3)
        'set-owner
        )
  (+! (-> arg0 msg-count) 1)
  (set! (-> (the-as (pointer symbol) (+ (* (-> arg0 msg-count) 4) (the-as int (-> arg0 msg-map)))) 3)
        'collected
        )
  (+! (-> arg0 msg-count) 1)
  (set! (-> (the-as (pointer symbol) (+ (* (-> arg0 msg-count) 4) (the-as int (-> arg0 msg-map)))) 3) 'respawn)
  (+! (-> arg0 msg-count) 1)
  0
  (none)
  )

;; definition for symbol *msg-map-eco-mgr*, type array
(define *msg-map-eco-mgr*
  (the-as array (new 'static 'boxed-array :type symbol :length 0 :allocated-length 64))
  )

;; definition for symbol *net-process-class-info-eco-mgr*, type net-process-class-info
(define *net-process-class-info-eco-mgr* (new 'static 'net-process-class-info))

(set! (-> *net-process-class-info-eco-mgr* msg-map) *msg-map-eco-mgr*)

(write-msg-map-rec (the-as process-drawable eco-mgr) *net-process-class-info-eco-mgr*)

(set! (-> *net-process-class-info-eco-mgr* owner-type) eco-mgr)

;; failed to figure out what this is:
(let ((t9-9 net-process-class-register))
  *net-process-class-info-eco-mgr*
  (t9-9)
  )

;; definition for method 40 of type eco-mgr
(defmethod process-nettable-method-40 ((this eco-mgr))
  *net-process-class-info-eco-mgr*
  )




