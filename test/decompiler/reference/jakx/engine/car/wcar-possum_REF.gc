(in-package goal)

;; definition of type v-possum
(deftype v-possum (wcar-base)
  ()
  )

;; definition for method 3 of type v-possum
(defmethod inspect ((this v-possum))
  (when (not this)
    (set! this this)
    (goto cfg-4)
    )
  (let ((t9-0 (method-of-type wcar-base inspect)))
    (t9-0 this)
    )
  (label cfg-4)
  this
  )

;; definition for method 115 of type v-possum
