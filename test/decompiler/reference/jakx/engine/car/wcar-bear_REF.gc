;;-*-Lisp-*-
(in-package goal)

;; definition of type v-bear
(deftype v-bear (wcar-base)
  ()
  )

;; definition for method 3 of type v-bear
(defmethod inspect ((this v-bear))
  (when (not this)
    (set! this this)
    (goto cfg-4)
    )
  (let ((t9-0 (method-of-type wcar-base inspect)))
    (t9-0 this)
    )
  (label cfg-4)
  this
  )

;; definition for method 115 of type v-bear
;; INFO: function output is handled by mips2c
(defmethod-mips2c "(method 115 v-bear)" 115 v-bear)

;; definition for method 100 of type v-bear
;; INFO: function output is handled by mips2c
(defmethod-mips2c "(method 100 v-bear)" 100 v-bear)

;; definition for method 66 of type v-bear
