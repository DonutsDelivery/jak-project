(in-package goal)

;; definition of type v-tiger
(deftype v-tiger (wcar-base)
  ()
  )

;; definition for method 3 of type v-tiger
(defmethod inspect ((this v-tiger))
  (when (not this)
    (set! this this)
    (goto cfg-4)
    )
  (let ((t9-0 (method-of-type wcar-base inspect)))
    (t9-0 this)
    )
  (label cfg-4)
  this
  )

;; definition for method 69 of type v-tiger
;; INFO: function output is handled by mips2c
(defmethod-mips2c "(method 69 v-tiger)" 69 v-tiger)

