;;-*-Lisp-*-
(in-package goal)

;; definition of type v-gila
(deftype v-gila (wcar-base)
  ()
  )

;; definition for method 3 of type v-gila
(defmethod inspect ((this v-gila))
  (when (not this)
    (set! this this)
    (goto cfg-4)
    )
  (let ((t9-0 (method-of-type wcar-base inspect)))
    (t9-0 this)
    )
  (label cfg-4)
  this
  )

;; definition for method 115 of type v-gila
;; INFO: function output is handled by mips2c
(defmethod-mips2c "(method 115 v-gila)" 115 v-gila)

;; definition for method 100 of type v-gila
;; INFO: function output is handled by mips2c
(defmethod-mips2c "(method 100 v-gila)" 100 v-gila)

;; definition for method 66 of type v-gila
