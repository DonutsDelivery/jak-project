(define *desert-mood-color-table* (the-as mood-color-table L21))

;; definition for symbol *sandstorm-start-mood-color-table*, type mood-color-table
(define *sandstorm-start-mood-color-table* (the-as mood-color-table L20))

;; definition for symbol *sandstorm-end-mood-color-table*, type mood-color-table
(define *sandstorm-end-mood-color-table* (the-as mood-color-table L19))

