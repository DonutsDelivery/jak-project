;; definition for function view-get-real-active
(defun view-get-real-active ()
  (with-pp
    (cond
      ((and pp (-> pp view))
       (-> pp view)
       )
      ((>= *view-context-stack-ptr* 0)
       (-> *views* (-> *view-context-stack* *view-context-stack-ptr*))
       )
      (else
        (the-as view #f)
        )
      )
    )
  )

;; definition for function view-get-active
(defun view-get-active ()
  (with-pp
    (cond
      ((and pp (-> pp view))
       (-> pp view)
       )
      ((>= *view-context-stack-ptr* 0)
       (-> *views* (-> *view-context-stack* *view-context-stack-ptr*))
       )
      (else
        (when *view-assert*
          (break!)
          0
          )
        (-> *views* *view-default*)
        )
      )
    )
  )

;; definition for function view-get-index
(defun view-get-index ((arg0 view))
  (if arg0
      (-> arg0 index)
      -1
      )
  )

;; definition for function view-get-active-index
(defun view-get-active-index ()
  (with-pp
    (let ((v1-1 (cond
                  ((and pp (-> pp view))
                   (-> pp view)
                   )
                  ((>= *view-context-stack-ptr* 0)
                   (-> *views* (-> *view-context-stack* *view-context-stack-ptr*))
                   )
                  (else
                    (when *view-assert*
                      (break!)
                      0
                      )
                    (-> *views* *view-default*)
                    )
                  )
                )
          )
      (if v1-1
          (-> v1-1 index)
          -1
          )
      )
    )
  )

;; definition for function view-get-real-active-index
(defun view-get-real-active-index ()
  (let ((v1-0 (view-get-real-active)))
    (if v1-0
        (-> v1-0 index)
        -1
        )
    )
  )

;; definition for function view-print
;; WARN: Return type mismatch int vs none.
(defun view-print ((arg0 view))
  (let ((t9-0 format)
        (v1-0 #t)
        (a1-0 "[~D]")
        (a0-1 (the-as object (-> arg0 target)))
        )
    (t9-0 v1-0 a1-0 (if (the-as basic a0-1)
                        (-> (the-as (pointer int8) a0-1) 0)
                        -1
                        )
          )
    )
  0
  (none)
  )

;; failed to figure out what this is:
(dotimes (gp-0 2)
  (format 0 "allocating view ~D~%" gp-0)
  (set! (-> *views* gp-0) (new 'global 'view))
  (set! (-> *views* gp-0 camera) #f)
  (set! (-> *views* gp-0 camera-combiner) #f)
  (set! (-> *views* gp-0 target) #f)
  (set! (-> *views* gp-0 math-camera) (new 'global 'math-camera))
  (set! (-> *views* gp-0 index) gp-0)
  )




