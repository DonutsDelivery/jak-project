;;-*-Lisp-*-
(in-package goal)

;; definition of type process-focusable
(deftype process-focusable (process-drawable)
  ((self          process-focusable           :override)
   (ppointer      (pointer process-focusable) :override)
   (focus-status  uint64)
   )
  (:methods
    (process-focusable-method-50 (_type_) int)
    (process-focusable-method-51 (_type_ int) object)
    (process-focusable-method-52 (_type_) vector)
    (process-focusable-method-53 (_type_) vector)
    (process-focusable-method-54 (_type_) int)
    (process-focusable-method-55 (_type_) int)
    (process-focusable-method-56 (_type_) int)
    (process-focusable-method-57 (_type_) int)
    (process-focusable-method-58 (_type_ vector) float)
    )
  )

;; definition for method 3 of type process-focusable
(defmethod inspect ((this process-focusable))
  (when (not this)
    (set! this this)
    (goto cfg-4)
    )
  (let ((t9-0 (method-of-type process-drawable inspect)))
    (t9-0 this)
    )
  (format #t "~2Tfocus-status: ~D~%" (-> this focus-status))
  (label cfg-4)
  this
  )

;; definition for method 50 of type process-focusable
(defmethod process-focusable-method-50 ((this process-focusable))
  (let ((v0-0 0))
    (let ((v1-0 (-> this mask)))
      (if (logtest? (process-mask crate) v1-0)
          (set! v0-0 (logior v0-0 2))
          )
      (if (logtest? (process-mask enemy) v1-0)
          (set! v0-0 (logior v0-0 16))
          )
      )
    v0-0
    )
  )

;; definition for method 51 of type process-focusable
(defmethod process-focusable-method-51 ((this process-focusable) (arg0 int))
  (let ((gp-0 (-> this root)))
    (cond
      ((zero? arg0)
       (-> gp-0 trans)
       )
      ((and (= arg0 1) (type? gp-0 collide-shape-moving))
       (&-> (the-as collide-shape-moving gp-0) csm-pad-1 200)
       )
      ((and (or (= arg0 2) (= arg0 3) (= arg0 10)) (type? gp-0 collide-shape))
       (-> (the-as collide-shape-moving gp-0) root-prim prim-core)
       )
      (else
        (-> gp-0 trans)
        )
      )
    )
  )

;; definition for method 53 of type process-focusable
(defmethod process-focusable-method-53 ((this process-focusable))
  (-> this root transv)
  )

