;;-*-Lisp-*-
(in-package goal)

;; definition of type driver-ur-86
(deftype driver-ur-86 (driver)
  ()
  )

;; definition for method 3 of type driver-ur-86
(defmethod inspect ((this driver-ur-86))
  (when (not this)
    (set! this this)
    (goto cfg-4)
    )
  (let ((t9-0 (method-of-type driver inspect)))
    (t9-0 this)
    )
  (label cfg-4)
  this
  )

;; failed to figure out what this is:
(defskelgroup skel-driver-ur-86 ur-86-low 1 4
              ((2 (meters 20)) (3 (meters 999999)))
              :bounds (static-spherem 0 0 0 4)
              )

;; definition for method 62 of type driver-ur-86
;; WARN: Return type mismatch int vs none.
(defmethod driver-method-62 ((this driver-ur-86))
  (set! (-> this info-skel)
        (the-as basic (the-as uint8 (level-group-method-22 *level* "skel-driver-ur-86" (the-as (pointer level) #f))))
        )
  (set! (-> this info-turn-back) 6)
  (set! (-> this info-turn-front) 5)
  (set! (-> this info-up-down) 7)
  (set! (-> this info-head-node) 8)
  (set! (-> this info-arm0-node) 9)
  (set! (-> this info-arm1-node) -1)
  (set! (-> this stack 122) (the-as uint -1))
  (set! (-> this stack 123) (the-as uint 7))
  (set! (-> this stack 124) (the-as uint 0))
  (set! (-> this stack 125) (the-as uint 0))
  (set! (-> this info-arm0-dist) 0.0)
  (set! (-> this info-arm1-dist) 0.0)
  0
  (none)
  )




