;;-*-Lisp-*-
(in-package goal)

;; definition of type driver-gtblitz
(deftype driver-gtblitz (driver)
  ()
  )

;; definition for method 3 of type driver-gtblitz
(defmethod inspect ((this driver-gtblitz))
  (when (not this)
    (set! this this)
    (goto cfg-4)
    )
  (let ((t9-0 (method-of-type driver inspect)))
    (t9-0 this)
    )
  (label cfg-4)
  this
  )

;; failed to figure out what this is:
(defskelgroup skel-driver-gtblitz raceblitz 1 4
              ((2 (meters 20)) (3 (meters 999999)))
              :bounds (static-spherem 0 0 0 4)
              )

;; definition for method 62 of type driver-gtblitz
;; WARN: Return type mismatch int vs none.
(defmethod driver-method-62 ((this driver-gtblitz))
  (set! (-> this info-skel)
        (the-as
          basic
          (the-as uint8 (level-group-method-22 *level* "skel-driver-gtblitz" (the-as (pointer level) #f)))
          )
        )
  (set! (-> this info-turn-back) 6)
  (set! (-> this info-turn-front) 5)
  (set! (-> this info-up-down) 7)
  (set! (-> this info-head-node) 8)
  (set! (-> this info-arm0-node) 9)
  (set! (-> this info-arm1-node) 10)
  (set! (-> this stack 122) (the-as uint -1))
  (set! (-> this stack 123) (the-as uint 7))
  (set! (-> this stack 124) (the-as uint 10))
  (set! (-> this stack 125) (the-as uint 13))
  (set! (-> this info-arm0-dist) 3276.8)
  (set! (-> this info-arm1-dist) 3276.8)
  0
  (none)
  )

;; definition for method 64 of type driver-gtblitz
(defmethod driver-method-64 ((this driver-gtblitz))
  (if (and (= (if *net-world*
                  (the-as int (-> *net-world* task-node-info net-play-mode))
                  18
                  )
              17
              )
           (nonzero? (-> this draw))
           )
      (setup-masks (-> this draw) 0 2)
      )
  0
  )




