;; definition of type animation-info
(deftype animation-info (structure)
  ((enter-anim    int32)
   (exit-anim     int32)
   (running-anim  int32)
   (anim-speed    float)
   (enter-delay   uint32)
   (pad20         uint32  3)
   (3d-offset     vector  :inline :offset  32)
   (3d-offset-x   float           :overlay-at (-> 3d-offset x))
   (3d-offset-y   float           :overlay-at (-> 3d-offset y))
   (3d-offset-z   float           :overlay-at (-> 3d-offset z))
   (3d-offset-w   float           :overlay-at (-> 3d-offset w))
   )
  )

;; definition for method 3 of type animation-info
(defmethod inspect ((this animation-info))
  (when (not this)
    (set! this this)
    (goto cfg-4)
    )
  (format #t "[~8x] ~A~%" this 'animation-info)
