;; definition of type car-level-array
(deftype car-level-array (basic)
  ((data      car-info-full  6 :inline)
   (textures  car-textures   6 :inline)
   )
  (:methods
    (car-level-array-method-9 (_type_) int)
    )
  )

;; definition for method 3 of type car-level-array
(defmethod inspect ((this car-level-array))
  (when (not this)
    (set! this this)
    (goto cfg-4)
    )
  (format #t "[~8x] ~A~%" this (-> this type))
  (format #t "~1Tdata[6] @ #x~X~%" (-> this data))
  (format #t "~1Ttextures[6] @ #x~X~%" (-> this textures))
  (label cfg-4)
  this
  )

