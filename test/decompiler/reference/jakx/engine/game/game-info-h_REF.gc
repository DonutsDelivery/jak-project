   (traction-multiplier                   float)
   (turbo-factor                          float)
   (turbo-disabled                        int8)
   (turbo-last-disabled                   int32)
   (fragile-vehicle                       basic)
   (music-data                            uint8             4)
   (music-info                            uint32               :overlay-at (-> music-data 0))
   (game-movie                            (array game-movie))
   (grand-prix                            (array grand-prix))
   (playing-grand-prix?                   grand-prix)
   (grand-prix-index                      uint32)
   (collision-vs-rbody-damage-multiplier  float)
   (global-speed-factor                   float)
   (this-race-grand-prix-score            uint32            23)
   (cumulative-grand-prix-score           uint32            23)
   (driver-info                           uint64)
   (driver-info2                          uint32            2  :overlay-at driver-info)
   (driver-unlock                         uint32               :overlay-at driver-info)
   (driver-award                          uint32               :overlay-at (-> driver-info2 1))
   )
  (:methods
    (game-info-method-9 (_type_) none)
    (game-info-method-10 (_type_ symbol float handle) float)
    (game-info-method-11 (_type_ game-task) symbol)
    (game-info-method-12 (_type_ string) int)
    (game-info-method-13 (_type_ actor-id) none)
    (game-info-method-14 (_type_ int) none)
    (game-info-method-15 (_type_ level) none)
    (game-info-method-16 (_type_ level) int)
    (game-info-method-17 (_type_ symbol) _type_)
    (game-info-method-18 (_type_ string) continue-point)
    (game-info-method-19 (_type_ string) continue-point)
    (game-info-method-20 (_type_ basic symbol) continue-point)
    (game-info-method-21 (_type_) int)
    (game-info-method-22 (_type_) none)
    (game-info-method-23 (_type_) none)
    (game-info-method-24 (_type_ symbol int) int)
    (you-suck-scale (_type_ symbol int) float)
    (get-next-attack-id! (_type_) uint)
    (game-info-method-27 (_type_) none)
    (game-info-method-28 (_type_ int) (pointer float))
    (game-info-method-29 (_type_ int) int)
    (game-info-method-30 (_type_ int float) none)
    )
  )

