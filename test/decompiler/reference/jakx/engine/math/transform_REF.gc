;;-*-Lisp-*-
(in-package goal)

;; definition for method 0 of type trsq
(defmethod new trsq ((allocation symbol) (type-to-make type))
  (let ((gp-0 (object-new allocation type-to-make (the-as int (-> type-to-make size)))))
    (set! (-> gp-0 trans w) 1.0)
    (set! (-> gp-0 rot w) 1.0)
    (vector-identity! (-> gp-0 scale))
    gp-0
    )
  )




