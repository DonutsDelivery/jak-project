;; definition of type rigid-body-object
(deftype rigid-body-object (process-focusable)
  ((info                rigid-body-object-constants)
   (flags               rigid-body-object-flag)
   (max-time-step       float)
   (incoming-attack-id  uint32)
   (disturbed-time      uint32)
   (perf                rb-perf-data)
   )
  (:methods
    (rigid-body-object-method-59 (_type_) none)
    (rigid-body-object-method-60 (_type_) none)
    (rigid-body-object-method-61 (_type_) int)
    (rigid-body-object-method-62 (_type_ float) int)
    (rigid-body-object-method-63 (_type_) int)
    (rigid-body-object-method-64 (_type_ object) none)
    (rigid-body-object-method-65 (_type_) int)
    (rigid-body-object-method-66 (_type_) int)
    (rigid-body-object-method-67 (_type_) none)
    (rigid-body-object-method-68 (_type_ object object) int)
    (rigid-body-object-method-69 (_type_) int)
    (rigid-body-object-method-70 (_type_) int)
    (rigid-body-object-method-71 (_type_) none)
    (rigid-body-object-method-72 (_type_) none)
    (rigid-body-object-method-73 (_type_) none)
    (rigid-body-object-method-74 (_type_) none)
    (rigid-body-object-method-75 (_type_) none)
    (rigid-body-object-method-76 (_type_) none)
    (rigid-body-object-method-77 (_type_) none)
    (rigid-body-object-method-78 (_type_ object object) int)
    (rigid-body-object-method-79 (_type_ object object) none)
    (rigid-body-object-method-80 (_type_ object) int)
    (rigid-body-object-method-81 (_type_ object object object object) none)
    (rigid-body-object-method-82 (_type_ object object object object) symbol)
    (rigid-body-object-method-83 (_type_ object object) symbol)
    (rigid-body-object-method-84 (_type_ rigid-body-impact touching-shapes-entry) none)
    (rigid-body-object-method-85 (_type_) int)
    (rigid-body-object-method-86 (_type_) int)
    (rigid-body-object-method-87 (_type_) int)
    (rigid-body-object-method-88 (_type_) int)
    )
  )

;; definition for method 3 of type rigid-body-object
(defmethod inspect ((this rigid-body-object))
  (when (not this)
    (set! this this)
    (goto cfg-12)
    )
  (let ((t9-0 (method-of-type process-focusable inspect)))
    (t9-0 this)
    )
  (format #t "~2Tinfo: #<rigid-body-object-constants @ #x~X>~%" (-> this info))
  (format #t "~2Tflags: #x~X : (rigid-body-object-flag " (-> this flags))
  (let ((s5-0 (-> this flags)))
    (if (= (logand s5-0 (rigid-body-object-flag dead)) (rigid-body-object-flag dead))
        (format #t "dead ")
        )
    (if (= (logand s5-0 (rigid-body-object-flag damaged)) (rigid-body-object-flag damaged))
        (format #t "damaged ")
        )
    (if (= (logand s5-0 (rigid-body-object-flag disturbed)) (rigid-body-object-flag disturbed))
        (format #t "disturbed ")
        )
    (if (= (logand s5-0 (rigid-body-object-flag enable-collision)) (rigid-body-object-flag enable-collision))
        (format #t "enable-collision ")
        )
    )
  (format #t ")~%")
  (format #t "~2Tmax-time-step: ~f~%" (-> this max-time-step))
  (format #t "~2Tincoming-attack-id: ~D~%" (-> this incoming-attack-id))
  (format #t "~2Tdisturbed-time: ~D~%" (-> this disturbed-time))
  (format #t "~2Tperf: #<rb-perf-data @ #x~X>~%" (-> this perf))
  (label cfg-12)
  this
  )

;; definition of type rigid-body-queue
(deftype rigid-body-queue (structure)
  ((count    int8)
   (manager  uint64)
   (array    handle  128)
   )
  (:methods
    (rigid-body-queue-method-9 (_type_ process) none)
    (rigid-body-queue-method-10 (_type_) none)
